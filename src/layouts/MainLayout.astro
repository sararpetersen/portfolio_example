          },
        };

        function apply(lang) {
          document.querySelectorAll("[data-i18n]").forEach(function (el) {
            var key = el.getAttribute("data-i18n");
            if (t[lang] && t[lang][key] !== undefined) {
              el.innerHTML = t[lang][key];
            }
          });
          document.documentElement.lang = lang === "da" ? "da" : "en";
          var enBtn = document.getElementById("lang-toggle-en");
          var daBtn = document.getElementById("lang-toggle-da");
          if (enBtn && daBtn) {
            enBtn.setAttribute("aria-pressed", lang === "en" ? "true" : "false");
            daBtn.setAttribute("aria-pressed", lang === "da" ? "true" : "false");
            enBtn.classList.toggle("active-lang", lang === "en");
            daBtn.classList.toggle("active-lang", lang === "da");
          }
        }

        return {
          apply: apply,
          setLang: function (lang) {
            localStorage.setItem("lang", lang);
            apply(lang);
            window.dispatchEvent(new CustomEvent("langchange", { detail: { lang: lang } }));
          },
          getLang: function () {
            return localStorage.getItem("lang") || "en";
          },
        };
      })();

      document.addEventListener("DOMContentLoaded", function () {
        window.__i18n.apply(window.__i18n.getLang());
      });
    </script>
