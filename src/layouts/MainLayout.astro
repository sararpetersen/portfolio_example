            "terms.privacy.h3.controller": "Dataansvarlig",
            "terms.privacy.p.controller": "Sara Ringkow Petersen – <a href='mailto:sara.ringkow@gmail.com'>sara.ringkow@gmail.com</a>",
            "terms.booking.sub": "Sådan arbejder vi sammen",
