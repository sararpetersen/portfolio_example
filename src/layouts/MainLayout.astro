    outline: 2px solid var(--brand-primary-soft, #c0d7e1);
    outline-offset: 2px;
  }

  body.dark .skip-link {
    background: #f0f0f0;
    color: #1a1a1a;
    transition:
      transform 0.2s ease,
      background-color 0.3s ease-in-out,
      color 0.3s ease-in-out;
  }

  body.dark .skip-link:hover {
    background: var(--brand-primary-soft, #c0d7e1);
    color: #1a1a1a;
  }

  body.dark .skip-link:focus,
  body.dark .skip-link:focus-visible {
    outline: 2px solid #ff6f61;
    outline-offset: 2px;
  }

  /* When hinting, slide down to just below the accessibility bar (36px = h-9) */
  body.show-skip-link-hint .skip-link {
    transform: translateY(calc(36px + 0.5rem));
  }

  body.dark {
    background: var(--dark-bg);
    color: var(--text-on-dark);
    box-shadow: none;
  }

  body.dark .toggle-switch {
