<style>
  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    z-index: 100;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    background: #1f2937;
    color: #f9fafb;
    text-decoration: none;
    transform: translateY(-180%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus,
  .skip-link:focus-visible {
    transform: translateY(0);
    outline: 2px solid #c0d7e1;
    outline-offset: 2px;
  }

  /* When hinting, slide down to just below the accessibility bar (36px = h-9) */
  body.show-skip-link-hint .skip-link {
    transform: translateY(calc(36px + 0.5rem));
  }

  body.dark {
    background: var(--dark-bg);
    color: var(--text-on-dark);
    box-shadow: none;
  }

  body.dark .toggle-switch {
    background-color: #4b5563;
  }
  body.dark .toggle-switch[aria-pressed="true"] {
    background-color: #94a3b8;
  }
  body.dark .toggle-circle {
    background-color: #f0f0f0;
  }
</style>

<script>
  import { animate } from "motion";
  /*Entrance Animation*/
  animate("body", { opacity: [0, 1] }, { duration: 1 });

  // Briefly reveal the skip link for first-time visitors to improve discoverability.
  const skipHintSeenKey = "skipLinkHintSeen";
  if (localStorage.getItem(skipHintSeenKey) !== "true") {
    document.body.classList.add("show-skip-link-hint");
    setTimeout(() => {
      document.body.classList.remove("show-skip-link-hint");
      localStorage.setItem(skipHintSeenKey, "true");
    }, 2800);
  }
</script>
