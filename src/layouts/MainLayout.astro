---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import AccessibilityPanel from "../components/AccessibilityPanel.astro";
import "../styles/tailwind.css";
import "animate.css";
import "../styles/global.css";
const siteUrl = "https://sararingkow.dk/";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL("/images/hero_image.webp", siteUrl).toString();

const schemamarkup = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Sara Ringkow Petersen",
  url: "https://sararingkow.dk/",
  email: "sara.ringkow@gmail.com",
  jobTitle: "Multimedia Designer & Concept Developer",
  description:
    "Multimedia Designer and Concept Developer based in Denmark, specialising in accessible, user-centred digital experiences that combine UX/UI design, web design, and inclusive design principles.",
  knowsAbout: [
    "UX Design",
    "UI Design",
    "Accessibility",
    "Inclusive Design",
    "Accessible Web Design",
    "Web Design",
    "Visual Communication",
    "Digital Prototyping",
    "Astro",
    "Tailwind CSS",
    "JavaScript",
    "TypeScript",
    "Figma",
    "Concept Development",
  ],
  alumniOf: [
    { "@type": "EducationalOrganization", name: "Copenhagen School of Design and Technology (KEA)", description: "Multimedia Design" },
    { "@type": "EducationalOrganization", name: "Academy of Technologies and Business (Zealand)", description: "Digital Concept Development" },
  ],
  address: { "@type": "PostalAddress", addressCountry: "DK" },
  sameAs: ["https://www.linkedin.com/in/sara-ringkow-petersen-49830b264/", "https://github.com/sararpetersen", "https://sararingkow.dk/"],
};
