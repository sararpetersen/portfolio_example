            "modal.terms.link": "Læs de fulde vilkår →",
            "terms.updated": "Sidst opdateret: 25. juni 2026",
            "terms.privacy.sub": "Hvad der indsamles og hvorfor",
            "terms.privacy.h3.collected": "Indsamlet data",
            "terms.privacy.p.collected1":
