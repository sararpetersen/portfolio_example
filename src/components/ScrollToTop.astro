---

<!-- Scroll-to-Top Button -->
<button
  id="scrollToTop"
  class="fixed md:bottom-8 md:right-8 bottom-5 right-5 w-14 h-14 rounded-full text-gray-50 focus:outline-none focus:ring-2 focus:ring-red-200 hover:-translate-y-1 transition-all duration-300 ease-out opacity-0 invisible pointer-events-none z-[999] shadow-lg"
  aria-label="Scroll to top"
  title="Back to top"
>
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-7 h-7 mx-auto">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
  </svg>
</button>

<script>
  const scrollToTopButton = document.getElementById("scrollToTop");

  if (scrollToTopButton) {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const updateScrollToTopUi = () => {
      const y = window.scrollY;

      if (y > 320) {
        scrollToTopButton.classList.remove("opacity-0", "invisible", "pointer-events-none");
        scrollToTopButton.classList.add("opacity-100", "visible", "pointer-events-auto");
      } else {
        scrollToTopButton.classList.remove("opacity-100", "visible", "pointer-events-auto");
        scrollToTopButton.classList.add("opacity-0", "invisible", "pointer-events-none");
      }
    };

    scrollToTopButton.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: prefersReducedMotion ? "auto" : "smooth" });
    });

    updateScrollToTopUi();
    window.addEventListener("scroll", updateScrollToTopUi, { passive: true });
    window.addEventListener("resize", updateScrollToTopUi);
  }
</script>

<style>
  #scrollToTop {
    position: fixed;
    display: grid;
    place-items: center;
    isolation: isolate;
    background: #bb4a34;
    border: 1px solid #bb4a34;
    color: #f7f3ef;
  }

  #scrollToTop:hover {
    background: #a8412d;
    border-color: #a8412d;
  }

  body.calm-mode #scrollToTop {
    background: #8e7b79;
    border-color: #8e7b79;
  }

  body.calm-mode #scrollToTop:hover {
    background: #7d6c6a;
    border-color: #7d6c6a;
  }
</style>
