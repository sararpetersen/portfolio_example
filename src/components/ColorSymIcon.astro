---
// Inline ColorSym glyphs — a symbol-per-colour system so colour-coded tags on this
// site can be identified by shape, not just hue, for colourblind visitors.
// Decorative reinforcement only: the tag's own text is what actually conveys meaning,
// so the icon stays aria-hidden to avoid a redundant screen-reader announcement.
// Only the letters actually used on the site are included — extend as needed.
interface Props {
  letter: "B" | "O" | "G" | "R";
  class?: string;
}

const { letter, class: className = "" } = Astro.props;

const paths: Record<Props["letter"], string> = {
  B: "M50.41,39.65c.99,1.06.93,2.73-.13,3.72-.51.47-1.15.71-1.79.71-.7,0-1.41-.28-1.92-.84l-13.01-13.98-13.26,14c-1,1.06-2.67,1.1-3.72.1-1.05-1-1.1-2.66-.1-3.71l15.19-16.03c.5-.52,1.19-.82,1.91-.82h0c.73,0,1.42.31,1.91.84l14.92,16.03h0v-.02Z",
  O: "M51.11,43.23c0,1.45-1.18,2.63-2.63,2.63h-30.11c-1.45,0-2.63-1.17-2.63-2.63s1.18-2.63,2.63-2.63h30.11c1.45,0,2.63,1.17,2.63,2.63ZM28.24,26.19c0-2.86,2.33-5.19,5.19-5.19s5.19,2.33,5.19,5.19-2.33,5.19-5.19,5.19-5.19-2.33-5.19-5.19Z",
  G: "M20.28,36.64c-1,1.06-2.67,1.1-3.72.1-1.05-1-1.1-2.66-.1-3.71l15.19-16.03c.5-.52,1.19-.82,1.91-.82.7.12,1.43.3,1.92.84l14.92,16.03c.99,1.06.93,2.73-.13,3.72-.5.47-1.15.7-1.79.7-.7,0-1.41-.28-1.92-.84l-13.01-13.98-13.26,14h-.01ZM51.11,47.63c0,1.45-1.18,2.63-2.63,2.63h-30.11c-1.45,0-2.63-1.18-2.63-2.63s1.18-2.63,2.63-2.63h30.11c1.45,0,2.63,1.18,2.63,2.63Z",
  R: "M38.61,33.51c0,2.86-2.33,5.19-5.19,5.19s-5.19-2.33-5.19-5.19,2.33-5.19,5.19-5.19,5.19,2.33,5.19,5.19Z",
};
---

<svg
  class={`colorsym-icon ${className}`}
  viewBox="0 0 66.86 66.86"
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d={paths[letter]}></path>
</svg>

<style>
  .colorsym-icon {
    width: 1.15em;
    height: 1.15em;
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>
