---
import "../styles/global.css";
---

<!-- Torii icon -->
<div id="torii-icon" class="flex justify-center items-center pb-6 pointer-events-none">
  <img src="/images/torii.svg" alt="" aria-hidden="true" class="w-[400px] h-auto" width="1956" height="582" loading="lazy" />
</div>

<!-- Terms modal (backdrop is the container itself) -->
<div id="terms-modal" role="dialog" aria-modal="true" aria-labelledby="terms-modal-title" aria-hidden="true">
  <div id="terms-modal-panel">
    <div id="terms-modal-header">
      <h2 id="terms-modal-title" class="font-garamond font-semibold italic text-h3-mobile md:text-h3-desktop" data-i18n="modal.terms.title">
        Terms & Privacy
      </h2>
      <button id="terms-modal-close" aria-label="Close terms">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"></path></svg
        >
      </button>
    </div>
    <div id="terms-modal-body">
      <section class="terms-modal-section">
        <h3 class="text-h4-mobile font-garamond font-bold tracking-[0.1em] uppercase text-gray-800" data-i18n="modal.terms.privacy">
          Privacy policy
        </h3>
        <p class="text-gray-600 leading-relaxed mb-2" data-i18n="modal.terms.privacy.p1">
          When you submit the contact form, your name, email, and message are processed by <a
            href="https://www.netlify.com/privacy/"
            class="terms-link text-blue-500 hover:underline"
            target="_blank"
            rel="noopener noreferrer">Netlify Forms</a
          > solely to respond to your enquiry. Accessibility preferences are stored in your browser's <code class="text-[14px]">localStorage</code> only&mdash;
          no personal data leaves your device. No cookies, no tracking, no third-party marketing.
        </p>
        <p class="text-gray-600 leading-relaxed mb-3" data-i18n="modal.terms.privacy.p2">
          <strong>Your rights <em>(GDPR)</em>:</strong> You may request access to, correction of, or deletion of your data at any time - email: <a
            href="mailto:sara.ringkow@gmail.com"
            class="terms-link text-blue-500 hover:underline">sara.ringkow@gmail.com</a
          >.
        </p>
      </section>

      <hr class="terms-modal-divider" />

      <section class="terms-modal-section">
        <h3 class="text-h4-mobile font-garamond font-bold tracking-[0.1em] uppercase text-gray-800 mt-3" data-i18n="modal.terms.booking">
          Booking & freelance terms
        </h3>
        <p class="text-gray-600 leading-relaxed mb-2" data-i18n="modal.terms.booking.p1">
          I take on projects case by case. A written quote is provided before work starts&mdash; no surprises. Two rounds of revisions are included.
          Upon full payment you receive a licence to use agreed deliverables; I retain the right to show the work in my portfolio unless
          confidentiality is agreed.
        </p>
        <p class="text-gray-600 leading-relaxed mb-3" data-i18n="modal.terms.booking.p2">
          Cancellations must be in writing. Work completed up to that point may be invoiced.
        </p>
      </section>

      <hr class="terms-modal-divider" />

      <section class="terms-modal-section">
        <h3 class="text-h4-mobile font-garamond font-bold tracking-[0.1em] uppercase text-gray-800 mt-3" data-i18n="modal.terms.use">Terms of use</h3>
        <p class="text-gray-600 leading-relaxed mb-3" data-i18n="modal.terms.use.p1">
          All content on this portfolio belongs to Sara Ringkow Petersen <em>(me)</em>. Do not reproduce or republish without written permission.
          External links are provided for reference only. These terms are governed by Danish law.
        </p>
      </section>

      <a href="/terms" class="terms-modal-fulllink" data-i18n="modal.terms.link">Read full terms →</a>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="bg-gray-800 py-6 md:px-4 px-6">
  <div class="container mx-auto flex flex-col items-start md:flex-row md:justify-between">
    <!-- Logo -->
    <div
      id="footer-logo"
      class="flex justify-start md:justify-center items-center relative font-bold transition-opacity duration-300 ease-in-out mb-8 md:mb-0"
    >
      <a href="/" class="group w-20 h-20">
        <img
          src="/logo_white.svg"
          alt="Logo for my website, with two of my initials"
          class="object-contain w-full h-full transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02]"
          width="80"
          height="80"
          loading="lazy"
        />
      </a>
    </div>

    <!-- Navigation Links -->
    <nav aria-label="Footer navigation" class="some1 flex md:flex-row flex-col items-start mb-8 md:mb-0 gap-12">
      <div class="flex flex-col md:flex-row items-start md:gap-8 gap-0">
        <div class="flex flex-col items-start">
          <a
            href="/"
            aria-label="Go to homepage"
            class="py-1 text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
            data-i18n="nav.home">Home</a
          >
          <a
            href="/about_me"
            aria-label="Go to about-page"
            class="py-1 text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
            data-i18n="nav.about">About</a
          >
          <a
            href="/contact"
            aria-label="Go to contact-page"
            class="py-1 text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
            data-i18n="nav.contact">Contact</a
          >
        </div>
        <div class="flex flex-col items-start">
          <a
            href="/blog"
            aria-label="Go to blog overview"
            class="py-1 text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
            data-i18n="nav.blog">Blog</a
          >
          <a
            href="/lab"
            aria-label="Go to lab"
            class="py-1 text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
            data-i18n="nav.lab">Lab</a
          >
        </div>
      </div>
    </nav>

    <!-- Social Media Links -->
    <div id="footer-social" class="flex flex-col items-start justify-center mb-4 md:mb-0">
      <div class="flex space-x-3 justify-evenly max-w-xs">
        <a
          href="https://www.linkedin.com/in/sara-ringkow-petersen-49830b264/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Go to my LinkedIn-profile (external link)"
          class="flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
        >
          <svg
            class="w-[40] h-[40] text-gray-50 hover:-translate-y-1 transition-transform duration-300 ease-in-out"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="45"
            height="45"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              fill-rule="evenodd"
              d="M12.51 8.796v1.697a3.738 3.738 0 0 1 3.288-1.684c3.455 0 4.202 2.16 4.202 4.97V19.5h-3.2v-5.072c0-1.21-.244-2.766-2.128-2.766-1.827 0-2.139 1.317-2.139 2.676V19.5h-3.19V8.796h3.168ZM7.2 6.106a1.61 1.61 0 0 1-.988 1.483 1.595 1.595 0 0 1-1.743-.348A1.607 1.607 0 0 1 5.6 4.5a1.601 1.601 0 0 1 1.6 1.606Z"
              clip-rule="evenodd"></path>
