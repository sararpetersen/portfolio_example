            width="33"
            height="33"
            fill="currentColor"
            class="text-gray-50 hover:-translate-y-1 transition-transform duration-300 ease-in-out"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/srp_portfolio/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Go to my Instagram-profile (external link)"
          class="flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="33"
            height="33"
            fill="currentColor"
            class="text-gray-50 hover:-translate-y-1 transition-transform duration-300 ease-in-out"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Contact Information -->
    <div id="footer-contact" class="flex flex-col items-start md:mt-0 mt-8 mb-8 md:mb-0 last:mb-0">
      <div class="some1 flex items-center py-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-4 h-4 mr-2 text-gray-50"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path>
        </svg>
        <a
          href="mailto:sara.ringkow@gmail.com"
          class="text-gray-50 py-1 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
          aria-label="Send an email to 'sara.ringkow@gmail.com'">sara.ringkow@gmail.com</a
        >
      </div>
      <div class="some1 flex items-center py-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-4 h-4 mr-2 text-gray-50"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          ></path>
        </svg>
        <a
          href="tel:+4542428807"
          class="text-gray-50 py-1 focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
          aria-label="Call '+45 42 42 88 07'">+45 42 42 88 07</a
        >
      </div>
    </div>
  </div>

  <!-- Bottom strip: copyright + terms -->
  <div
    id="footer-bottom"
    class="container mx-auto mt-6 pt-4 border-t border-gray-700 flex flex-col md:flex-row items-start md:items-center justify-between gap-2"
  >
    <p class="text-gray-400 text-xs" data-i18n="footer.copyright">© 2026 SRP Portfolio - Sara Ringkow Petersen. All rights reserved.</p>
    <button
      id="terms-modal-trigger"
      class="text-gray-400 text-xs border border-gray-600 rounded-full px-3 py-1 hover:text-gray-100 hover:border-gray-400 hover:bg-gray-700 transition duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
      aria-haspopup="dialog"
      data-i18n="modal.terms.title"
    >
      Terms &amp; Privacy
    </button>
  </div>
</footer>

<style>
  /* Terms modal — container IS the backdrop */
  #terms-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.45);
    cursor: pointer;
  }
  #terms-modal.open {
    display: block;
  }

  #terms-modal-panel {
    position: absolute;
    z-index: 1;
    bottom: 0;
    cursor: default;
    left: 0;
    right: 0;
    max-height: 75vh;
    background: #f7f3ef;
    border-radius: 1.25rem 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.3s ease;
  }
  @media (min-width: 768px) {
    #terms-modal-panel {
      top: 50%;
      bottom: auto;
      left: 50%;
      right: auto;
      transform: translate(-50%, -50%);
      width: 640px;
      max-width: calc(100vw - 2rem);
      max-height: 80vh;
      border-radius: 1.25rem;
      animation: fadeIn 0.25s ease;
    }
  }
  @keyframes slideUp {
    from {
      transform: translateY(100%);
    }
    to {
      transform: translateY(0);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translate(-50%, -48%);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }
  #terms-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid #dcd6d0;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    background: #f7f3ef;
  }
  #terms-modal-title {
    font-weight: 600;
    color: #1a1a1a;
  }

  #terms-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1.5px solid #bfb7b0;
    background: transparent;
    color: #4b4b4b;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  #terms-modal-close:hover {
    background: #2f3f4c;
    border-color: #2f3f4c;
    color: #f7f3ef;
  }
  #terms-modal-close:focus-visible {
    outline: 2px solid #477b93;
    outline-offset: 2px;
  }

  #terms-modal-body {
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  :global(.terms-modal-section a) {
    color: #477b93;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  :global(.terms-modal-section a:hover) {
    color: #334857;
  }
  .terms-modal-section code {
    background: #f0ebe6;
    padding: 1px 4px;
    border-radius: 3px;
    font-family: monospace;
  }
  .terms-modal-divider {
    border: none;
    border-top: 1px solid #dcd6d0;
    margin: 0.125rem 0;
  }
  .terms-modal-fulllink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 24px;
    border: 2px solid #2f3f4c;
    border-radius: 5px;
    background: #2f3f4c;
    color: #f9fafb;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
    transition:
      background 0.3s ease-in-out,
      color 0.3s ease-in-out,
      border-color 0.3s ease-in-out;
    width: fit-content;
  }
  .terms-modal-fulllink:hover {
    background: #375567;
    color: #f9fafb;
    border-color: #375567;
  }
  .terms-modal-fulllink:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px #93c5fd;
  }
  .terms-modal-fulllink::before {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 0.3rem;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(230, 57, 70, 0.72), transparent);
    opacity: 0.55;
    transform: scaleX(0.45);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }
  .terms-modal-fulllink:hover::before,
  .terms-modal-fulllink:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  /* Dark mode modal */
  body.dark #terms-modal-panel,
  body.dark #terms-modal-header {
    background: var(--dark-bg, #1a1a1a);
  }

  :global(body.dark .terms-modal-section a) {
    color: var(--brand-primary-soft, #c0d7e1);
  }
  :global(body.dark .terms-modal-section a:hover) {
    color: var(--brand-primary-strong, #95bccb);
  }

  body.dark #terms-modal-title {
    color: var(--text-on-dark, #f0f0f0);
  }
  body.dark #terms-modal-header,
  body.dark .terms-modal-divider {
    border-color: var(--dark-border, #333);
  }
  body.dark .terms-modal-section p {
    color: var(--text-on-dark-soft, #c0c0c0);
  }
  body.dark .terms-modal-section h3 {
    color: #c0d7e1;
  }
  body.dark #terms-modal-close {
    border-color: var(--dark-border, #333);
    color: var(--text-on-dark-soft, #c0c0c0);
  }
  body.dark #terms-modal-close:hover {
    background: #c0d7e1;
    border-color: #c0d7e1;
    color: #1a1a1a;
  }
  body.dark .terms-modal-section code {
    background: var(--dark-surface, #2a2a2a);
    color: var(--text-on-dark-soft);
  }
  body.dark .terms-modal-fulllink {
    color: #f6f6f6;
    border-color: #f6f6f6;
    background: transparent;
  }
  body.dark .terms-modal-fulllink:hover {
    background: var(--brand-primary-soft);
    color: #1a1a1a;
    border-color: var(--brand-primary-soft);
  }

  footer a:hover {
    color: var(--brand-primary-soft);
  }

  footer #footer-social a:hover svg {
    color: var(--brand-primary-soft);
  }

  .some1 a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark footer {
    border-top: 1px solid #333;
    background: var(--dark-bg);
  }
  body.dark #footer-bottom {
    border-color: var(--dark-border, #333);
  }
  body.dark #footer-bottom p {
    color: var(--text-on-dark-soft, #c0c0c0);
  }
  body.dark #terms-modal-trigger {
    color: var(--text-on-dark-soft, #c0c0c0);
    border-color: #4a4a4a;
  }
  body.dark #terms-modal-trigger:hover {
    color: var(--text-on-dark, #f0f0f0);
    border-color: var(--brand-primary-soft);
    background: rgba(71, 123, 147, 0.15);
  }

  body.calm-mode #footer-logo img {
    filter: saturate(0.45) brightness(1.04);
  }

  /* Torii entrance animation */
  #torii-icon img {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 1.2s ease,
      transform 1.2s ease;
  }

  #torii-icon.torii-visible img {
    opacity: 0.22;
    transform: translateY(0);
  }

  body.dark #torii-icon.torii-visible img {
    filter: invert(1) grayscale(1) brightness(0.8);
    opacity: 0.15;
  }

  body.calm-mode #torii-icon.torii-visible img {
    filter: grayscale(0.6) brightness(1.05);
    opacity: 0.15;
  }

  body.reduce-motion #torii-icon img {
    transition: none;
  }
  body.reduce-motion #torii-icon.torii-visible img {
    opacity: 0.22;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #torii-icon img {
      transition: none;
    }
    #torii-icon.torii-visible img {
      opacity: 0.22;
      transform: none;
    }
  }
</style>

<script>
  // Terms modal
  const termsModal = document.getElementById("terms-modal") as HTMLElement;
  const termsPanel = document.getElementById("terms-modal-panel") as HTMLElement;
  const termsTrigger = document.getElementById("terms-modal-trigger") as HTMLButtonElement;
  const termsClose = document.getElementById("terms-modal-close") as HTMLButtonElement;

  function openTerms(): void {
    termsModal.classList.add("open");
    termsModal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    termsClose.focus();
  }
  function closeTerms(): void {
    termsModal.classList.remove("open");
    termsModal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    termsTrigger.focus();
  }

  termsTrigger?.addEventListener("click", openTerms);
  termsClose?.addEventListener("click", closeTerms);
  // Close when clicking the backdrop (the modal container), but not the panel itself
  termsModal?.addEventListener("click", (e: MouseEvent) => {
    if (!termsPanel?.contains(e.target as Node)) closeTerms();
  });
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && termsModal.classList.contains("open")) closeTerms();
  });

  // Torii icon
  const toriEl = document.getElementById("torii-icon");
  if (toriEl && !document.body.classList.contains("reduce-motion")) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            toriEl.classList.add("torii-visible");
            observer.disconnect();
          }
        });
      },
      { threshold: 0.15 },
    );
    observer.observe(toriEl);
  } else if (toriEl) {
    toriEl.classList.add("torii-visible");
  }
</script>
