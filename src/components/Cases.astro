---
interface ProjectCard {
  id?: number | string;
  slug?: string;
  name?: string;
  image: string;
  semester?: string;
  semester_da?: string;
  year?: string;
  year_da?: string;
  tools?: string[];
}

const { projects: propProjects } = Astro.props;

const getDegreeLabel = (period?: string) => {
  if (!period) return "";

  const parts = period
    .split("·")
    .map((part) => part.trim())
    .filter(Boolean);

  return parts[parts.length - 1] || "";
};

const fetchCards = async (): Promise<ProjectCard[]> => {
  const response = await fetch("https://bbmabdbbjpfqoapbtstm.supabase.co/rest/v1/portfolio_cases?order=id.asc", {
    method: "GET",
    headers: {
      apikey:
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJibWFiZGJianBmcW9hcGJ0c3RtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI0NjkwNDYsImV4cCI6MjA1ODA0NTA0Nn0.gFnw6GZiMFOCMwy6rAcQFzoK0_qUJCwKNpl-XGzy574",
    },
  });

  if (!response.ok) return [];

  const data = (await response.json()) as ProjectCard[];
  return Array.isArray(data) ? data : [];
};

const projects = (propProjects ?? (await fetchCards())) as ProjectCard[];
---

<!-- Carousel -->
<div class="carousel w-full col-span-12">
  <ul id="project-cards" class="carousel-track grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      projects.map((project: ProjectCard) => (
        <li
          class="h-[300px] relative overflow-hidden rounded-2xl group hover:-translate-y-1 transition duration-300 ease-in-out border-l-4 border border-gray-500 hover:border-gray-400"
          data-id={project.id ?? ""}
          data-name={project.name ? project.name.toLowerCase() : ""}
        >
          {project.slug === "no-project" ? (
            <div aria-label={`View project: ${project.name}`}>
              <img src={project.image} alt={project.name} class="w-full h-full object-cover z-0" loading="lazy" />

              <div class="absolute inset-0 overflow-hidden rounded-2xl bg-gray-800 bg-opacity-75 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
                <span class="card-degree-badge" data-year={project.year || ""} data-year-da={project.year_da || ""}>
                  {getDegreeLabel(project.year)}
                </span>
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <p class="text-h4-mobile font-bold text-gray-50">{project.name}</p>
                  <p
                    class="card-period text-h4-mobile font-light italic pb-2 text-gray-50"
                    data-semester={project.semester || ""}
                    data-semester-da={project.semester_da || ""}
                    data-year={project.year || ""}
                    data-year-da={project.year_da || ""}
                  >
                    {project.semester || project.year}
                  </p>

                  <div class="flex flex-row flex-wrap gap-2 py-2">
                    {project.tools && project.tools.map((tool: string) => <span class="tool-chip">{tool}</span>)}
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a href={`/${project.slug}`} aria-label={`View project: ${project.name}`}>
              <img src={project.image} alt={project.name} class="w-full h-full object-cover z-0" loading="lazy" />

              <div class="absolute inset-0 overflow-hidden rounded-2xl bg-gray-800 bg-opacity-75 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
                <span class="card-degree-badge" data-year={project.year || ""} data-year-da={project.year_da || ""}>
                  {getDegreeLabel(project.year)}
                </span>
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <p class="text-h4-mobile font-bold text-gray-50">{project.name}</p>
                  <p
                    class="card-period text-h4-mobile font-light italic pb-2 text-gray-50"
                    data-semester={project.semester || ""}
                    data-semester-da={project.semester_da || ""}
                    data-year={project.year || ""}
                    data-year-da={project.year_da || ""}
                  >
                    {project.semester || project.year}
                  </p>

                  <div class="flex flex-row flex-wrap gap-2 py-2">
                    {project.tools && project.tools.map((tool: string) => <span class="tool-chip">{tool}</span>)}
                  </div>
                </div>
              </div>
            </a>
          )}
        </li>
      ))
    }
  </ul>
</div>

<script>
  import { inView } from "motion";

  const getLang = () => localStorage.getItem("lang") || "en";

  const applyCardTranslations = (lang: string) => {
    const getCurrentPeriod = (el: HTMLElement) => {
      const year = el.dataset.year || "";
      const yearDa = el.dataset.yearDa || "";
      const semester = el.dataset.semester || "";
      const semesterDa = el.dataset.semesterDa || "";

      const currentYear = lang === "da" ? yearDa || year : year;
      const currentSemester = lang === "da" ? semesterDa || semester : semester;

      return currentSemester || currentYear;
    };

    const getCurrentDegree = (el: HTMLElement) => {
      const year = el.dataset.year || "";
      const yearDa = el.dataset.yearDa || "";
      const currentYear = lang === "da" ? yearDa || year : year;
      const parts = currentYear
        .split("·")
        .map((part) => part.trim())
        .filter(Boolean);

      return parts[parts.length - 1] || "";
    };

    document.querySelectorAll(".card-period").forEach((periodEl) => {
      const element = periodEl as HTMLElement;
      element.textContent = getCurrentPeriod(element);
    });

    document.querySelectorAll(".card-degree-badge").forEach((degreeEl) => {
      const element = degreeEl as HTMLElement;
      element.textContent = getCurrentDegree(element);
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    applyCardTranslations(getLang());

    const cards = Array.from(document.querySelectorAll("#project-cards > li")) as HTMLElement[];
    const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;

    // Keyboard accessibility
    cards.forEach((card) => {
      card.setAttribute("tabindex", "0");
      card.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          const link = card.querySelector("a");
          if (link) link.click();
        }
      });
    });

    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduceMotion) return;

    cards.forEach((card, index) => {
      let stop = () => {};
      stop = inView(card, () => {
        card.classList.add("animate__animated", "animate__fadeInUp");
        card.style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
        card.style.animationDuration = isMobileViewport ? "0.95s" : "1.4s";
        card.style.animationFillMode = "both";

        stop();
      });
    });
  });

  document.addEventListener("astro:page-load", () => {
    applyCardTranslations(getLang());
  });

  window.addEventListener("langchange", (event: Event) => {
    const customEvent = event as CustomEvent;
    const lang = customEvent.detail?.lang || getLang();
    applyCardTranslations(lang);
  });
</script>

<style>
  .card-degree-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 20;
    display: inline-flex;
    align-items: center;
    max-width: calc(100% - 2rem);
    border-radius: 9999px;
    background: rgba(193, 219, 204, 0.18);
    border: 1px solid rgba(193, 219, 204, 0.28);
    color: #edf7f0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    padding: 0.55rem 0.8rem;
    text-transform: uppercase;
    pointer-events: none;
  }

  .tool-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    border: 1px solid rgba(226, 232, 240, 0.35);
    background: rgba(15, 23, 42, 0.45);
    color: #f8fafc;
    font-size: 0.69rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.4rem 0.7rem;
    text-transform: uppercase;
  }

  body.dark #project-cards > li {
    background-color: var(--dark-gradient-start);
    border-color: var(--dark-border);
  }

  body.dark #project-cards > li:hover {
    background-color: var(--dark-surface-hover);
    border-color: var(--dark-border-strong);
  }

  body.dark #project-cards > li:focus {
    border-color: var(--brand-primary-soft);
  }

  body.dark #project-cards > li h1,
  body.dark #project-cards > li h2,
  body.dark #project-cards > li p,
  body.dark #project-cards > li span {
    color: var(--text-on-dark);
  }

  body.dark .card-degree-badge {
    background: rgba(193, 219, 204, 0.16);
    border-color: rgba(193, 219, 204, 0.24);
    color: var(--text-on-dark);
  }

  body.dark .tool-chip {
    border-color: rgba(192, 215, 225, 0.35);
    background: rgba(15, 23, 42, 0.45);
    color: var(--text-on-dark);
  }
</style>
