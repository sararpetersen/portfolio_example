---
const { variant = "primary", size = "medium" } = Astro.props;

const buttonStyling = "inline-flex items-center justify-center px-6 py-[10px] border-2 font-semibold rounded-[5px] transition duration-300 uppercase";

const variantClasses = {
  primary:
    "main-button text-gray-50 bg-[#2f3f4c] border-[#2f3f4c] hover:bg-[#3a4d5c] hover:border-[#3a4d5c] hover:text-gray-50 focus:outline-none focus:ring-2  focus:ring-[#9caebb] ease-in-out",
  secondary:
    "secondary-button text-[#1d1d1d] bg-transparent border-[#2f3f4c] hover:bg-[#2f3f4c] hover:text-gray-50 hover:border-[#2f3f4c] focus:outline-none focus:ring-2  focus:ring-[#9caebb] ease-in-out",
};

const sizeClasses = {
  large: "text-[18px]",
  medium: "text-[16px]",
  small: "text-[14px]",
};
---

<button class:list={[buttonStyling, variantClasses[variant], sizeClasses[size]]}><slot /></button>

<style>
  .main-button,
  .secondary-button {
    position: relative;
    overflow: hidden;
  }

  .main-button::before,
  .secondary-button::before {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 0.3rem;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(187, 74, 52, 0.72), transparent);
    opacity: 0.55;
    transform: scaleX(0.45);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .main-button:hover::before,
  .main-button:focus-visible::before,
  .secondary-button:hover::before,
  .secondary-button:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  body.dark .main-button {
    background-color: #d5e0e8;
    color: #14202b;
    border: #d5e0e8 2px solid;
    font-weight: 700;
  }

  body.dark .main-button:hover {
    background-color: #edf3f7;
    color: #14202b;
    border: #edf3f7 2px solid;
  }

  body.dark .secondary-button {
    background-color: transparent;
    color: #e9eef2;
    border: #aebfcc 2px solid;
    font-weight: 700;
  }

  body.dark .secondary-button:hover {
    background-color: #aebfcc;
    color: #14202b;
    border: #aebfcc 2px solid;
  }
</style>
