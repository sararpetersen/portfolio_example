---
const { variant = "primary", size = "medium" } = Astro.props;

const buttonStyling = "inline-flex items-center justify-center px-6 py-[10px] border-2 font-semibold rounded-[5px] transition duration-300 uppercase";

const variantClasses = {
  primary:
    "main-button text-gray-50 bg-blue-900 border-blue-900 hover:bg-blue-800 hover:border-blue-800 hover:text-gray-50 focus:outline-none focus:ring-2 focus:ring-pale-400 ease-in-out",
  secondary:
    "secondary-button text-gray-900 bg-transparent border-blue-900 hover:bg-blue-900 hover:text-gray-50 hover:border-blue-900 focus:outline-none focus:ring-2 focus:ring-pale-400 ease-in-out",
};

const sizeClasses = {
  large: "text-[18px]",
  medium: "text-[16px]",
  small: "text-[14px]",
};
---

<button class:list={[buttonStyling, variantClasses[variant], sizeClasses[size]]}><slot /></button>

<style>
  .main-button,
  .secondary-button {
    position: relative;
    overflow: hidden;
  }

  .main-button::before,
  .secondary-button::before {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 0.3rem;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(187, 74, 52, 0.72), transparent);
    opacity: 0.55;
    transform: scaleX(0.45);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .main-button:hover::before,
  .main-button:focus-visible::before,
  .secondary-button:hover::before,
  .secondary-button:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  body.dark .main-button {
    background-color: #d4e1e9;
    color: #1b2731;
    border: #d4e1e9 2px solid;
    font-weight: 700;
  }

  body.dark .main-button:hover {
    background-color: #f4f8fa;
    color: #1b2731;
    border: #f4f8fa 2px solid;
  }

  body.dark .secondary-button {
    background-color: transparent;
    color: #e7eef2;
    border: #b7cdd9 2px solid;
    font-weight: 700;
  }

  body.dark .secondary-button:hover {
    background-color: #b7cdd9;
    color: #1b2731;
    border: #b7cdd9 2px solid;
  }
</style>
