---
const buttonStyling = "inline-flex items-center justify-center px-6 py-[10px] border-2 font-semibold rounded-[5px] transition duration-300 uppercase";

const variantClasses = {
  primary:
    "main-button text-gray-50 bg-blue-900 border-blue-900 hover:bg-blue-700 hover:border-blue-700 hover:text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-300 ease-in-out",
  secondary:
    "secondary-button text-gray-900 bg-transparent border-blue-900 hover:bg-blue-900 hover:text-gray-50 hover:border-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-300 ease-in-out",
} as const;

const sizeClasses = {
  large: "text-[18px]",
  medium: "text-[16px]",
  small: "text-[14px]",
} as const;

type Variant = keyof typeof variantClasses;
type Size = keyof typeof sizeClasses;

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  target?: string;
  rel?: string;
  "aria-label"?: string;
}

const { variant = "primary", size = "medium", href, target, rel, "aria-label": ariaLabel } = Astro.props as Props;
const cls = buttonStyling + " " + variantClasses[variant] + " " + sizeClasses[size];
---

{
  href ? (
    <a href={href} class={cls} target={target} rel={rel} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button type="button" class={cls} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}

<style>
  .main-button,
  .secondary-button {
    position: relative;
    overflow: hidden;
  }

  .main-button > span,
  .secondary-button > span {
    font-size: inherit;
    line-height: inherit;
  }

  .main-button::before,
  .secondary-button::before {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: 0.3rem;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, transparent, rgba(230, 57, 70, 0.72), transparent);
    opacity: 0.55;
    transform: scaleX(0.45);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .main-button:hover::before,
  .main-button:focus-visible::before,
  .secondary-button:hover::before,
  .secondary-button:focus-visible::before {
    opacity: 1;
    transform: scaleX(1);
  }

  body.dark .main-button {
    background-color: var(--brand-primary-soft);
    color: #1a1a1a;
    border: var(--brand-primary-soft) 2px solid;
    font-weight: 700;
  }

  body.dark .main-button:hover {
    background-color: var(--brand-primary-strong);
    color: #1a1a1a;
    border: var(--brand-primary-strong) 2px solid;
  }

  body.dark .secondary-button {
    background-color: transparent;
    color: #f6f6f6;
    border: #f6f6f6 2px solid;
    font-weight: 700;
  }

  body.dark .secondary-button:hover {
    background-color: var(--brand-primary-soft);
    color: #1a1a1a;
    border: var(--brand-primary-soft) 2px solid;
  }
</style>
