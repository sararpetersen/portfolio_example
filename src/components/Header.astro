---
import "../styles/global.css";

const currentPath = Astro.url.pathname;
const isActive = (path: string) => (path === "/" ? currentPath === "/" : currentPath.startsWith(path));
---

<!-- Accessibility bar -->
<div
  id="accessibility-bar"
  class="fixed top-0 left-0 w-full bg-gray-800 text-gray-50 flex items-center h-9 px-4 z-50"
  role="region"
  aria-label="Accessibility and language settings"
>
  <!-- Quick-access setting buttons -->
  <div class="flex items-center gap-1.5" role="group" aria-label="Quick accessibility settings">
    <!-- Text size -->
    <button id="textSizeToggle" aria-pressed="false" aria-label="Toggle larger text" class="bar-quick-btn tooltip-below" data-tooltip="Text size">
      <span style="font-size:12px;font-weight:700;line-height:1;letter-spacing:0">A</span>
    </button>

    <!-- Reading font (cycles Default -> Atkinson -> Verdana -> OpenDyslexic) -->
    <button
      id="fontCycleToggle"
      type="button"
      aria-pressed="false"
      aria-label="Reading font: Default. Click to cycle to the next option."
      class="bar-quick-btn tooltip-below tooltip-align-left"
      data-tooltip="Font: Default"
    >
      <span style="font-size:11px;font-weight:700;line-height:1;letter-spacing:0">Aa</span>
    </button>

    <!-- Dark mode -->
    <button id="darkModeToggle" aria-pressed="false" aria-label="Toggle dark mode" class="bar-quick-btn tooltip-below" data-tooltip="Dark mode">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- Calm mode -->
    <button
      id="colorModeToggle"
      aria-pressed="false"
      aria-label="Toggle calm colours"
      class="bar-quick-btn tooltip-below"
      data-tooltip="Calm colours"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M12 3v18M3 12h18" opacity="0.4"></path>
        <path d="M12 3a9 9 0 0 1 0 18z" fill="currentColor" stroke="none"></path>
      </svg>
    </button>

    <!-- Reduce motion -->
    <button id="motionToggle" aria-pressed="false" aria-label="Toggle reduce motion" class="bar-quick-btn tooltip-below" data-tooltip="Reduce motion">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
      </svg>
    </button>

    <!-- Focus mode -->
    <button id="focusModeToggle" aria-pressed="false" aria-label="Toggle focus mode" class="bar-quick-btn tooltip-below" data-tooltip="Focus mode">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
      </svg>
    </button>

    <!-- Colour vision simulation (cycles Off -> Protanopia -> Deuteranopia -> Tritanopia) -->
    <button
      id="cvdCycleToggle"
      type="button"
      aria-pressed="false"
      aria-label="Colour vision simulation: Off. Click to cycle to the next option."
      class="bar-quick-btn tooltip-below tooltip-align-left"
      data-tooltip="Colour vision: Off"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </button>
  </div>

  <!-- Language Toggle -->
  <div class="ml-auto flex items-center gap-1">
    <button
      id="lang-toggle-en"
      data-lang="en"
      class="lang-btn hover:cursor-pointer px-1.5 py-0.5 text-xs font-semibold rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 tooltip-below"
      aria-label="Switch to English"
      aria-pressed="true"
      data-tooltip="English">EN</button
    >
    <span class="text-gray-300 text-xs" aria-hidden="true">/</span>
    <button
      id="lang-toggle-da"
      data-lang="da"
      class="lang-btn hover:cursor-pointer px-1.5 py-0.5 text-xs font-semibold rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 tooltip-below"
      aria-label="Skift til dansk"
      aria-pressed="false"
      data-tooltip="Danish">DA</button
    >
  </div>
</div>

<header id="header" class="fixed top-9 left-0 right-0 w-full p-4 md:px-16 bg-gray-50 z-30" x-data="{ showmenu: false, showDropdown: false }">
  <div class="flex items-center justify-between">
    <!-- Logo Section -->
    <div class="flex-shrink-0 flex justify-center">
      <a href="/" aria-label="Go to homepage" class="group inline-block">
        <img
          src="/logo.svg"
          alt="Logo for my website, with three of my initials (standard)"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-light"
          width="64"
          height="64"
          loading="eager"
        />
        <img
          src="/logo_white.svg"
          alt="Logo for my website, with three of my initials (white)"
          aria-hidden="true"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-dark"
          width="64"
          height="64"
          loading="eager"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav aria-label="Main navigation">
      <ul class="hidden lg:flex space-x-6 items-center">
        <li class="some1">
          <a
            href="/"
            class:list={[
              "py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
              isActive("/") && "text-blue-700 font-semibold",
            ]}
            aria-current={isActive("/") ? "page" : undefined}
            aria-label="Go to homepage"
            data-i18n="nav.home">Home</a
          >
        </li>
        <li class="some1">
          <a
            href="/about_me"
            class:list={[
              "py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
              isActive("/about_me") && "text-blue-700 font-semibold",
            ]}
            aria-current={isActive("/about_me") ? "page" : undefined}
            aria-label="Go to about-page"
            data-i18n="nav.about">About</a
          >
        </li>
        <li class="some1">
          <a
            href="/contact"
            class:list={[
              "py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
              isActive("/contact") && "text-blue-700 font-semibold",
            ]}
            aria-current={isActive("/contact") ? "page" : undefined}
            aria-label="Go to contact-page"
            data-i18n="nav.contact">Contact</a
          >
        </li>

        <li class="some1">
          <a
            href="/blog"
            class:list={[
              "py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
              isActive("/blog") && "text-blue-700 font-semibold",
            ]}
            aria-current={isActive("/blog") ? "page" : undefined}
            aria-label="Go to blog-page"
            data-i18n="nav.blog">Blog</a
          >
        </li>

        <li id="vertical-border" aria-hidden="true" class="h-4 border-l border-gray-200"></li>
        <li class="some1">
          <a
            href="/lab"
            class:list={[
              "py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
              isActive("/lab") && "text-blue-700 font-semibold",
            ]}
            aria-current={isActive("/lab") ? "page" : undefined}
            data-i18n="nav.lab">The Lab</a
          >
        </li>
        <li class="some1">
          <a
            href="https://srp-library.netlify.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
            aria-label="Go to asset library (opens in a new tab)"
            data-i18n="nav.library">The Library</a
          >
        </li>
      </ul>
    </nav>

    <!-- Mobile Burger (shows below lg) -->
    <button
      id="burgermenu"
      aria-label="Show mobile-menu"
      aria-controls="mobilmenu"
      x-bind:aria-expanded="showmenu ? 'true' : 'false'"
      class="lg:hidden tooltip-below"
      x-on:click="showmenu = !showmenu"
      data-tooltip="Menu"
    >
      <!-- Hamburger -->
      <svg
        x-show="!showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
      </svg>

      <!-- X -->
      <svg
        x-show="showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu (below lg) -->
  <nav
    id="mobilmenu"
    aria-label="Mobile navigation"
    x-bind:aria-hidden="showmenu ? 'false' : 'true'"
    class="lg:hidden"
    x-show="showmenu"
    x-transition
    x-cloak
    x-on:click="showmenu = false"
    x-on:click.outside="showmenu = false"
    x-on:keydown.escape.window="showmenu = false"
  >
    <ul class="flex flex-col items-center gap-2 pt-4 pb-4">
      <li class="some1">
        <a
          href="/#hero"
          class:list={[
            "py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
            isActive("/") && "text-blue-700 font-semibold",
          ]}
          aria-current={isActive("/") ? "page" : undefined}
          aria-label="Go to homepage"
          data-i18n="nav.home">Home</a
        >
      </li>
      <li class="some1">
        <a
          href="/about_me"
          class:list={[
            "py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
            isActive("/about_me") && "text-blue-700 font-semibold",
          ]}
          aria-current={isActive("/about_me") ? "page" : undefined}
          aria-label="Go to about-page"
          data-i18n="nav.about">About</a
        >
      </li>
      <li class="some1">
        <a
          href="/contact"
          class:list={[
            "py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
            isActive("/contact") && "text-blue-700 font-semibold",
          ]}
          aria-current={isActive("/contact") ? "page" : undefined}
          aria-label="Go to contact-page"
          data-i18n="nav.contact">Contact</a
        >
      </li>
      <li class="some1">
        <a
          href="/blog"
          class:list={[
            "py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
            isActive("/blog") && "text-blue-700 font-semibold",
          ]}
          aria-current={isActive("/blog") ? "page" : undefined}
          aria-label="Go to blog-page"
          data-i18n="nav.blog">Blog</a
        >
      </li>
      <li class="some1">
        <a
          href="/lab"
          class:list={[
            "py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300",
            isActive("/lab") && "text-blue-700 font-semibold",
          ]}
          aria-current={isActive("/lab") ? "page" : undefined}
          data-i18n="nav.lab">The Lab</a
        >
      </li>
      <li class="some1">
        <a
          href="https://srp-library.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
          aria-label="Go to asset library (opens in a new tab)"
          data-i18n="nav.library">The Library</a
        >
      </li>
    </ul>
  </nav>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }

  #header a:hover {
    color: var(--brand-primary);
  }

  #header #mobilmenu a:hover {
    color: var(--brand-primary);
  }

  #header .some1 a[aria-current="page"]::before {
    transform-origin: left;
    transform: scaleX(1);
  }

  #header .some1 a[aria-current="page"]::after {
    opacity: 0.9;
    transform: rotate(45deg) scale(1);
  }

  #header #mobilmenu a:hover svg,
  #header #burgermenu:hover svg {
    color: var(--brand-primary);
  }

  /* Dark Mode */
  body.dark #header a {
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header #mobilmenu a:hover svg,
  body.dark #header #burgermenu:hover svg,
  body.dark #header a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header .some1 a[aria-current="page"]::before {
    background-color: var(--brand-primary-soft);
  }

  /* Keep the header layer visually stable while scrolling. */
  #header {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    border-bottom: 1px solid transparent;
  }

  /* Dark Mode */
  body.dark #header {
    background: var(--dark-bg);
    color: var(--text-on-dark);
    box-shadow: none;
    border-bottom: 1px solid #333;
  }

  .bar-quick-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
    flex-shrink: 0;
  }
  .bar-quick-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #f0f0f0;
  }
  .bar-quick-btn[aria-pressed="true"] {
    background: rgba(71, 123, 147, 0.35);
    border-color: #477b93;
    color: #c0d7e1;
  }
  .bar-quick-btn:focus-visible {
    outline: 2px solid #477b93;
    outline-offset: 2px;
  }

  body.dark #accessibility-bar {
    background-color: #252525;
    border-bottom: 1px solid #333333;
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu {
    color: var(--text-on-dark);
  }

  /* Colour-vision simulation, applied here (not on body) so this component's own
     fixed-position elements aren't given a new containing block by an ancestor filter. */
  body.cvd-protanopia #accessibility-bar,
  body.cvd-protanopia #header {
    filter: url(#cvd-protanopia-filter);
  }
  body.cvd-deuteranopia #accessibility-bar,
  body.cvd-deuteranopia #header {
    filter: url(#cvd-deuteranopia-filter);
  }
  body.cvd-tritanopia #accessibility-bar,
  body.cvd-tritanopia #header {
    filter: url(#cvd-tritanopia-filter);
  }

  body.dark #header a[aria-current="page"],
  body.dark #mobilmenu a[aria-current="page"] {
    color: var(--brand-primary-soft);
  }

  body.dark #vertical-border {
    border-color: var(--dark-border);
  }

  /* Button styles for dark mode */
  body.dark .toggle-switch {
    background-color: #4b5563;
  }
  body.dark .toggle-switch[aria-pressed="true"] {
    background-color: #95bccb;
  }
  body.dark .toggle-circle {
    background-color: #f0f0f0;
  }

  /* Reduce Motion Mode */
  body.reduce-motion * {
    transition: none !important;
    animation: none !important;
    scroll-behavior: auto !important;
  }

  :global(html) {
    transition: font-size 0.3s ease;
  }

  :global(html.text-large) {
    font-size: 112.5%;
  }

  body {
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  /* Logo */
  /* Light mode logo */
  .logo-dark {
    display: none;
  }

  /* Dark mode logo */
  body.dark .logo-light {
    display: none;
  }

  body.dark .logo-dark {
    display: block;
  }

  /* Calm mode: desaturate the red circle on the logo */
  body.calm-mode .logo-light,
  body.calm-mode .logo-dark {
    filter: saturate(0.45) brightness(1.04);
  }

  #accessibilityOptions span {
    font-size: 17.6px;
  }

  #burgermenu:hover svg,
  body.dark #burgermenu svg:hover {
    color: var(--brand-primary-soft);
  }

  .lang-btn {
    color: #f0f1f3;
    background-color: transparent;
    border: 1px solid transparent;
  }

  .lang-btn[aria-pressed="true"] {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.16);
    border-color: var(--brand-primary-soft);
  }
</style>

<script>
  type ToggleTarget = "body" | "html";

  interface ToggleOptions {
    target?: ToggleTarget;
    mediaQuery?: string;
  }

  // Utility function to initialize toggle
  function initToggle(toggleId: string, className: string, storageKey: string, options: ToggleOptions = {}): void {
    const target = options.target ?? "body";
    const targetElement = target === "html" ? document.documentElement : document.body;
    const toggleButton = document.getElementById(toggleId);
    const savedSetting = localStorage.getItem(storageKey);
    const fallbackState = options.mediaQuery ? window.matchMedia(options.mediaQuery).matches : false;
    const initialState = savedSetting === null ? fallbackState : savedSetting === "true";

    // Apply initial state (saved setting first, then OS preference fallback)
    if (initialState) {
      targetElement.classList.add(className);
      toggleButton?.setAttribute("aria-pressed", "true");
    } else {
      toggleButton?.setAttribute("aria-pressed", "false");
    }

    // Set up click handler
    toggleButton?.addEventListener("click", () => {
      const isPressed = toggleButton.getAttribute("aria-pressed") === "true";
      const newState = !isPressed;

      toggleButton.setAttribute("aria-pressed", String(newState));
      targetElement.classList.toggle(className, newState);
      localStorage.setItem(storageKey, String(newState));
    });
  }

  // Initialize each toggle
  initToggle("motionToggle", "reduce-motion", "motionReductionEnabled", {
    mediaQuery: "(prefers-reduced-motion: reduce)",
  });
  initToggle("darkModeToggle", "dark", "darkModeEnabled", {
    mediaQuery: "(prefers-color-scheme: dark)",
  });
  initToggle("colorModeToggle", "calm-mode", "calmModeEnabled");
  initToggle("focusModeToggle", "focus-mode", "focusModeEnabled");
  initToggle("textSizeToggle", "text-large", "largeTextEnabled", {
    target: "html",
  });

  // Reading font cycle (Default -> Atkinson -> Verdana -> OpenDyslexic -> Default)
  type FontOption = "default" | "atkinson" | "verdana" | "opendyslexic";
  const fontCycleOrder: FontOption[] = ["default", "atkinson", "verdana", "opendyslexic"];
  const fontClassMap: Record<Exclude<FontOption, "default">, string> = {
    atkinson: "readable-font",
    verdana: "verdana-font",
    opendyslexic: "opendyslexic-font",
  };
  const fontStorageKeyMap: Record<Exclude<FontOption, "default">, string> = {
    atkinson: "readableFontEnabled",
    verdana: "verdanaFontEnabled",
    opendyslexic: "opendyslexicFontEnabled",
  };
  const fontDisplayLabels: Record<FontOption, string> = {
    default: "Default",
    atkinson: "Atkinson Hyperlegible",
    verdana: "Verdana",
    opendyslexic: "OpenDyslexic",
  };

  function getCurrentFont(): FontOption {
    const html = document.documentElement;
    if (html.classList.contains("readable-font")) return "atkinson";
    if (html.classList.contains("verdana-font")) return "verdana";
    if (html.classList.contains("opendyslexic-font")) return "opendyslexic";
    return "default";
  }

  function updateFontButtonUI(font: FontOption): void {
    const btn = document.getElementById("fontCycleToggle");
    if (!btn) return;
    btn.setAttribute("data-tooltip", `Font: ${fontDisplayLabels[font]}`);
    btn.setAttribute("aria-label", `Reading font: ${fontDisplayLabels[font]}. Click to cycle to the next option.`);
    btn.setAttribute("aria-pressed", String(font !== "default"));
  }

  function applyFont(font: FontOption): void {
    const html = document.documentElement;
    html.classList.remove("readable-font", "verdana-font", "opendyslexic-font");
    localStorage.removeItem("readableFontEnabled");
    localStorage.removeItem("verdanaFontEnabled");
    localStorage.removeItem("opendyslexicFontEnabled");
    if (font !== "default") {
      html.classList.add(fontClassMap[font]);
      localStorage.setItem(fontStorageKeyMap[font], "true");
    }
    updateFontButtonUI(font);
  }

  document.getElementById("fontCycleToggle")?.addEventListener("click", () => {
    const next = fontCycleOrder[(fontCycleOrder.indexOf(getCurrentFont()) + 1) % fontCycleOrder.length];
    applyFont(next);
  });

  // Keep the bar button's label in sync if the font is changed elsewhere (e.g. the accessibility panel)
  new MutationObserver(() => updateFontButtonUI(getCurrentFont())).observe(document.documentElement, { attributeFilter: ["class"] });

  updateFontButtonUI(getCurrentFont());

  // Language toggle
  const langButtons = document.querySelectorAll<HTMLButtonElement>(".lang-btn");
  langButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.getAttribute("data-lang") || "en";
      (window as any).__i18n?.setLang(lang);
    });
  });
  // Sync lang button state on load
  const currentLang = localStorage.getItem("lang") || "en";
  document.getElementById("lang-toggle-en")?.setAttribute("aria-pressed", currentLang === "en" ? "true" : "false");
  document.getElementById("lang-toggle-da")?.setAttribute("aria-pressed", currentLang === "da" ? "true" : "false");
</script>
