---
import "../styles/global.css";

const currentPath = Astro.url.pathname;
const isActive = (path: string) => (path === "/" ? currentPath === "/" : currentPath.startsWith(path));
---

<!-- Accessibility settings bar -->
<div id="accessibility-bar" class="fixed top-0 left-0 w-full bg-gray-800 text-gray-50 flex items-center h-9 p-4 z-50">
  <!-- Gear Icon -->
  <button
    id="accessibilityToggle"
    class="svg-gear focus:outline-none focus:ring-2 focus:ring-pale-400 transition duration-300 ease-in-out"
    aria-label="Accessibility-settings"
    aria-controls="accessibilityOptions"
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6 transition duration-300 ease-in-out">
      <path
        fill-rule="evenodd"
        d="M11.078 2.25c-.917 0-1.699.663-1.85 1.567L9.05 4.889c-.02.12-.115.26-.297.348a7.493 7.493 0 0 0-.986.57c-.166.115-.334.126-.45.083L6.3 5.508a1.875 1.875 0 0 0-2.282.819l-.922 1.597a1.875 1.875 0 0 0 .432 2.385l.84.692c.095.078.17.229.154.43a7.598 7.598 0 0 0 0 1.139c.015.2-.059.352-.153.43l-.841.692a1.875 1.875 0 0 0-.432 2.385l.922 1.597a1.875 1.875 0 0 0 2.282.818l1.019-.382c.115-.043.283-.031.45.082.312.214.641.405.985.57.182.088.277.228.297.35l.178 1.071c.151.904.933 1.567 1.85 1.567h1.844c.916 0 1.699-.663 1.85-1.567l.178-1.072c.02-.12.114-.26.297-.349a7.493 7.493 0 0 0 .986-.57c.166-.115.334-.126.45-.083l1.019.382a1.875 1.875 0 0 0 2.282-.818l.922-1.597a1.875 1.875 0 0 0-.432-2.385l-.84-.692c-.095-.078-.17-.229-.154-.43a7.598 7.598 0 0 0 0-1.139c-.015-.2.059-.352.153-.43l.841-.692a1.875 1.875 0 0 0 .432-2.385l-.922-1.597a1.875 1.875 0 0 0-2.282-.818l-1.019.382c-.115.043-.283.031-.45-.082a7.493 7.493 0 0 0-.986-.57c-.182-.088-.277-.228-.297-.35L14.927 4A1.875 1.875 0 0 0 13.078 2.25H11.078zM12 8a4 4 0 1 0 0 8a4 4 0 0 0 0-8z"
      ></path>
    </svg>
  </button>

  <!-- Accessibility Options -->
  <div
    id="accessibilityOptions"
    class="ml-4 flex gap-6 items-center transition-all duration-300 ease-in-out origin-left scale-x-0 opacity-0"
    aria-hidden="true"
  >
    <!-- Dark Mode Toggle -->
    <div class="flex items-center gap-2">
      <span id="darkModeToggleLabel" class="md:block hidden text-gray-50" data-i18n="settings.darkmode">Dark-mode</span>
      <button id="darkModeToggle" aria-pressed="false" class="toggle-switch" aria-label="Toggle dark-mode">
        <span class="toggle-circle"></span>
      </button>
    </div>

    <!-- Reduce Motion Toggle -->
    <div class="flex items-center gap-2">
      <span id="motionToggleLabel" class="md:block hidden text-gray-50" data-i18n="settings.animations">Remove animations</span>
      <button id="motionToggle" aria-pressed="false" class="toggle-switch" aria-label="Toggle 'remove animations'">
        <span class="toggle-circle"></span>
      </button>
    </div>
  </div>

  <!-- Language Toggle -->
  <div class="ml-auto flex items-center gap-1">
    <button
      id="lang-toggle-en"
      data-lang="en"
      class="lang-btn px-1.5 py-0.5 text-xs font-semibold rounded focus:outline-none focus:ring-2 focus:ring-pale-400"
      aria-label="Switch to English"
      aria-pressed="true">EN</button
    >
    <span class="text-gray-500 text-xs" aria-hidden="true">/</span>
    <button
      id="lang-toggle-da"
      data-lang="da"
      class="lang-btn px-1.5 py-0.5 text-xs font-semibold rounded focus:outline-none focus:ring-2 focus:ring-pale-400"
      aria-label="Skift til dansk"
      aria-pressed="false">DA</button
    >
  </div>
</div>

<header
  id="header"
  class="fixed top-9 left-0 right-0 w-full shadow-drop25 p-4 md:px-16 bg-gray-50 z-30"
  x-data="{ showmenu: false, showDropdown: false }"
>
  <div class="flex items-center justify-between">
    <!-- Logo Section -->
    <div class="flex-shrink-0 flex justify-center">
      <a href="/" aria-label="Go to homepage" class="group inline-block">
        <img
          src="/logo.svg"
          alt="Logo for my website, with two of my initials (black)"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-light"
          width="64"
          height="64"
          loading="eager"
        />
        <img
          src="/logo_white.svg"
          alt=""
          aria-hidden="true"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-dark"
          width="64"
          height="64"
          loading="eager"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav aria-label="Main navigation">
      <ul class="hidden lg:flex space-x-6 items-center">
        <li class="some1">
          <a
            href="/"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/") ? "page" : undefined}
            aria-label="Go to homepage"
            data-i18n="nav.home">Home</a
          >
        </li>
        <li class="some1">
          <a
            href="/about_me"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/about_me") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/about_me") ? "page" : undefined}
            aria-label="Go to about-page"
            data-i18n="nav.about">About</a
          >
        </li>
        <li class="some1">
          <a
            href="/contact"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/contact") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/contact") ? "page" : undefined}
            aria-label="Go to contact-page"
            data-i18n="nav.contact">Contact</a
          >
        </li>
      </ul>
    </nav>

    <!-- Mobile Burger (shows below lg) -->
    <button
      id="burgermenu"
      aria-label="Show mobile-menu"
      aria-controls="mobilmenu"
      x-bind:aria-expanded="showmenu ? 'true' : 'false'"
      class="lg:hidden"
      x-on:click="showmenu = !showmenu"
    >
      <!-- Hamburger -->
      <svg
        x-show="!showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-pale-400"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
      </svg>

      <!-- X -->
      <svg
        x-show="showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-pale-400"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu (below lg) -->
  <nav
    id="mobilmenu"
    aria-label="Open mobile-menu"
    x-bind:aria-hidden="showmenu ? 'false' : 'true'"
    class="lg:hidden"
    x-show="showmenu"
    x-transition
    x-cloak
    x-on:click="showmenu = false"
    x-on:click.outside="showmenu = false"
  >
    <ul class="flex flex-col items-center gap-2 pt-4 pb-4">
      <li class="some1">
        <a
          href="/#hero"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/") ? "page" : undefined}
          aria-label="Go to homepage"
          data-i18n="nav.home">Home</a
        >
      </li>
      <li class="some1">
        <a
          href="/about_me"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/about_me") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/about_me") ? "page" : undefined}
          aria-label="Go to about-page"
          data-i18n="nav.about">About</a
        >
      </li>
      <li class="some1">
        <a
          href="/contact"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-pale-400", isActive("/contact") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/contact") ? "page" : undefined}
          aria-label="Go to contact-page"
          data-i18n="nav.contact">Contact</a
        >
      </li>
    </ul>
  </nav>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }

  #header a:hover {
    color: var(--brand-primary);
  }

  #header #mobilmenu a:hover {
    color: var(--brand-primary);
  }

  #header .some1 a[aria-current="page"]::before {
    transform-origin: left;
    transform: scaleX(1);
  }

  #header .some1 a[aria-current="page"]::after {
    opacity: 0.9;
    transform: rotate(45deg) scale(1);
  }

  #header #mobilmenu a:hover svg,
  #header #burgermenu:hover svg {
    color: var(--brand-primary);
  }

  /* Dark Mode */
  body.dark #header a {
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header #mobilmenu a:hover svg,
  body.dark #header #burgermenu:hover svg,
  body.dark #header a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header .some1 a[aria-current="page"]::before {
    background-color: var(--brand-primary-soft);
  }

  /* Dark Mode */
  body.dark #header {
    background: var(--dark-bg);
    color: var(--text-on-dark);
    box-shadow: none;
    border-bottom: 1px solid #333;
  }

  body.dark #accessibility-bar {
    background-color: var(--dark-surface-strong);
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu {
    color: var(--text-on-dark);
  }

  body.dark #header a[aria-current="page"],
  body.dark #mobilmenu a[aria-current="page"] {
    color: var(--brand-primary-soft);
  }

  body.dark #vertical-border {
    border-color: var(--dark-border);
  }

  /* Button styles for dark mode */
  body.dark .toggle-switch {
    background-color: var(--dark-border);
  }
  body.dark .toggle-circle {
    background-color: var(--toggle-circle-dark);
  }

  /* Reduce Motion Mode */
  body.reduce-motion * {
    transition: none !important;
    animation: none !important;
    scroll-behavior: auto !important;
  }

  body {
    transition:
      font-size 0.3s ease,
      background-color 0.3s ease,
      color 0.3s ease;
  }

  /* Logo */
  /* Light mode logo */
  .logo-dark {
    display: none;
  }

  /* Dark mode logo */
  body.dark .logo-light {
    display: none;
  }

  body.dark .logo-dark {
    display: block;
  }

  #accessibilityOptions span {
    font-size: 17.6px;
  }

  #accessibilityToggle:hover svg,
  #burgermenu:hover svg,
  body.dark #burgermenu svg:hover {
    color: var(--brand-primary-soft);
  }

  .lang-btn {
    color: var(--dark-border);
    transition: color 0.2s ease;
  }
  .lang-btn.active-lang {
    color: var(--text-on-dark);
    font-weight: 700;
  }
  .lang-btn:hover {
    color: var(--brand-primary-soft);
  }
</style>

<script>
  // Utility function to initialize toggle
  function initToggle(toggleId: string, className: string, storageKey: string): void {
    const toggleButton = document.getElementById(toggleId);
    const savedState = localStorage.getItem(storageKey) === "true";

    // Apply saved state
    if (savedState) {
      document.body.classList.add(className);
      toggleButton?.setAttribute("aria-pressed", "true");
    } else {
      toggleButton?.setAttribute("aria-pressed", "false");
    }

    // Set up click handler
    toggleButton?.addEventListener("click", () => {
      const isPressed = toggleButton.getAttribute("aria-pressed") === "true";
      const newState = !isPressed;

      toggleButton.setAttribute("aria-pressed", String(newState));
      document.body.classList.toggle(className, newState);
      localStorage.setItem(storageKey, String(newState));
    });
  }

  // Initialize each toggle
  initToggle("motionToggle", "reduce-motion", "motionReductionEnabled");
  initToggle("darkModeToggle", "dark", "darkModeEnabled");

  // Language toggle
  const langButtons = document.querySelectorAll<HTMLButtonElement>(".lang-btn");
  langButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.getAttribute("data-lang") || "en";
      (window as any).__i18n?.setLang(lang);
    });
  });
  // Sync lang button state on load
  const currentLang = localStorage.getItem("lang") || "en";
  document.getElementById("lang-toggle-en")?.classList.toggle("active-lang", currentLang === "en");
  document.getElementById("lang-toggle-en")?.setAttribute("aria-pressed", currentLang === "en" ? "true" : "false");
  document.getElementById("lang-toggle-da")?.classList.toggle("active-lang", currentLang === "da");
  document.getElementById("lang-toggle-da")?.setAttribute("aria-pressed", currentLang === "da" ? "true" : "false");

  // Accessibility-toggle
  const toggleButton = document.getElementById("accessibilityToggle");
  const options = document.getElementById("accessibilityOptions");

  // Function to show or hide the options based on state
  function setToggleState(isOpen: boolean): void {
    if (isOpen) {
      options?.classList.remove("scale-x-0", "opacity-0");
      options?.classList.add("scale-x-100", "opacity-100");
      toggleButton?.setAttribute("aria-expanded", "true");
      options?.setAttribute("aria-hidden", "false");
    } else {
      options?.classList.remove("scale-x-100", "opacity-100");
      options?.classList.add("scale-x-0", "opacity-0");
      toggleButton?.setAttribute("aria-expanded", "false");
      options?.setAttribute("aria-hidden", "true");
    }
  }

  // Load saved state from localStorage
  let isOpen = localStorage.getItem("accessibilityOpen") === "true";
  setToggleState(isOpen);

  // On click: toggle state, update localStorage and UI
  toggleButton?.addEventListener("click", () => {
    isOpen = !isOpen;
    localStorage.setItem("accessibilityOpen", String(isOpen));
    setToggleState(isOpen);
  });
</script>
