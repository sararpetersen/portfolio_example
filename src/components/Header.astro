---
import "../styles/global.css";

const currentPath = Astro.url.pathname;
const isActive = (path: string) => (path === "/" ? currentPath === "/" : currentPath.startsWith(path));
---

<!-- Accessibility bar -->
<div id="accessibility-bar" class="fixed top-0 left-0 w-full bg-gray-600 text-gray-50 flex items-center h-9 px-4 z-50">
  <!-- Quick-access setting buttons -->
  <div class="flex items-center gap-1.5" role="group" aria-label="Quick accessibility settings">
    <!-- Text size -->
    <button id="textSizeToggle" aria-pressed="false" aria-label="Toggle larger text" class="bar-quick-btn tooltip-below" data-tooltip="Text size">
      <span style="font-size:12px;font-weight:700;line-height:1;letter-spacing:0">A</span>
    </button>

    <!-- Dark mode -->
    <button id="darkModeToggle" aria-pressed="false" aria-label="Toggle dark mode" class="bar-quick-btn tooltip-below" data-tooltip="Dark mode">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- Calm mode -->
    <button
      id="colorModeToggle"
      aria-pressed="false"
      aria-label="Toggle calm colours"
      class="bar-quick-btn tooltip-below"
      data-tooltip="Calm colours"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M12 3v18M3 12h18" opacity="0.4"></path>
        <path d="M12 3a9 9 0 0 1 0 18z" fill="currentColor" stroke="none"></path>
      </svg>
    </button>

    <!-- Reduce motion -->
    <button id="motionToggle" aria-pressed="false" aria-label="Toggle reduce motion" class="bar-quick-btn tooltip-below" data-tooltip="Reduce motion">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
      </svg>
    </button>
  </div>

  <!-- Language Toggle -->
  <div class="ml-auto flex items-center gap-1">
    <button
      id="lang-toggle-en"
      data-lang="en"
      class="lang-btn px-1.5 py-0.5 text-xs font-semibold rounded focus:outline-none focus:ring-2 focus:ring-blue-300"
      aria-label="Switch to English"
      aria-pressed="true">EN</button
    >
    <span class="text-gray-400 text-xs" aria-hidden="true">/</span>
    <button
      id="lang-toggle-da"
      data-lang="da"
      class="lang-btn px-1.5 py-0.5 text-xs font-semibold rounded focus:outline-none focus:ring-2 focus:ring-blue-300"
      aria-label="Skift til dansk"
      aria-pressed="false">DA</button
    >
  </div>
</div>

<header id="header" class="fixed top-9 left-0 right-0 w-full p-4 md:px-16 bg-gray-50 z-30" x-data="{ showmenu: false, showDropdown: false }">
  <div class="flex items-center justify-between">
    <!-- Logo Section -->
    <div class="flex-shrink-0 flex justify-center">
      <a href="/" aria-label="Go to homepage" class="group inline-block">
        <img
          src="/logo.svg"
          alt="Logo for my website, with two of my initials (black)"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-light"
          width="64"
          height="64"
          loading="eager"
        />
        <img
          src="/logo_white.svg"
          alt=""
          aria-hidden="true"
          class="h-16 transition duration-300 ease-out group-hover:-translate-y-[2px] group-hover:scale-[1.02] logo-dark"
          width="64"
          height="64"
          loading="eager"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav aria-label="Main navigation">
      <ul class="hidden lg:flex space-x-6 items-center">
        <li class="some1">
          <a
            href="/"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/") ? "page" : undefined}
            aria-label="Go to homepage"
            data-i18n="nav.home">Home</a
          >
        </li>
        <li class="some1">
          <a
            href="/about_me"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/about_me") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/about_me") ? "page" : undefined}
            aria-label="Go to about-page"
            data-i18n="nav.about">About</a
          >
        </li>
        <li class="some1">
          <a
            href="/contact"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/contact") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/contact") ? "page" : undefined}
            aria-label="Go to contact-page"
            data-i18n="nav.contact">Contact</a
          >
        </li>
        <li class="some1">
          <a
            href="/blog"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/blog") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/blog") ? "page" : undefined}
            aria-label="Go to blog-page"
            data-i18n="nav.blog">Blog</a
          >
        </li>
        <li class="some1">
          <a
            href="/lab"
            class:list={["py-1 focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/lab") && "text-blue-700 font-semibold"]}
            aria-current={isActive("/lab") ? "page" : undefined}
            aria-label="Go to lab-page"
            data-i18n="nav.lab">Lab</a
          >
        </li>
      </ul>
    </nav>

    <!-- Mobile Burger (shows below lg) -->
    <button
      id="burgermenu"
      aria-label="Show mobile-menu"
      aria-controls="mobilmenu"
      x-bind:aria-expanded="showmenu ? 'true' : 'false'"
      class="lg:hidden"
      x-on:click="showmenu = !showmenu"
      data-tooltip="Menu"
    >
      <!-- Hamburger -->
      <svg
        x-show="!showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-300"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
      </svg>

      <!-- X -->
      <svg
        x-show="showmenu"
        x-cloak
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8 transition duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-300"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu (below lg) -->
  <nav
    id="mobilmenu"
    aria-label="Open mobile-menu"
    x-bind:aria-hidden="showmenu ? 'false' : 'true'"
    class="lg:hidden"
    x-show="showmenu"
    x-transition
    x-cloak
    x-on:click="showmenu = false"
    x-on:click.outside="showmenu = false"
    x-on:keydown.escape.window="showmenu = false"
  >
    <ul class="flex flex-col items-center gap-2 pt-4 pb-4">
      <li class="some1">
        <a
          href="/#hero"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/") ? "page" : undefined}
          aria-label="Go to homepage"
          data-i18n="nav.home">Home</a
        >
      </li>
      <li class="some1">
        <a
          href="/about_me"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/about_me") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/about_me") ? "page" : undefined}
          aria-label="Go to about-page"
          data-i18n="nav.about">About</a
        >
      </li>
      <li class="some1">
        <a
          href="/contact"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/contact") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/contact") ? "page" : undefined}
          aria-label="Go to contact-page"
          data-i18n="nav.contact">Contact</a
        >
      </li>
      <li class="some1">
        <a
          href="/blog"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/blog") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/blog") ? "page" : undefined}
          aria-label="Go to blog-page"
          data-i18n="nav.blog">Blog</a
        >
      </li>
      <li class="some1">
        <a
          href="/lab"
          class:list={["py-1 transition focus:outline-none focus:ring-2 focus:ring-blue-300", isActive("/lab") && "text-blue-700 font-semibold"]}
          aria-current={isActive("/lab") ? "page" : undefined}
          aria-label="Go to lab-page"
          data-i18n="nav.lab">Lab</a
        >
      </li>
    </ul>
  </nav>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }

  #header a:hover {
    color: var(--brand-primary);
  }

  #header #mobilmenu a:hover {
    color: var(--brand-primary);
  }

  #header .some1 a[aria-current="page"]::before {
    transform-origin: left;
    transform: scaleX(1);
  }

  #header .some1 a[aria-current="page"]::after {
    opacity: 0.9;
    transform: rotate(45deg) scale(1);
  }

  #header #mobilmenu a:hover svg,
  #header #burgermenu:hover svg {
    color: var(--brand-primary);
  }

  /* Dark Mode */
  body.dark #header a {
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header #mobilmenu a:hover svg,
  body.dark #header #burgermenu:hover svg,
  body.dark #header a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #header .some1 a[aria-current="page"]::before {
    background-color: var(--brand-primary-soft);
  }

  /* Light mode shadow → border on scroll */
  #header {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    border-bottom: 1px solid transparent;
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  #header.header-scrolled {
    box-shadow: none;
    border-bottom: 1px solid #dcd6d0;
  }

  /* Dark Mode */
  body.dark #header {
    background: var(--dark-bg);
    color: var(--text-on-dark);
    box-shadow: none;
    border-bottom: 1px solid #333;
  }

  .bar-quick-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: transparent;
    color: #dde1e8;
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
    flex-shrink: 0;
  }
  .bar-quick-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #f0f0f0;
  }
  .bar-quick-btn[aria-pressed="true"] {
    background: rgba(71, 123, 147, 0.35);
    border-color: #477b93;
    color: #c0d7e1;
  }
  .bar-quick-btn:focus-visible {
    outline: 2px solid #477b93;
    outline-offset: 2px;
  }

  body.dark #accessibility-bar {
    background-color: #252525;
    border-bottom: 1px solid #333333;
    color: var(--text-on-dark);
  }

  body.dark #header #mobilmenu {
    color: var(--text-on-dark);
  }

  body.dark #header a[aria-current="page"],
  body.dark #mobilmenu a[aria-current="page"] {
    color: var(--brand-primary-soft);
  }

  body.dark #vertical-border {
    border-color: var(--dark-border);
  }

  /* Button styles for dark mode */
  body.dark .toggle-switch {
    background-color: #4b5563;
  }
  body.dark .toggle-switch[aria-pressed="true"] {
    background-color: #95bccb;
  }
  body.dark .toggle-circle {
    background-color: #f0f0f0;
  }

  /* Reduce Motion Mode */
  body.reduce-motion * {
    transition: none !important;
    animation: none !important;
    scroll-behavior: auto !important;
  }

  :global(html) {
    transition: font-size 0.3s ease;
  }

  :global(html.text-large) {
    font-size: 112.5%;
  }

  body {
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  /* Logo */
  /* Light mode logo */
  .logo-dark {
    display: none;
  }

  /* Dark mode logo */
  body.dark .logo-light {
    display: none;
  }

  body.dark .logo-dark {
    display: block;
  }

  /* Calm mode: desaturate the red circle on the logo */
  body.calm-mode .logo-light,
  body.calm-mode .logo-dark {
    filter: saturate(0.45) brightness(1.04);
  }

  #accessibilityOptions span {
    font-size: 17.6px;
  }

  #burgermenu:hover svg,
  body.dark #burgermenu svg:hover {
    color: var(--brand-primary-soft);
  }

  .lang-btn {
    color: #a6acb5;
  }
  .lang-btn.active-lang {
    color: var(--text-on-dark);
    font-weight: 700;
  }
  .lang-btn:hover {
    color: var(--brand-primary-soft);
  }
</style>

<script>
  type ToggleTarget = "body" | "html";

  interface ToggleOptions {
    target?: ToggleTarget;
    mediaQuery?: string;
  }

  // Utility function to initialize toggle
  function initToggle(toggleId: string, className: string, storageKey: string, options: ToggleOptions = {}): void {
    const target = options.target ?? "body";
    const targetElement = target === "html" ? document.documentElement : document.body;
    const toggleButton = document.getElementById(toggleId);
    const savedSetting = localStorage.getItem(storageKey);
    const fallbackState = options.mediaQuery ? window.matchMedia(options.mediaQuery).matches : false;
    const initialState = savedSetting === null ? fallbackState : savedSetting === "true";

    // Apply initial state (saved setting first, then OS preference fallback)
    if (initialState) {
      targetElement.classList.add(className);
      toggleButton?.setAttribute("aria-pressed", "true");
    } else {
      toggleButton?.setAttribute("aria-pressed", "false");
    }

    // Set up click handler
    toggleButton?.addEventListener("click", () => {
      const isPressed = toggleButton.getAttribute("aria-pressed") === "true";
      const newState = !isPressed;

      toggleButton.setAttribute("aria-pressed", String(newState));
      targetElement.classList.toggle(className, newState);
      localStorage.setItem(storageKey, String(newState));
    });
  }

  // Initialize each toggle
  initToggle("motionToggle", "reduce-motion", "motionReductionEnabled", {
    mediaQuery: "(prefers-reduced-motion: reduce)",
  });
  initToggle("darkModeToggle", "dark", "darkModeEnabled", {
    mediaQuery: "(prefers-color-scheme: dark)",
  });
  initToggle("colorModeToggle", "calm-mode", "calmModeEnabled");
  initToggle("textSizeToggle", "text-large", "largeTextEnabled", {
    target: "html",
  });

  // Language toggle
  const langButtons = document.querySelectorAll<HTMLButtonElement>(".lang-btn");
  langButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = btn.getAttribute("data-lang") || "en";
      (window as any).__i18n?.setLang(lang);
    });
  });
  // Sync lang button state on load
  const currentLang = localStorage.getItem("lang") || "en";
  document.getElementById("lang-toggle-en")?.classList.toggle("active-lang", currentLang === "en");
  document.getElementById("lang-toggle-en")?.setAttribute("aria-pressed", currentLang === "en" ? "true" : "false");
  document.getElementById("lang-toggle-da")?.classList.toggle("active-lang", currentLang === "da");
  document.getElementById("lang-toggle-da")?.setAttribute("aria-pressed", currentLang === "da" ? "true" : "false");

  // Header scroll: shadow at top → border when scrolled (light mode only)
  const header = document.getElementById("header");
  const updateHeaderStyle = () => {
    if (window.scrollY > 10) {
      header?.classList.add("header-scrolled");
    } else {
      header?.classList.remove("header-scrolled");
    }
  };
  window.addEventListener("scroll", updateHeaderStyle, { passive: true });
  updateHeaderStyle();
</script>
