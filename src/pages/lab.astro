---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
---

<MainLayout
  title="SRP portfolio | Lab"
  description="Sara's lab — vibe coding experiments and side projects built with AI assistance."
  ogtitle="SRP portfolio - Lab"
  ogdescription="A space for experiments, vibe coding, and things built with AI assistance."
>
  <!-- Lab Intro -->
  <section id="lab" class="grid grid-cols-12 max-w-6xl mx-auto md:pt-desktop-top pt-mobil-top md:mt-16 mt-8 md:px-0 px-8 relative">
    <div class="col-span-12 md:pt-12 pt-16 md:pb-16 pb-10">
      <div id="lab-title-row" class="flex items-center gap-4 mb-9">
        <span class="text-sm text-red-500 tracking-widest" aria-hidden="true">実験</span>
        <h1 class="uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru" data-i18n="lab.title">Experiments</h1>
      </div>
      <p id="lab-intro" class="text-gray-600 max-w-3xl leading-relaxed" data-i18n="lab.intro">
        This is where I put the looser stuff&mdash; projects built with AI assistance, quick prototypes, and things that exist mostly because I wanted
        to see if I could. Less polished than the main cases, more honest about the process.
      </p>
    </div>
  </section>

  <!-- What is vibe coding -->
  <section id="lab-about" class="max-w-6xl mx-auto md:px-0 px-8">
    <div class="bg-gradient-to-br from-gray-50 to-gray-100 border-l-4 border border-gray-500 rounded-3xl p-8 max-w-3xl">
      <h2 id="lab-vibe-title" class="font-inter italic text-gray-800 text-xl mb-3" data-i18n="lab.vibe.title">What is vibe coding?</h2>
      <p id="lab-vibe-text" class="text-gray-600 leading-relaxed" data-i18n="lab.vibe.text">
        Vibe coding is building with AI assistance&mdash; you describe what you want, the AI generates the code, and you shape and guide it. It's less
        about writing every line yourself and more about knowing what you want and being able to evaluate what you get. It changes how you think about
        prototyping and iteration.
      </p>
    </div>
  </section>

  <!-- Lab Items -->
  <section id="lab-items" class="max-w-6xl mx-auto md:px-0 px-8 md:pt-16 pt-10 md:pb-desktop-bottom pb-mobil-bottom">
    <h2 id="lab-items-title" class="font-inter italic text-gray-700 text-2xl mb-3" data-i18n="lab.items.title">Projects from the lab</h2>

    <p class="lab-legend flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-gray-400 mb-7">
      <span class="lab-tag" title="This project was built with AI assistance">Vibe coded</span>
      <span data-i18n="lab.legend.vibecoded">= built with AI assistance</span>
      <span class="text-gray-300 hidden sm:inline" aria-hidden="true">·</span>
      <span class="lab-tag wip-tag" title="Work in progress — the coded version is still being developed">WIP</span>
      <span data-i18n="lab.legend.wip">= in progress</span>
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Vibeloop (WIP) -->
      <article id="lab-item-vibeloop" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[11px] uppercase tracking-[0.2em] text-gray-500">2025-2026</p>
          <div class="flex items-center gap-2">
            <span class="lab-tag" title="This project was built with AI assistance">Vibe coded</span>
            <span class="lab-tag wip-tag" title="Work in progress — the coded version is still being developed">WIP</span>
          </div>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800">Vibeloop</h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.vibeloop.desc">
          An app concept for supporting social connection and local engagement — designed to help people find and join activities happening around them.
        </p>
        <a href="/vibeloop" aria-label="View the Vibeloop case study">
          <Button variant="secondary" size="small"><span data-i18n="lab.vibeloop.link">View case →</span></Button>
        </a>
      </article>

      <!-- AutismeGuiden -->
      <article id="lab-item-autismeguiden" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[11px] uppercase tracking-[0.2em] text-gray-500">2026</p>
          <span class="lab-tag" title="This project was built with AI assistance">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800">AutismeGuiden</h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.autismeguiden.desc">
          A Danish information guide about autism — for autistic people, family, teachers, and professionals. Built to WCAG 2.2 with accessibility at the core.
        </p>
        <a href="https://autisme-guiden.netlify.app/" target="_blank" rel="noopener noreferrer" aria-label="Visit AutismeGuiden (opens in new tab)">
          <Button variant="primary" size="small"><span data-i18n="lab.autismeguiden.link">Visit site →</span></Button>
        </a>
      </article>

      <!-- Steady -->
      <article id="lab-item-steady" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[11px] uppercase tracking-[0.2em] text-gray-500">2026</p>
          <span class="lab-tag" title="This project was built with AI assistance">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800">Steady</h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.steady.desc">
          A daily life tracker app designed for neurodivergent users, with local-first data storage and a low-friction interface.
        </p>
        <a href="https://app-steady.netlify.app/" target="_blank" rel="noopener noreferrer" aria-label="Visit Steady app (opens in new tab)">
          <Button variant="primary" size="small"><span data-i18n="lab.steady.link">Visit app →</span></Button>
        </a>
      </article>
    </div>
  </section>

  <!-- Back -->
  <section class="lab-back-btn mx-auto py-20 text-center">
    <a href="/" class="btn_container" aria-label="Back to homepage">
      <Button variant="primary" size="small"><span data-i18n="btn.back">Back to homepage</span></Button>
    </a>
  </section>
</MainLayout>

<!-- Animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    if (document.body.classList.contains("reduce-motion")) return;

    let i = 0;
    const register = (selector: string) => {
      const el = document.querySelector(selector) as HTMLElement | null;
      if (!el) return;
      inView(el, () => {
        el.classList.add("animate__animated", "animate__fadeInUp");
        el.style.animationDelay = `${i * 60}ms`;
        el.style.animationDuration = "1.5s";
        el.style.animationFillMode = "both";
      });
      i++;
    };

    ["#lab-title-row", "#lab-intro", "#lab-about", "#lab-items-title"].forEach(register);

    document.querySelectorAll("#lab-items > div > article, #lab-items > div > div").forEach((el, idx) => {
      inView(el, () => {
        el.classList.add("animate__animated", "animate__fadeInUp");
        (el as HTMLElement).style.animationDelay = `${idx * 80}ms`;
        (el as HTMLElement).style.animationDuration = "1.3s";
        (el as HTMLElement).style.animationFillMode = "both";
      });
    });
  });
</script>

<style>
  html.has-js body:not(.reduce-motion) #lab-label,
  html.has-js body:not(.reduce-motion) #lab-title-row,
  html.has-js body:not(.reduce-motion) #lab-intro,
  html.has-js body:not(.reduce-motion) #lab-about,
  html.has-js body:not(.reduce-motion) #lab-items-title,
  html.has-js body:not(.reduce-motion) #lab-item-vibeloop,
  html.has-js body:not(.reduce-motion) #lab-item-autismeguiden,
  html.has-js body:not(.reduce-motion) #lab-item-steady {
    opacity: 0;
    will-change: transform, opacity;
  }

  .lab-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    border: 1px solid rgba(71, 123, 147, 0.4);
    background: rgba(71, 123, 147, 0.1);
    color: var(--brand-primary-strong);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.42rem 0.72rem;
    text-transform: uppercase;
  }

  .wip-tag {
    border-color: rgba(217, 119, 6, 0.4);
    background: rgba(217, 119, 6, 0.1);
    color: #92400e;
  }

  /* Dark mode — text */
  body.dark #lab h1,
  body.dark #lab-label,
  body.dark #lab-intro,
  body.dark #lab-vibe-title,
  body.dark #lab-vibe-text,
  body.dark #lab-items-title,
  body.dark #lab-items article h3,
  body.dark #lab-items article p {
    color: var(--text-on-dark-soft);
  }

  /* Dark mode — card backgrounds */
  body.dark #lab-about > div {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #lab-items article {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  /* Dark mode — badges */
  body.dark .lab-tag {
    border-color: rgba(192, 215, 225, 0.35);
    background: rgba(71, 123, 147, 0.2);
    color: var(--brand-primary-soft);
  }

  body.dark .wip-tag {
    border-color: rgba(251, 191, 36, 0.35);
    background: rgba(217, 119, 6, 0.2);
    color: #fbbf24;
  }

  body.dark .lab-legend {
    color: var(--dark-border);
  }

  /* Lone last card: spans 2 cols on desktop, full width on tablet */
  @media (min-width: 1024px) {
    #lab-items .grid > article:last-child:nth-child(3n + 1) {
      grid-column: span 2;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    #lab-items .grid > article:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
  }

  body.dark .lab-back-btn a {
    color: var(--text-on-dark);
  }
</style>
