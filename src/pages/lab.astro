---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
---

<MainLayout
  title="SRP portfolio | The Lab"
  description="Experiments, prototypes, and AI-assisted builds by Sara Ringkow Petersen."
  ogtitle="The Lab – SRP Portfolio"
  ogdescription="A space for looser work – AI-assisted builds, unfinished prototypes, and experiments in progress."
>
  <!-- Lab Intro -->
  <section id="lab" class="grid grid-cols-12 gap-10 max-w-6xl mx-auto md:pt-desktop-top pt-mobil-top md:mt-16 mt-8 lg:px-0 px-8 relative">
    <div class="col-span-12">
      <div class="lg:pt-12 pt-16 mb-8">
        <div id="lab-title-row" class="mb-3">
          <h1 class="uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru text-[1.85rem] md:text-h2-desktop" data-i18n="lab.title">
            Experiments
          </h1>
        </div>
        <p id="lab-intro" class="text-gray-600 max-w-3xl leading-relaxed text-left" data-i18n="lab.intro">
          This is where I put the looser stuff&mdash; projects built with help from AI, unfinished prototypes, and things that exist mostly because I
          wanted to see if they could work. Less polished than the main cases, but more honest about the process.
        </p>
      </div>

      <!-- What is vibe coding -->
      <div id="lab-about">
        <div class="bg-gradient-to-br from-gray-50 to-gray-100 border-l-4 border border-gray-500 rounded-3xl p-8 max-w-3xl">
          <h2 id="lab-vibe-title" class="font-garamond font-semibold italic text-gray-800 text-xl mb-3" data-i18n="lab.vibe.title">
            What is<em>'vibe coding'</em>?
          </h2>

          <p id="lab-vibe-text" class="text-gray-600 leading-relaxed" data-i18n="lab.vibe.text">
            <em>'Vibe coding'</em> is building with AI assistance&mdash; you describe what you want, the AI generates the code, and you shape and guide
            it. It's less about writing every line yourself and more about knowing what you want and being able to evaluate what you get. It changes how
            you think about prototyping and iteration.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div id="lab-divider-1" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-16 pt-12 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Revamped School Projects -->
  <section id="lab-revamped" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="lab-revamped-title"
      class="font-garamond font-semibold italic md:text-h3-desktop text-h3-mobile text-gray-800 mb-3"
      data-i18n="lab.revamped.title"
    >
      Old school projects, revamped
    </h2>

    <p id="lab-revamped-intro" class="text-sm text-gray-600 leading-relaxed max-w-3xl mb-6" data-i18n="lab.revamped.intro">
      Past projects from Multimedia Design, rebuilt from scratch with the tools and perspective I have now.
    </p>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Digital Resume / PPP -->
      <article id="lab-item-srpprofile" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2024/2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800" data-i18n="lab.srpprofile.title">
          Digital resume <em>(PPP)</em>
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.srpprofile.desc">
          A personal professional profile – developed and used during our internship preparations.
        </p>
        <Button
          href="https://srp-profile.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit Digital Resume / PPP (opens in new tab)"><span data-i18n="lab.srpprofile.link">Visit site →</span></Button
        >
      </article>

      <!-- The Great Mushroom Kingdom Wiki -->
      <article id="lab-item-mariowiki" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2023/2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800">The Great Mushroom Kingdom Wiki</h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.mariowiki.desc">
          A fan wiki exploring the Super Mario universe – my second ever project.
        </p>
        <Button
          href="https://mario-wiki.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit The Great Mushroom Kingdom Wiki (opens in new tab)"><span data-i18n="lab.mariowiki.link">Visit site →</span></Button
        >
      </article>

      <!-- Computer Site -->
      <article id="lab-item-computersite" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2023/2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-3 text-gray-800">Computer Site</h3>
        <p class="text-sm text-gray-600 leading-relaxed mb-6" data-i18n="lab.computersite.desc">
          A site talking about computers and their history – my project from our entrance exam.
        </p>
        <Button
          href="https://computer-site.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit Computer Site (opens in new tab)"><span data-i18n="lab.computersite.link">Visit site →</span></Button
        >
      </article>
    </div>

    <!-- Archive pointer -->
    <div
      id="lab-archive-pointer"
      class="archive-pointer-container md:mt-10 mt-8 w-[30rem] max-w-full px-6 py-4 border border-blue-300 border-l-4 bg-blue-100 rounded-2xl"
    >
      <p id="lab-archive-link" class="flex flex-wrap items-baseline gap-x-[0.2em] text-sm text-blue-600">
        <span data-i18n="lab.archive.intro">Looking for original projects, as old as these?</span>
        <span class="some1">
          <a
            href="/archive"
            class="inline-flex items-baseline text-[1em] text-current transition duration-300 hover:text-blue-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-4"
            aria-label="Go to the archive"
            data-i18n="lab.archive.link"
          >
            Then visit the archive →
          </a>
        </span>
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div id="lab-divider-2" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-16 pt-12 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Lab Items -->
  <section id="lab-items" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="lab-items-title"
      class="font-garamond font-semibold italic md:text-h3-desktop text-h3-mobile text-gray-800 mb-3"
      data-i18n="lab.items.title"
    >
      Projects from the lab
    </h2>

    <p id="lab-items-intro" class="text-sm text-gray-600 leading-relaxed max-w-2xl mb-6" data-i18n="lab.items.intro">
      A collection of experimental tools and concepts centred on neurodivergence, disability, and accessible design. Each project explores how digital
      experiences can feel calmer, clearer, and free from performance pressure.
    </p>

    <p class="lab-legend flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[11px] text-gray-600 mb-6">
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
        <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        <span data-i18n="lab.legend.vibecoded">= built with AI assistance</span>
      </span>
      <span class="text-gray-300 hidden sm:inline" aria-hidden="true">·</span>
      <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
        <span class="lab-tag wip-tag" title="Work in progress — the coded version is still being developed">WIP</span>
        <span data-i18n="lab.legend.wip">= in progress</span>
      </span>
    </p>

    <!-- Projects -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Bivi (featured) -->
      <article
        id="lab-item-bivi"
        class="lab-featured-card md:col-span-2 border-r-4 border border-gray-500 bg-gradient-to-br from-gray-50 to-gray-100 rounded-2xl p-8"
      >
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <div class="max-w-3xl">
          <h3 class="font-bold text-[20px] leading-snug mb-6 text-gray-800" data-i18n="lab.bivi.title">Bivi - Your Little Medication Sidekick</h3>
          <Button
            href="https://web-bivi.netlify.app/"
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            size="small"
            aria-label="Visit Bivi website (opens in new tab)"><span data-i18n="lab.bivi.link">Visit site →</span></Button
          >
        </div>
      </article>

      <!-- Ephemeris -->
      <article id="lab-item-ephemeris" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-6 text-gray-800" data-i18n="lab.ephemeris.title">Ephemeris - Dragon Mood Journal</h3>
        <Button
          href="https://web-ephemeris.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit Ephemeris (opens in new tab)"><span data-i18n="lab.ephemeris.link">Visit site →</span></Button
        >
      </article>

      <!-- Steady -->
      <article id="lab-item-steady" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-6 text-gray-800" data-i18n="lab.steady.title">
          Steady - Daily Life Tracker App for Neurodivergents
        </h3>
        <Button
          href="https://web-steady.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit Steady website (opens in new tab)"><span data-i18n="lab.steady.link">Visit site →</span></Button
        >
      </article>

      <!-- Vibeloop (WIP) -->
      <article id="lab-item-vibeloop" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2025/2026</p>
          <div class="flex items-center gap-2 flex-wrap justify-end">
            <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
            <span class="lab-tag wip-tag" title="Work in progress — the coded version is still being developed">WIP</span>
          </div>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-6 text-gray-800">
          <span data-i18n="lab.vibeloop.title">VibeLoop - Mood Based Social App</span>
          <span class="italic" data-i18n="lab.badge.vibeloopwip">(under development)</span>
        </h3>
        <Button href="/vibeloop" variant="secondary" size="small" aria-label="View the Vibeloop case study"
          ><span data-i18n="lab.vibeloop.link">View case →</span></Button
        >
      </article>

      <!-- AutismeGuiden -->
      <article id="lab-item-autismeguiden" class="bg-gradient-to-br from-gray-50 to-gray-100 border-r-4 border border-gray-500 rounded-2xl p-8">
        <div class="flex items-center justify-between mb-4">
          <p class="text-[12px] uppercase tracking-[0.2em] text-gray-500 whitespace-nowrap shrink-0">2025/2026</p>
          <span class="lab-tag" title="This project was built with AI assistance" data-i18n="lab.badge.vibecoded">Vibe coded</span>
        </div>
        <h3 class="font-bold text-[20px] leading-snug mb-6 text-gray-800" data-i18n="lab.autismeguiden.title">
          AutismeGuiden - Your Guide to Autism and Neurodivergence
        </h3>
        <Button
          href="https://autisme-guiden.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="small"
          aria-label="Visit AutismeGuiden (opens in new tab)"><span data-i18n="lab.autismeguiden.link">Visit site →</span></Button
        >
      </article>
    </div>
  </section>

  <!-- Back -->
  <section class="lab-back-btn mx-auto py-20 text-center">
    <Button href="/" variant="primary" size="small" aria-label="Back to homepage"><span data-i18n="btn.back">Back to homepage</span></Button>
  </section>
</MainLayout>

<!-- Animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      document.body.classList.add("reduce-motion");
      return;
    }

    let i = 0;
    const register = (selector: string) => {
      const el = document.querySelector(selector) as HTMLElement | null;
      if (!el) return;
      inView(el, () => {
        el.style.animationDelay = `${i * 60}ms`;
        el.style.animationDuration = "1.5s";
        el.style.animationFillMode = "both";
        el.classList.add("animate__animated", "animate__fadeInUp");
      });
      i++;
    };

    [
      "#lab-title-row",
      "#lab-intro",
      "#lab-about",
      "#lab-revamped-title",
      "#lab-revamped-intro",
      "#lab-items-title",
      "#lab-items-intro",
      "#lab-divider-1",
      "#lab-divider-2",
      "#lab-archive-pointer",
    ].forEach(register);

    document.querySelectorAll("#lab-revamped > div > article, #lab-items > div > article, #lab-items > div > div").forEach((el, idx) => {
      inView(el, () => {
        (el as HTMLElement).style.animationDelay = `${idx * 80}ms`;
        (el as HTMLElement).style.animationDuration = "1.3s";
        (el as HTMLElement).style.animationFillMode = "both";
        el.classList.add("animate__animated", "animate__fadeInUp");
      });
    });

    document.querySelectorAll(".lab-legend > span").forEach((el, idx) => {
      inView(el, () => {
        (el as HTMLElement).style.animationDelay = `${idx * 80}ms`;
        (el as HTMLElement).style.animationDuration = "1.3s";
        (el as HTMLElement).style.animationFillMode = "both";
        el.classList.add("animate__animated", "animate__fadeInUp");
      });
    });
  });
</script>

<style>
  html.has-js body:not(.reduce-motion) #lab-label,
  html.has-js body:not(.reduce-motion) #lab-title-row,
  html.has-js body:not(.reduce-motion) #lab-intro,
  html.has-js body:not(.reduce-motion) #lab-about,
  html.has-js body:not(.reduce-motion) #lab-revamped-title,
  html.has-js body:not(.reduce-motion) #lab-revamped-intro,
  html.has-js body:not(.reduce-motion) #lab-items-title,
  html.has-js body:not(.reduce-motion) #lab-items-intro,
  html.has-js body:not(.reduce-motion) #lab-archive-pointer,
  html.has-js body:not(.reduce-motion) #lab-divider-1,
  html.has-js body:not(.reduce-motion) #lab-divider-2,
  html.has-js body:not(.reduce-motion) #lab-item-vibeloop,
  html.has-js body:not(.reduce-motion) #lab-item-bivi,
  html.has-js body:not(.reduce-motion) #lab-item-autismeguiden,
  html.has-js body:not(.reduce-motion) #lab-item-steady,
  html.has-js body:not(.reduce-motion) #lab-item-srpprofile,
  html.has-js body:not(.reduce-motion) #lab-item-computersite,
  html.has-js body:not(.reduce-motion) #lab-item-mariowiki,
  html.has-js body:not(.reduce-motion) #lab-revamped > div > article,
  html.has-js body:not(.reduce-motion) #lab-items > div > article,
  html.has-js body:not(.reduce-motion) #lab-items > div > div,
  html.has-js body:not(.reduce-motion) .lab-legend > span {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    will-change: transform, opacity;
  }

  .lab-tag {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
    border-radius: 9999px;
    border: 1px solid rgba(71, 123, 147, 0.4);
    background: rgba(71, 123, 147, 0.1);
    color: var(--brand-primary-strong);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.42rem 0.72rem;
    text-transform: uppercase;
  }

  .wip-tag {
    border-color: rgba(217, 119, 6, 0.4);
    background: rgba(217, 119, 6, 0.1);
    color: #92400e;
  }

  /* Dark mode — text */
  body.dark #lab h1,
  body.dark #lab-label,
  body.dark #lab-intro,
  body.dark #lab-vibe-title,
  body.dark #lab-vibe-text,
  body.dark #lab-revamped-title,
  body.dark #lab-revamped-intro,
  body.dark #lab-items-title,
  body.dark #lab-items-intro,
  body.dark #lab-revamped article h3,
  body.dark #lab-revamped article p,
  body.dark #lab-items article h3,
  body.dark #lab-items article p {
    color: var(--text-on-dark-soft);
  }

  /* Dark mode — card backgrounds */
  body.dark #lab-about > div {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #lab-revamped article,
  body.dark #lab-items article {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  /* Dark mode — badges */
  body.dark .lab-tag {
    border-color: rgba(192, 215, 225, 0.35);
    background: rgba(71, 123, 147, 0.2);
    color: var(--brand-primary-soft);
  }

  body.dark .wip-tag {
    border-color: rgba(251, 191, 36, 0.35);
    background: rgba(217, 119, 6, 0.2);
    color: #fbbf24;
  }

  body.dark .lab-legend {
    color: var(--dark-border);
  }

  body.dark .archive-pointer-container {
    background-color: color-mix(in srgb, var(--dark-surface) 80%, #1e3a5f 20%);
    border-color: color-mix(in srgb, var(--dark-border) 60%, #3b6ea5 40%);
    color: color-mix(in srgb, var(--text-on-dark-soft) 90%, #a8c8e8 10%);
  }

  body.dark #lab-archive-link {
    color: color-mix(in srgb, var(--text-on-dark-soft) 90%, #a8c8e8 10%);
  }

  body.dark #lab-archive-link a:hover {
    color: var(--brand-primary-soft);
  }
</style>
