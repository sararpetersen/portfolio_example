<!-- Script for inView animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion");

    if (!reduceMotion) {
      let animationIndex = 0;
      const registerInView = (selector: string, animationClass: string = "animate__fadeInUp") => {
        const element = document.querySelector(selector) as HTMLElement | null;
        if (!element) return;

        const delayMs = animationIndex * 60;
        inView(element, () => {
          element.classList.add("animate__animated", animationClass);
          element.style.animationDelay = `${delayMs}ms`;
          element.style.animationDuration = "1.6s";
        });

        animationIndex++;
      };

      [
        "#about-me-title-label",
        "#about-title-row",
        ".heading-text",
        "#personal-background-tabs",
        "#personal-background img",
        "#about-divider-1",
        "#about-divider-2",
        "#interests-title-row",
        ".strength-and-weaknesses h3",
        "#resources-title-row",
        "#timeline-title-row",
        "#timeline-label",
        "#interests-label",
        "#resources-label",
        ".button-container",
      ].forEach((selector) => {
        registerInView(selector);
      });

      const timelineItems = document.querySelectorAll(".timeline-item");
      const timelineBadges = document.querySelectorAll(".timeline-column-badge");

      timelineBadges.forEach((timelineBadge, index) => {
        inView(timelineBadge, () => {
          timelineBadge.classList.add("animate__animated", "animate__fadeInUp");
          (timelineBadge as HTMLElement).style.animationDelay = `${index * 70}ms`;
          (timelineBadge as HTMLElement).style.animationDuration = "1.2s";
        });
      });

      timelineItems.forEach((timelineItem, index) => {
        inView(timelineItem, () => {
          timelineItem.classList.add("animate__animated", "animate__fadeInUp");
          (timelineItem as HTMLElement).style.animationDelay = `${index * 60}ms`;
          (timelineItem as HTMLElement).style.animationDuration = "1.2s";
        });
      });

      const sections = document.querySelectorAll("#interests-and-hobbies > div");

      sections.forEach((sections, index) => {
        inView(sections, () => {
          sections.classList.add("animate__animated", "animate__fadeInUp");
          (sections as HTMLElement).style.animationDelay = `${index * 60}ms`;
          (sections as HTMLElement).style.animationDuration = "1.4s";
        });
      });

      const section = document.querySelectorAll("#resources-section > div");

      section.forEach((section, index) => {
        inView(section, () => {
          section.classList.add("animate__animated", "animate__fadeInUp");
          (section as HTMLElement).style.animationDelay = `${index * 60}ms`;
          (section as HTMLElement).style.animationDuration = "1.4s";
        });
      });

      document.querySelectorAll("#").forEach((divider) => {
        inView(divider, () => {
          divider.classList.add("animate__animated", "animate__bounceInDown");
          divider.addEventListener(
            "animationend",
            () => {
              divider.classList.remove("animate__animated", "animate__bounceInDown");
            },
            { once: true },
          );
        });
      });
    }
  });
</script>

