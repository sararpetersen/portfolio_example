---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";

interface TimelineItem {
  i18nKey: number;
  category: "school" | "work";
  year: string;
  title: string;
  desc: string;
  note?: string;
}

const timelineItems: TimelineItem[] = [
  {
    i18nKey: 0,
    category: "school",
    year: "August 2019 - June 2021",
    title: "HF | Egedal Gymnasium & HF",
    desc: "Completed high school with a focus on art, social studies and psychology, which sparked my interest in creativity, people and communication.",
  },
  {
    i18nKey: 5,
    category: "work",
    year: "January 2026 - June 2026",
    title: "Student Buddy | Academy of Technologies and Business (Zealand)",
    desc: "Supporting international students through onboarding, social and academic integration, and acting as a go-to contact for everyday questions.",
  },
  {
    i18nKey: 2,
    category: "school",
    year: "August 2023 - June 2025",
    title: "Multimedia Design | Copenhagen School of Design and Technology (KEA)",
    desc: "Worked with UX/UI, digital design and coding, and gained hands-on experience with design tools, prototyping and web projects.",
  },
  {
    i18nKey: 3,
    category: "work",
    year: "January 2025 - April 2025",
    title: "Junior Creative/Intern | Kadaver ApS",
    desc: "Worked on website redesigns, developed sitemaps and information architecture, and created maintenance documentation for clients.",
  },
  {
    i18nKey: 4,
    category: "school",
    year: "Present",
    title: "Digital Concept Development | Academy of Technologies and Business (Zealand)",
    desc: "Currently studying how to turn ideas into user-focused digital concepts, with a strong focus on strategic and behavioural design.",
  },
  {
    i18nKey: 6,
    category: "work",
    year: "May 2026 - October 2026",
    title: "Software Developer & Multimedia Design Intern | Folkæt",
    desc: "Working on the further development of interactive quizzes and improving user-flows, and contributes to digital solutions with a focus on user-experience and engagement.",
  },
];

const getTimelineSortValue = (yearRange: string) => {
  if (yearRange.toLowerCase().includes("present")) return 9999;

  const years = yearRange.match(/\d{4}/g);
  if (!years || years.length === 0) return 0;

  return Number(years[years.length - 1]);
};

const schoolTimelineItems = timelineItems
  .filter((item) => item.category === "school")
  .sort((a, b) => getTimelineSortValue(b.year) - getTimelineSortValue(a.year));

const workTimelineItems = timelineItems
  .filter((item) => item.category === "work")
  .sort((a, b) => getTimelineSortValue(b.year) - getTimelineSortValue(a.year));
---

<MainLayout
  title="SRP portfolio | About me"
  description="About Sara and her background"
  ogtitle="SRP portfolio - the portfolio of Sara Ringkow Petersen"
  ogdescription="Learn more about Sara"
>
  <!-- Top Section -->
  <section
    id="about-me"
    class="grid grid-cols-12 md:pt-desktop-top pt-mobil-top md:mt-16 mt-8 md:px-0 px-8 mx-auto relative container max-w-6xl md:text-left text-center"
  >
    <div class="relative col-span-12 md:pt-12 pt-16 mb-12">
      <div id="about-title-row" class="flex items-center md:justify-start justify-center gap-4 mb-3">
        <h1
          class="heading-title uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru text-[1.85rem] md:text-h2-desktop md:text-left text-center"
          data-i18n="about.title"
        >
          About me
        </h1>
      </div>
      <p class="heading-text text-gray-600 max-w-3xl" data-i18n="about.intro">
        Expand a section in the menu below to read about my background, what inspires me, and where I'm heading.<br class="hidden md:block" /> Scroll further
        down the page to explore my journey, interests, and downloadable resources.
      </p>
    </div>
  </section>

  <!-- Personal Background -->
  <section id="personal-background" class="container grid grid-cols-12 px-6 max-w-6xl mx-auto md:px-0">
    <div class="grid md:grid-cols-2 grid-cols-1 md:items-start items-center justify-center col-span-12">
      <div id="personal-background-content" class="md:pb-0 pb-8">
        <div class="personal-bg-item border-t-2 border-gray-200">
          <button
            type="button"
            id="acc-trigger-background"
            class="accordion-trigger w-full flex items-center justify-between py-5 text-left"
            aria-expanded="false"
            aria-controls="acc-background"
          >
            <h4 class="text-gray-800" data-i18n="about.tab.background">Background</h4>
            <svg
              class="accordion-chevron w-4 h-4 text-gray-400 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
            </svg>
          </button>
          <div id="acc-background" class="accordion-panel" role="region" aria-labelledby="acc-trigger-background">
            <div>
              <p class="text-gray-500 text-sm leading-relaxed pb-5" data-i18n="about.background.text">
                I've always loved being creative. From a young age, I've enjoyed drawing, painting, crafting&mdash; just everything that spelt <em
                  >"creativity"</em
                > in general. I knew deep down that when I grew up, I someday wanted to make that a career. As I became older, however, I also started to
                become interested in technology. And now wanting a career that combined both that and creativity, I struggled to find the right thing. This
                internal conflict between my artistic interests and my growing curiosity about tech kept me searching for a path that could harmonise these
                two passions. It wasn't until I discovered Multimedia Design that I finally found the answer I'd been looking for.
              </p>
            </div>
          </div>
        </div>
        <div class="personal-bg-item border-t-2 border-gray-200">
          <button
            type="button"
            id="acc-trigger-inspiration"
            class="accordion-trigger w-full flex items-center justify-between py-5 text-left"
            aria-expanded="false"
            aria-controls="acc-inspiration"
          >
            <h4 class="text-gray-800" data-i18n="about.tab.inspiration">Inspiration</h4>
            <svg
              class="accordion-chevron w-4 h-4 text-gray-400 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
            </svg>
          </button>
          <div id="acc-inspiration" class="accordion-panel" role="region" aria-labelledby="acc-trigger-inspiration">
            <div>
              <p class="text-gray-500 text-sm leading-relaxed pb-5" data-i18n="about.inspiration.text">
                As someone who's late-diagnosed with autism and recently diagnosed with ADD, I know what it's like navigating a world that isn't
                always accessible to everyone. This personal experience has shaped my perspective on creating meaningful digital experiences. I'm
                inspired by the potential of inclusive design to create spaces where everyone can thrive. Whether it's through thoughtful color
                choices, clear navigation, or semantic HTML, I find purpose in solving accessibility challenges and seeing how small design decisions
                can have a meaningful impact on people's lives.
              </p>
            </div>
          </div>
        </div>
        <div class="personal-bg-item border-t-2 border-gray-200">
          <button
            type="button"
            id="acc-trigger-goals"
            class="accordion-trigger w-full flex items-center justify-between py-5 text-left"
            aria-expanded="false"
            aria-controls="acc-goals"
          >
            <h4 class="text-gray-800" data-i18n="about.tab.goals">Goals</h4>
            <svg
              class="accordion-chevron w-4 h-4 text-gray-400 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
            </svg>
          </button>
          <div id="acc-goals" class="accordion-panel" role="region" aria-labelledby="acc-trigger-goals">
            <div>
              <p class="text-gray-500 text-sm leading-relaxed pb-5" data-i18n="about.goals.text">
                My goal is to create digital experiences that are accessible and inclusive for everyone. I believe that good design isn't just about
                aesthetics&mdash; it's about removing barriers and ensuring all users are included. Through my work, I strive to merge creativity with
                purpose, always keeping accessibility and user experience at the forefront. I want to apply my passion for inclusive design in my
                future career and make a real difference in how people interact with digital products.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-center md:justify-end">
        <img
          src="/images/pfp2.webp"
          alt="Portrait of Sara (taken during the internship at Kadaver)"
          class="portrait md:w-[400px] w-[250px] md:h-[450px] h-[300px] object-cover rounded-2xl border-r-4 border border-gray-500"
          width="400"
          height="450"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div id="about-divider-1" class="max-w-6xl mx-auto md:px-0 px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Timeline -->
  <section id="timeline" class="container max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="timeline-title"
      class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 pb-6"
      data-i18n="timeline.title"
    >
      The highlights of my journey
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      <div>
        <h4 class="timeline-column-label font-garamond italic font-semibold text-base text-gray-800 mb-4" data-i18n="timeline.education">
          Education
        </h4>
        <div class="flex flex-col">
          {
            schoolTimelineItems.map((item) => (
              <div class="timeline-item border-t-2 border-gray-200 pt-5 pb-5 last:pb-0">
                <p class="text-[11px] font-semibold text-gray-500 mb-1 uppercase tracking-widest" data-i18n={`timeline.${item.i18nKey}.year`}>
                  {item.year}
                </p>
                <h5 class="font-bold text-[15px] leading-snug mb-1" data-i18n={`timeline.${item.i18nKey}.title`}>
                  {item.title}
                </h5>
                <p class="text-gray-500 text-sm leading-relaxed" data-i18n={`timeline.${item.i18nKey}.desc`}>
                  {item.desc}
                </p>
                {item.note && (
                  <p class="italic text-gray-400 text-xs mt-2" data-i18n={`timeline.${item.i18nKey}.note`}>
                    {item.note}
                  </p>
                )}
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h4 class="timeline-column-label font-garamond italic font-semibold text-base text-gray-800 mb-4" data-i18n="timeline.work">
          Work experience
        </h4>
        <div class="flex flex-col">
          {
            workTimelineItems.map((item) => (
              <div class="timeline-item border-t-2 border-gray-200 pt-5 pb-5 last:pb-0">
                <p class="text-[11px] font-semibold text-gray-500 mb-1 uppercase tracking-widest" data-i18n={`timeline.${item.i18nKey}.year`}>
                  {item.year}
                </p>
                <h5 class="font-bold text-[15px] leading-snug mb-1" data-i18n={`timeline.${item.i18nKey}.title`}>
                  {item.title}
                </h5>
                <p class="text-gray-500 text-sm leading-relaxed" data-i18n={`timeline.${item.i18nKey}.desc`}>
                  {item.desc}
                </p>
                {item.note && (
                  <p class="italic text-gray-400 text-xs mt-2" data-i18n={`timeline.${item.i18nKey}.note`}>
                    {item.note}
                  </p>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Interests and Hobbies -->
  <section id="interests" class="max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <div class="flex flex-col mb-6">
      <h2
        id="interests-title"
        class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-6"
        data-i18n="interests.title"
      >
        Interests and hobbies
      </h2>
    </div>
    <div id="interests-and-hobbies" class="grid md:grid-cols-3 grid-cols-1 gap-x-10 gap-y-8">
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.reading.title">Reading</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.reading.text">
          There's nothing better than getting lost in a good book — it's my go-to way to unwind and explore new worlds.
        </p>
      </div>
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.gaming.title">Gaming</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.gaming.text">
          Video games let me step into different realities and tackle challenges in ways that feel completely immersive.
        </p>
      </div>
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.nintendo.title">Nintendo &amp; Super Mario</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.nintendo.text">
          There's just something about those worlds that keeps drawing me back.
        </p>
      </div>
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.japanese.title">Japanese culture</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.japanese.text">
          I love the balance between simplicity, detail, and thoughtful storytelling.
        </p>
      </div>
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.lego.title">Building with LEGO</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.lego.text">My creative outlet that doesn't require a screen.</p>
      </div>
      <div class="interest-item border-t-2 border-gray-200 pt-5">
        <h4 class="text-gray-800 mb-2" data-i18n="interest.themepark.title">Theme parks &amp; attractions</h4>
        <p class="text-gray-500 text-sm leading-relaxed" data-i18n="interest.themepark.text">
          Few things beat a full day at a theme park — the rides, the shows, all of it.
        </p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div id="about-divider-2" class="max-w-6xl mx-auto md:px-0 px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Resources Section -->
  <section id="resources" class="resources-section max-w-6xl mx-auto lg:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="resources-title"
      class="font-garamond font-semibold italic text-h3-mobile md:text-h3-desktop text-gray-800 mb-6"
      data-i18n="resources.title"
    >
      Resources
    </h2>
    <div id="resources-section" class="divide-y divide-gray-200">
      <div class="resource-row flex md:flex-row flex-col md:items-center md:justify-between gap-3 md:gap-0 py-4">
        <h4 class="text-gray-800" data-i18n="resource.app.en.title">Application-template (EN)</h4>
        <a
          href="/pdfs/application_template_sararpetersen_(EN).pdf"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="See application-template (EN)"
          class="self-start py-2"
        >
          <Button variant="secondary" size="small"><span data-i18n="resource.app.en.btn">View template</span></Button>
        </a>
      </div>
      <div class="resource-row flex md:flex-row flex-col md:items-center md:justify-between gap-3 md:gap-0 py-4">
        <h4 class="text-gray-800" data-i18n="resource.resume.en.title">Resume (EN)</h4>
        <a href="/pdfs/CV_sararpetersen_(EN).pdf" target="_blank" rel="noopener noreferrer" aria-label="See resume (EN)" class="self-start py-2">
          <Button variant="secondary" size="small"><span data-i18n="resource.resume.en.btn">View resume</span></Button>
        </a>
      </div>
      <div class="resource-row flex md:flex-row flex-col md:items-center md:justify-between gap-3 md:gap-0 py-4">
        <h4 class="text-gray-800" data-i18n="resource.app.da.title">Ansøgningsskabelon (DA)</h4>
        <a
          href="/pdfs/application_template_sararpetersen_(DA).pdf"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="See application-template (DA)"
          class="self-start py-2"
        >
          <Button variant="secondary" size="small"><span data-i18n="resource.app.da.btn">Se skabelon</span></Button>
        </a>
      </div>
      <div class="resource-row flex md:flex-row flex-col md:items-center md:justify-between gap-3 md:gap-0 py-4">
        <h4 class="text-gray-800" data-i18n="resource.cv.da.title">CV (DA)</h4>
        <a href="/pdfs/CV_sararpetersen_(DA).pdf" target="_blank" rel="noopener noreferrer" aria-label="See resume (DA)" class="self-start py-2">
          <Button variant="secondary" size="small"><span data-i18n="resource.cv.da.btn">Se CV</span></Button>
        </a>
      </div>
    </div>
  </section>

  <!-- Navigation Back to Portfolio -->
  <section class="button-container mx-auto py-20 text-center">
    <a href="/" class="mt-8 btn_container" aria-label="Back to homepage">
      <Button variant="primary" size="small"><span data-i18n="btn.back">Back to homepage</span></Button>
    </a>
  </section>
</MainLayout>

<!-- Accordion script -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll<HTMLButtonElement>(".accordion-trigger").forEach((trigger) => {
      const panelId = trigger.getAttribute("aria-controls");
      if (!panelId) return;
      const panel = document.getElementById(panelId);
      if (!panel) return;

      trigger.addEventListener("click", () => {
        const isExpanded = trigger.getAttribute("aria-expanded") === "true";
        trigger.setAttribute("aria-expanded", String(!isExpanded));
        panel.classList.toggle("open", !isExpanded);
      });
    });
  });
</script>

<!-- Script for inView animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;

    if (!reduceMotion) {
      let animationIndex = 0;

      const registerInView = (selector: string, animationClass: string = "animate__fadeInUp") => {
        const element = document.querySelector(selector) as HTMLElement | null;
        if (!element) return;

        const delayMs = isMobileViewport ? Math.min(animationIndex * 60, 220) : animationIndex * 60;
        let stop = () => {};
        stop = inView(element, () => {
          element.classList.add("animate__animated", animationClass);
          element.style.animationDelay = `${delayMs}ms`;
          element.style.animationDuration = "1.6s";
          element.style.animationFillMode = "both";
          stop();
        });

        animationIndex++;
      };

      [
        "#about-title-row",
        ".heading-text",
        "#personal-background img",
        "#about-divider-1",
        "#timeline-title",
        "#interests-title",
        "#resources-title",
        "#about-divider-2",
        ".button-container",
      ].forEach((selector) => {
        registerInView(selector);
      });

      document.querySelectorAll<HTMLElement>(".personal-bg-item").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          item.classList.add("animate__animated", "animate__fadeInUp");
          item.style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          item.style.animationDuration = "1.4s";
          item.style.animationFillMode = "both";
          stop();
        });
      });

      document.querySelectorAll<HTMLElement>(".timeline-column-label").forEach((label, index) => {
        let stop = () => {};
        stop = inView(label, () => {
          label.classList.add("animate__animated", "animate__fadeInUp");
          label.style.animationDelay = `${isMobileViewport ? Math.min(index * 70, 220) : index * 70}ms`;
          label.style.animationDuration = "1.2s";
          label.style.animationFillMode = "both";
          stop();
        });
      });

      document.querySelectorAll<HTMLElement>(".timeline-item").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          item.classList.add("animate__animated", "animate__fadeInUp");
          item.style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          item.style.animationDuration = "1.2s";
          item.style.animationFillMode = "both";
          stop();
        });
      });

      document.querySelectorAll<HTMLElement>("#interests-and-hobbies > div").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          item.classList.add("animate__animated", "animate__fadeInUp");
          item.style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          item.style.animationDuration = "1.4s";
          item.style.animationFillMode = "both";
          stop();
        });
      });

      document.querySelectorAll<HTMLElement>("#resources-section > div").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          item.classList.add("animate__animated", "animate__fadeInUp");
          item.style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          item.style.animationDuration = "1.4s";
          item.style.animationFillMode = "both";
          stop();
        });
      });
    }
  });
</script>

<!-- CSS -->
<style>
  /* Accordion */
  .accordion-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
    overflow: hidden;
  }

  .accordion-panel.open {
    grid-template-rows: 1fr;
  }

  .accordion-panel > div {
    overflow: hidden;
  }

  .accordion-chevron {
    transition: transform 0.3s ease;
  }

  .accordion-trigger[aria-expanded="true"] .accordion-chevron {
    transform: rotate(180deg);
  }

  .accordion-trigger {
    background: none;
    border: none;
    cursor: pointer;
  }

  body.dark .accordion-trigger h4 {
    color: var(--text-on-dark-soft);
  }

  body.dark .accordion-chevron {
    color: var(--dark-border-strong);
  }

  /* Pre-animation: hide elements until JS fires */
