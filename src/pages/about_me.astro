---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";

interface TimelineItem {
  year: string;
  title: string;
  desc: string;
  note?: string;
}

const timelineItems: TimelineItem[] = [
  {
    year: "August 2019 – June 2021",
    title: "HF (Higher Preparatory Examination) | Egedal Gymnasium & HF",
    desc: "Completed high school with a focus on art, social studies and psychology, which sparked my interest in creativity, people and communication.",
  },
  {
    year: "August 2022 – May 2023",
    title: "Japanese (Level 0-B) | Frederiksberg VUC & STX",
    desc: "Completed a singular course in Japanese language, focusing on basic grammar, vocabulary and cultural understanding.",
  },
  {
    year: "August 2023 – June 2025",
    title: "Multimedia Design | Copenhagen School of Design and Technology (KEA)",
    desc: "Studied UX/UI, digital design and frontend development, and worked hands-on with design tools, prototyping and web projects.",
  },
  {
    year: "January 2025 – April 2025",
    title: "Junior Creative/intern | Kadaver ApS",
    desc: "Worked with website redesigns, information structure and client documentation while gaining real experience in a creative agency.",
  },
  {
    year: "Present",
    title: "Digital Concept Development | Academy of Technologies and Business (Zealand)",
    desc: "Currently studying how to turn ideas into user-focused digital concepts, with a strong focus on storytelling, strategy and experience design.",
  },
  {
    year: "Present",
    title: "Student Buddy | Academy of Technologies and Business (Zealand)",
    desc: "Helping international students feel welcome, supporting them in their studies and everyday life, and being someone they can easily reach out to.",
  },
];
---

<MainLayout
  title="SRP portfolio | About me"
  description="About Sara and her background"
  ogtitle="SRP portfolio - the portfolio of Sara Ringkow Petersen"
  ogdescription="Learn more about Sara"
>
  <section
    id="about-me"
    class="grid grid-cols-12 md:pt-desktop-top pt-mobil-top md:mt-16 mt-8 md:px-0 px-8 mx-auto relative container max-w-6xl md:text-left text-center"
  >
    <!-- Intro Section -->
    <div class="relative col-span-12 md:pt-12 pt-16 md:pb-20">
      <p id="about-me-title-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="about.label">
        Profile
      </p>
      <h1 class="heading-title uppercase tracking-[0.14em] md:tracking-[0.18em] font-hiro md:text-left text-center mb-9" data-i18n="about.title">
        About me
      </h1>
      <p class="heading-text text-gray-600 md:pb-0 pb-16 max-w-3xl" data-i18n="about.intro">
        Read a little bit about me, my background, and who I am. You'll also find the templates that I've used for my resume and applications at the
        very bottom of the page.
      </p>
    </div>
  </section>
  <!-- Personal Background -->
  <section id="personal-background" class="container grid grid-cols-12 px-6 max-w-6xl mx-auto md:px-0">
    <div class="grid md:grid-cols-2 grid-cols-1 md:items-start items-center justify-center col-span-12">
      <div class="items-center md:pb-0 pb-8">
        <!-- Tabs -->
        <div class="flex gap-2 mb-6 border-b border-gray-300" role="tablist" aria-label="Personal background tabs">
          <button
            id="tab-background"
            type="button"
            class="tab-btn px-4 py-2 text-gray-800 border-b-2 border-transparent hover:text-blue-500 transition duration-300"
            data-tab="background"
            role="tab"
            aria-controls="background"
            aria-selected="true"
            tabindex="0"
            data-i18n="about.tab.background"
          >
            Background
          </button>
          <button
            id="tab-inspiration"
            type="button"
            class="tab-btn px-4 py-2 text-gray-800 border-b-2 border-transparent hover:text-blue-500 transition duration-300"
            data-tab="inspiration"
            role="tab"
            aria-controls="inspiration"
            aria-selected="false"
            tabindex="-1"
            data-i18n="about.tab.inspiration"
          >
            Inspiration
          </button>
          <button
            id="tab-goals"
            type="button"
            class="tab-btn px-4 py-2 text-gray-800 border-b-2 border-transparent hover:text-blue-500 transition duration-300"
            data-tab="goals"
            role="tab"
            aria-controls="goals"
            aria-selected="false"
            tabindex="-1"
            data-i18n="about.tab.goals"
          >
            Goals
          </button>
        </div>

        <!-- Tab Content -->
        <div
          id="background"
          class="tab-content active text-gray-600"
          role="tabpanel"
          aria-labelledby="tab-background"
          aria-hidden="false"
          tabindex="0"
        >
          <p data-i18n="about.background.text">
            I've always loved being creative. From a young age, I've enjoyed drawing, painting, crafting&mdash; just everything that spelt <em
              >"creativity"</em
            > in general. I knew deep down that when I grew up, I someday wanted to make that a career. As I became older, however, I also started to become
            interested in technology. And now wanting a career that combined both that and creativity, I struggled to find the right thing. This internal
            conflict between my artistic interests and my growing curiosity about tech kept me searching for a path that could harmonise these two passions.
            It wasn't until I discovered Multimedia Design that I finally found the answer I'd been looking for.
          </p>
        </div>

        <div
          id="inspiration"
          class="tab-content hidden text-gray-600"
          role="tabpanel"
          aria-labelledby="tab-inspiration"
          aria-hidden="true"
          tabindex="0"
        >
          <p data-i18n="about.inspiration.text">
            As someone who's late-diagnosed with autism, I know what it's like navigating a world that isn't always accessible to everyone. This
            personal experience has shaped my perspective on creating meaningful digital experiences. I'm inspired by the potential of inclusive
            design to create spaces where everyone can thrive. Whether it's through thoughtful color choices, clear navigation, or semantic HTML, I
            find purpose in solving accessibility challenges and seeing how small design decisions can have a meaningful impact on people's lives.
          </p>
        </div>

        <div id="goals" class="tab-content hidden text-gray-600" role="tabpanel" aria-labelledby="tab-goals" aria-hidden="true" tabindex="0">
          <p data-i18n="about.goals.text">
            My goal is to create digital experiences that are accessible and inclusive for everyone. I believe that good design isn't just about
            aesthetics&mdash; it's about removing barriers and ensuring all users are included. Through my work, I strive to merge creativity with
            purpose, always keeping accessibility and user experience at the forefront. I want to apply my passion for inclusive design in my future
            career and make a real difference in how people interact with digital products.
          </p>
        </div>
      </div>
      <div class="flex items-center justify-start md:justify-end">
        <img
          src="/images/pfp2.webp"
          alt="Portrait of Sara (taken during the internship at Kadaver)"
          class="portrait md:w-[400px] w-[250px] md:h-[450px] h-[300px] object-cover rounded-2xl border-r-4 border border-gray-500"
        />
      </div>
    </div>
  </section>

  <script>
    const tabButtons = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const tabContents = document.querySelectorAll<HTMLElement>(".tab-content");

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tabName = button.getAttribute("data-tab");
        if (!tabName) return;

        tabButtons.forEach((btn) => {
          btn.classList.remove("active", "border-b-blue-500", "font-semibold");
          btn.classList.add("border-b-transparent", "text-gray-600");
          btn.setAttribute("aria-selected", "false");
          btn.setAttribute("tabindex", "-1");
          btn.removeAttribute("aria-current");
        });

        tabContents.forEach((content) => {
          content.classList.add("hidden");
          content.classList.remove("active");
          content.setAttribute("aria-hidden", "true");
        });

        button.classList.add("active", "border-b-blue-500", "font-semibold");
        button.classList.remove("border-b-transparent", "text-gray-600");
        button.setAttribute("aria-selected", "true");
        button.setAttribute("tabindex", "0");
        button.setAttribute("aria-current", "page");

        const content = document.getElementById(tabName);
        if (!content) return;
        content.classList.remove("hidden");
        content.classList.add("active");
        content.setAttribute("aria-hidden", "false");
      });

      button.addEventListener("keydown", (event) => {
        const key = event.key;
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(key)) return;

        event.preventDefault();
        const tabs = Array.from(tabButtons);
        const currentIndex = tabs.indexOf(button);

        let nextIndex = currentIndex;
        if (key === "ArrowRight") nextIndex = (currentIndex + 1) % tabs.length;
        if (key === "ArrowLeft") nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
        if (key === "Home") nextIndex = 0;
        if (key === "End") nextIndex = tabs.length - 1;

        tabs[nextIndex].focus();
        tabs[nextIndex].click();
      });
    });

    // Set the initial active tab
    document.querySelector<HTMLButtonElement>(".tab-btn[data-tab='background']")?.click();
  </script>

  <!-- Timeline -->
  <section id="timeline" class="container max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <p id="timeline-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="timeline.label">
      Timeline
    </p>
    <h3 class="font-hiro pb-10 uppercase tracking-[0.14em] md:tracking-[0.18em]" data-i18n="timeline.title">The highlights of my journey</h3>
    <div id="timeline-line" class="relative">
      <!-- Timeline items -->
      {
        timelineItems.map((item, index) => (
          <div class={`mb-8 pb-8 border-b border-gray-300 flex gap-6 ${index === 9 ? "last:border-b-0" : ""}`}>
            <div class="flex flex-col items-center">
              <div id="timeline-circle" class="w-4 h-4 bg-blue-500 rounded-full border-4 border-white ring-2 ring-gray-300 sticky top-8" />
            </div>
            <div class="flex-1 pt-1">
              <p class="text-xs font-semibold text-blue-500 mb-1 uppercase" data-i18n={`timeline.${index}.year`}>
                {item.year}
              </p>
              <h4 class="text-h4-mobile font-bold mb-2" data-i18n={`timeline.${index}.title`}>
                {item.title}
              </h4>
              <p class="text-gray-600 text-sm" data-i18n={`timeline.${index}.desc`}>
                {item.desc}
              </p>
              {item.note && (
                <p class="italic text-gray-400 text-xs mt-2" data-i18n={`timeline.${index}.note`}>
                  {item.note}
                </p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Interests and Hobbies -->
  <section id="interests" class="max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <div class="flex flex-col mb-6">
      <p id="interests-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="interests.label">
        Interests
      </p>
      <h3 class="font-hiro mb-5 uppercase tracking-[0.14em] md:tracking-[0.18em]" data-i18n="interests.title">Interests and hobbies</h3>
    </div>
    <div id="interests-and-hobbies" class="grid md:grid-cols-2 grid-cols-1 gap-6">
      <!-- Interest Item 1 -->
      <div class="p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
        <h4 class="text-h4-mobile pb-2" data-i18n="interest.reading.title">Reading</h4>
        <p class="text-gray-600" data-i18n="interest.reading.text">
          There's nothing like getting lost in a good book&mdash; it's my go-to way to unwind and explore new worlds.
        </p>
      </div>
      <!-- Interest Item 2 -->
      <div class="p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
        <h4 class="text-h4-mobile pb-2" data-i18n="interest.gaming.title">Gaming</h4>
        <p class="text-gray-600" data-i18n="interest.gaming.text">
          Video games let me step into different realities and tackle challenges in ways that feel completely immersive.
        </p>
      </div>
      <!-- Interest Item 4 -->
      <div class="p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
        <h4 class="text-h4-mobile pb-2" data-i18n="interest.japanese.title">Japanese culture</h4>
        <p class="text-gray-600" data-i18n="interest.japanese.text">
          I'm inspired by Japanese aesthetics, culture, and language, especially the balance between simplicity, detail, and thoughtful storytelling.
        </p>
      </div>
      <!-- Interest Item 5 -->
      <div class="p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
        <h4 class="text-h4-mobile pb-2" data-i18n="interest.lego.title">Building with LEGO</h4>
        <p class="text-gray-600" data-i18n="interest.lego.text">
          There's something oddly therapeutic about clicking LEGO bricks together. It's my creative outlet that doesn't require a screen.
        </p>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section id="resources" class="resources-section max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <div>
      <p id="resources-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="resources.label">
        Resources
      </p>
      <h3 class="font-hiro pb-8 uppercase tracking-[0.14em] md:tracking-[0.18em]" data-i18n="resources.title">Resources</h3>
      <div id="resources-section" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
        <!-- Resource Item -->
        <div class="flex flex-col p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
          <h4 class="text-h4-mobile pb-2" data-i18n="resource.resume.en.title">Resume (EN)</h4>
          <p class="text-gray-600" data-i18n="resource.resume.en.desc">Look through my resume to get an overview of my background.</p>
          <a
            class="mt-5 btn_container md:w-[30%]"
            href="/pdfs/CV_sararpetersen_(EN).pdf"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="See resume (EN)"
          >
            <Button variant="secondary" size="small"><span data-i18n="resource.resume.en.btn">See resume</span></Button>
          </a>
        </div>
        <!-- Resource Item -->
        <div class="flex flex-col p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
          <h4 class="text-h4-mobile pb-2" data-i18n="resource.cv.da.title">CV (DA)</h4>
          <p class="text-gray-600" data-i18n="resource.cv.da.desc">Kig mit CV igennem for at få en oversigt over min baggrund.</p>
          <a
            class="mt-5 btn_container md:w-[30%]"
            href="/pdfs/CV_sararpetersen_(DA).pdf"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="See resume (DA)"
          >
            <Button variant="secondary" size="small"><span data-i18n="resource.cv.da.btn">Se CV</span></Button>
          </a>
        </div>
        <!-- Resource Item -->
        <div class="flex flex-col p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
          <h4 class="text-h4-mobile pb-2" data-i18n="resource.app.en.title">Application-template (EN)</h4>
          <p class="text-gray-600" data-i18n="resource.app.en.desc">Take a look at what I include when I send out applications.</p>
          <a
            class="mt-5 btn_container md:w-[50%]"
            href="/pdfs/application_template_sararpetersen_(EN).pdf"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="See application-template (EN)"
          >
            <Button variant="secondary" size="small"><span data-i18n="resource.app.en.btn">See application-template</span></Button>
          </a>
        </div>
        <!-- Resource Item -->
        <div class="flex flex-col p-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500">
          <h4 class="text-h4-mobile pb-2" data-i18n="resource.app.da.title">Ansøgningsskabelon (DA)</h4>
          <p class="text-gray-600" data-i18n="resource.app.da.desc">Tag et kig på hvad jeg inkluderer når jeg sender ansøgninger ud.</p>
          <a
            class="mt-5 btn_container md:w-[50%]"
            href="/pdfs/application_template_sararpetersen_(DA).pdf"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="See application-template (DA)"
          >
            <Button variant="secondary" size="small"><span data-i18n="resource.app.da.btn">Se ansøgningsskabelon</span></Button>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation Back to Portfolio -->
  <section class="button-container mx-auto py-20 text-center">
    <a href="/" class="mt-8 btn_container" aria-label="Back to homepage">
      <Button variant="primary" size="small"><span data-i18n="btn.back">Back to homepage</span></Button>
    </a>
  </section>
</MainLayout>
<script>
  import { inView } from "motion";

  //inView animations
  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion");

    if (!reduceMotion) {
      const elementmedanimation0 = document.querySelector("#about-me-title-label");
      inView(elementmedanimation0, () => {
        elementmedanimation0.classList.add("animate__animated", "animate__fadeInUp");
      });

      const elementmedanimation1 = document.querySelector(".heading-title");
      inView(elementmedanimation1, () => {
        elementmedanimation1.classList.add("animate__animated", "animate__backInRight");
      });

      const elementmedanimation2 = document.querySelector(".heading-text");
      inView(elementmedanimation2, () => {
        elementmedanimation2.classList.add("animate__animated", "animate__backInLeft");
      });

      const elementmedanimation4 = document.querySelector("#personal-background #background");
      inView(elementmedanimation4, () => {
        elementmedanimation4.classList.add("animate__animated", "animate__slideInRight");
      });

      const elementmedanimation4a = document.querySelector("#personal-background #inspiration");
      inView(elementmedanimation4a, () => {
        elementmedanimation4a.classList.add("animate__animated", "animate__slideInRight");
      });

      const elementmedanimation4b = document.querySelector("#personal-background #goals");
      inView(elementmedanimation4b, () => {
        elementmedanimation4b.classList.add("animate__animated", "animate__slideInRight");
      });

      const elementmedanimation5 = document.querySelector("#personal-background img");
      inView(elementmedanimation5, () => {
        elementmedanimation5.classList.add("animate__animated", "animate__fadeInLeft");
      });

      const elementmedanimation6 = document.querySelector("#interests h3");
      inView(elementmedanimation6, () => {
        elementmedanimation6.classList.add("animate__animated", "animate__fadeInRight");
      });

      const elementmedanimation6a = document.querySelector(".strength-and-weaknesses h3");
      inView(elementmedanimation6a, () => {
        elementmedanimation6a.classList.add("animate__animated", "animate__fadeInRight");
      });

      const elementmedanimation6b = document.querySelector("#resources h3");
      inView(elementmedanimation6b, () => {
        elementmedanimation6b.classList.add("animate__animated", "animate__fadeInRight");
      });

      const elementmedanimation6c = document.querySelector("#timeline h3");
      inView(elementmedanimation6c, () => {
        elementmedanimation6c.classList.add("animate__animated", "animate__fadeInRight");
      });

      const elementmedanimation6d = document.querySelector("#timeline-label");
      inView(elementmedanimation6d, () => {
        elementmedanimation6d.classList.add("animate__animated", "animate__fadeInUp");
      });

      const elementmedanimation6e = document.querySelector("#interests-label");
      inView(elementmedanimation6e, () => {
        elementmedanimation6e.classList.add("animate__animated", "animate__fadeInUp");
      });

      const elementmedanimation6f = document.querySelector("#resources-label");
      inView(elementmedanimation6f, () => {
        elementmedanimation6f.classList.add("animate__animated", "animate__fadeInUp");
      });

      const elementmedanimation7 = document.querySelector(".button-container");
      inView(elementmedanimation7, () => {
        elementmedanimation7.classList.add("animate__animated", "animate__fadeInRight");
      });

      const boxes = document.querySelectorAll("#timeline-line > div");

      boxes.forEach((boxes, index) => {
        inView(boxes, () => {
          boxes.classList.add("animate__animated", "animate__fadeInUp");
          (boxes as HTMLElement).style.animationDelay = `${index * 0.2}s`; // Delay each image by 0.2s
        });
      });

      const sections = document.querySelectorAll("#interests-and-hobbies > div");

      sections.forEach((sections, index) => {
        inView(sections, () => {
          sections.classList.add("animate__animated", "animate__fadeInUp");
          (sections as HTMLElement).style.animationDelay = `${index * 0.2}s`; // Delay each image by 0.2s
        });
      });

      const section = document.querySelectorAll("#resources-section > div");

      section.forEach((section, index) => {
        inView(section, () => {
          section.classList.add("animate__animated", "animate__fadeInUp");
          (section as HTMLElement).style.animationDelay = `${index * 0.2}s`; // Delay each image by 0.2s
        });
      });

      document.querySelectorAll("#").forEach((divider) => {
        inView(divider, () => {
          divider.classList.add("animate__animated", "animate__bounceInDown");
          divider.addEventListener(
            "animationend",
            () => {
              divider.classList.remove("animate__animated", "animate__bounceInDown");
            },
            { once: true },
          );
        });
      });
    }
  });
</script>

<style>
  body.dark .heading-title,
  body.dark .heading-text,
  body.dark h3,
  body.dark h4,
  body.dark p,
  body.dark li,
  body.dark a,
  body.dark .tab-btn {
    color: var(--text-on-dark);
  }

  body.dark .tab-btn:hover,
  body.dark .tab-btn.active {
    color: var(--brand-primary-soft);
    border-color: var(--brand-primary-soft);
  }

  body.dark #interests-and-hobbies > div,
  body.dark #resources-section > div,
  body.dark #strengths-weaknesses-container > div {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #lines hr {
    border-color: var(--dark-border);
  }

  body.dark .portrait {
    border-color: var(--dark-border);
  }

  .tab-btn.active,
  .tab-btn:hover {
    border-color: var(--brand-primary);
    color: var(--brand-primary);
  }
</style>
