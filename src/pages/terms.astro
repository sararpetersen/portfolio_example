---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";

const lastUpdated = "June 25, 2026";
---

<MainLayout
  title="SRP Portfolio | Terms & Privacy"
  description="Privacy policy, freelance booking terms, and terms of use for Sara Ringkow Petersen's portfolio."
  ogtitle="Terms & Privacy — SRP Portfolio"
  ogdescription="Privacy policy, freelance booking terms, and terms of use."
>
  <section class="max-w-3xl mx-auto px-6 md:px-0 md:pt-desktop-top pt-mobil-top md:mt-24 mt-12 md:pb-desktop-bottom pb-mobil-bottom">
    <!-- Page header -->
    <div class="md:pt-12 pt-16 mb-10">
      <h1 class="uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru text-[1.85rem] md:text-h2-desktop mb-3">Terms & Privacy</h1>
      <p class="text-gray-500 text-sm font-inter">Last updated: {lastUpdated}</p>
    </div>

    <!-- Quick navigation -->
    <nav aria-label="Terms navigation" class="terms-toc mb-12">
      <a href="#privacy">Privacy policy</a>
      <span aria-hidden="true">·</span>
      <a href="#booking">Booking & freelance terms</a>
      <span aria-hidden="true">·</span>
      <a href="#use">Terms of use</a>
    </nav>

    <!-- Divider -->
    <div class="flex items-center gap-3 text-gray-300 mb-8" aria-hidden="true">
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
      <span class="block h-2 w-2 rotate-45 border border-current/70 bg-pale-100"></span>
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    </div>

    <!-- 1. Privacy Policy -->
    <section id="privacy" class="terms-section mb-10">
      <h2 class="terms-heading">Privacy policy</h2>
      <p class="terms-sub mb-6">What data is collected and why</p>

      <div class="terms-body flex flex-col gap-gap">
        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Data collected</h3>
          <p class="text-gray-600 leading-relaxed">
            When you submit the contact form on this site, the following information is collected: full name, email address, and the message you
            write. This data is processed and stored by <a
              href="https://www.netlify.com/privacy/"
              class="focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
              target="_blank"
              rel="noopener noreferrer">Netlify Forms</a
            > on my behalf. No other personal data is collected.
          </p>
          <p class="text-gray-600 leading-relaxed mt-3">
            Accessibility preferences you set <em>(such as dark mode, text size, or reduced motion)</em> are stored in your browser's <code
              >localStorage</code
            >. This data never leaves your device and contains no personal information.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Why I collect it</h3>
          <p class="text-gray-600 leading-relaxed">
            Contact form data is used solely to respond to your enquiry. It's <strong><em>not</em></strong> used for marketing, analytics, or any other
            purpose.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Cookies & tracking</h3>
          <p class="text-gray-600 leading-relaxed">
            This site doesn't use cookies for tracking or analytics. No third-party advertising or profiling tools are active.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Your rights <em>(GDPR)</em></h3>
          <p class="text-gray-600 leading-relaxed">
            You have the right to access, correct, or request deletion of any personal data I hold about you. To exercise these rights, contact me at <a
              href="mailto:sara.ringkow@gmail.com">sara.ringkow@gmail.com</a
            >. I'll respond within 30 days.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Data controller</h3>
          <p class="text-gray-600 leading-relaxed">
            Sara Ringkow Petersen – <a href="mailto:sara.ringkow@gmail.com">sara.ringkow@gmail.com</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="flex items-center gap-3 text-gray-300 mb-8" aria-hidden="true">
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
      <span class="block h-2 w-2 rotate-45 border border-current/70 bg-pale-100"></span>
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    </div>

    <!-- 2. Booking & Freelance Terms -->
    <section id="booking" class="terms-section mb-10">
      <h2 class="terms-heading">Booking & freelance terms</h2>
      <p class="terms-sub mb-6">How we work together</p>

      <div class="terms-body flex flex-col gap-gap">
        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Availability</h3>
          <p class="text-gray-600 leading-relaxed">
            I'm currently studying and take on freelance projects on a case-by-case basis, depending on scope and availability. Please reach out early
            to discuss timing.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Getting in touch</h3>
          <p class="text-gray-600 leading-relaxed">
            Send an enquiry via the <a href="/contact" class="focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
              >contact form</a
            > or directly to <a
              class="focus:outline-none focus:ring-2 focus:ring-blue-300 transition duration-300 ease-in-out"
              href="mailto:sara.ringkow@gmail.com">sara.ringkow@gmail.com</a
            >. I aim to respond within 2-3 business days.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Proposals and agreements</h3>
          <p class="text-gray-600 leading-relaxed">
            A written quote or scope agreement is provided before any work begins. No work starts without mutual written confirmation of scope,
            timeline, and price.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Payment</h3>
          <p class="text-gray-600 leading-relaxed">
            Onboarding-sessions are at <strong><em>100 DKK (approx. 13,38€)</em></strong> for 30 minutes. For projects, the cost will be agreed on, depending
            on scope. For larger engagements, a deposit of up to 50% may be required before work commences. If the project expands by more than 10% mid-way
            through, I reserve the right to pause work and invoice for an additional deposit. The final payment is due within <strong
              ><em>7 days</em></strong
            > of delivery of the agreed deliverables, and invoicing is handled via email.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Revisions</h3>
          <p class="text-gray-600 leading-relaxed">
            Two rounds of revisions are included in every project unless otherwise agreed in writing. Additional revision rounds may incur extra cost.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Intellectual property</h3>
          <p class="text-gray-600 leading-relaxed">
            Upon receipt of full and final payment, you receive a licence to use the agreed deliverables for the agreed purpose. I retain the right to
            display the work in my portfolio and case studies unless confidentiality is explicitly agreed in writing.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Scope changes</h3>
          <p class="text-gray-600 leading-relaxed">
            Any changes to the agreed scope must be approved in writing and may affect delivery timeline and price. I will provide an updated estimate
            before proceeding.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Cancellation</h3>
          <p class="text-gray-600 leading-relaxed">
            Either party may cancel the project at any time with written notice. In the event of client cancellation, the upfront deposit is
            non-refundable, and any additional work completed up to the point of cancellation will be invoiced at the agreed rate.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="flex items-center gap-3 text-gray-300 mb-8" aria-hidden="true">
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
      <span class="block h-2 w-2 rotate-45 border border-current/70 bg-pale-100"></span>
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    </div>

    <!-- 3. Terms of Use -->
    <section id="use" class="terms-section mb-10">
      <h2 class="terms-heading">Terms of use</h2>
      <p class="terms-sub mb-6">Using this portfolio</p>

      <div class="terms-body flex flex-col gap-gap">
        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Content ownership</h3>
          <p class="text-gray-600 leading-relaxed">
            All content on this portfolio&mdash; including text, images, design, and code &mdash;is the property of Sara Ringkow Petersen <em>(me)</em
            > unless otherwise stated. You may not reproduce, republish, or redistribute any content without prior written permission.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Case studies & project work</h3>
          <p class="text-gray-600 leading-relaxed">
            Work shown in case studies was produced as part of academic projects, internships, or freelance engagements. Where work was produced
            collaboratively, I have credited my contributions accurately.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">External links</h3>
          <p class="text-gray-600 leading-relaxed">
            This site links to external platforms <em>(GitHub, LinkedIn, project demos, etc.)</em>. These links are provided for reference only. I'm
            not responsible for the content or availability of external sites.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">No warranty</h3>
          <p class="text-gray-600 leading-relaxed">
            This portfolio is provided as-is. I make no guarantee of continuous availability or accuracy of all content at all times.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Applicable law</h3>
          <p class="text-gray-600 leading-relaxed">
            These terms are governed by Danish law. Any disputes are subject to the jurisdiction of the Danish courts.
          </p>
        </div>

        <div>
          <h3 class="text-h4-mobile font-bold text-gray-700">Contact</h3>
          <p class="text-gray-600 leading-relaxed">
            Questions about these terms? Reach me at <a href="mailto:sara.ringkow@gmail.com">sara.ringkow@gmail.com</a>.
          </p>
        </div>
      </div>
    </section>

    <!-- Back link -->
    <div class="pt-4 pb-8">
      <a
        href="/"
        class="text-sm text-gray-500 hover:text-blue-500 hover:underline transition duration-300 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded"
      >
        ← Back to homepage
      </a>
    </div>
  </section>
</MainLayout>

<style>
  .terms-toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    font-size: 0.85rem;
    color: #6b7280;
  }
  .terms-toc a {
    color: #477b93;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }
  .terms-toc a:focus-visible {
    outline: 2px solid #477b93;
    outline-offset: 2px;
    border-radius: 2px;
  }
  .terms-toc span {
    color: #bfb7b0;
  }

  .terms-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 600;
    font-size: 2.5rem;
    font-style: italic;
    color: #1a1a1a;
  }
  .terms-sub {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #477b93;
    font-weight: 600;
  }

  .terms-body {
    border-left: 3px solid #dcd6d0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .terms-body a {
    color: #477b93;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-size: 1rem;
  }
  .terms-body a:hover {
    color: #334857;
  }
  .terms-body code {
    font-size: 0.8rem;
    background: #f0ebe6;
    padding: 1px 5px;
    border-radius: 4px;
    font-family: monospace;
  }

  /* Dark mode */
  body.dark .terms-heading {
    color: var(--text-on-dark);
  }
  body.dark .terms-body p {
    color: var(--text-on-dark-soft, #c0c0c0);
  }
  body.dark .terms-body h3 {
    color: var(--text-on-dark, #f0f0f0);
  }
  body.dark .terms-body {
    border-color: var(--dark-border, #333);
  }
  body.dark .terms-body code {
    background: var(--dark-surface, #2a2a2a);
    color: var(--text-on-dark-soft);
  }
  body.dark .divider-center {
    background: var(--dark-bg);
  }
</style>
