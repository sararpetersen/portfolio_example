---
import { getCollection, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts: CollectionEntry<"blog">[] = (await getCollection("blog")).filter((entry: CollectionEntry<"blog">) => !entry.data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await post.render();

const tagTranslations: Record<string, string> = {
  internship: "praktik",
  learning: "læring",
  career: "karriere",
  blog: "blog",
  portfolio: "portfolio",
  process: "proces",
};
const tagsEn = post.data.tags;
const tagsDa = post.data.tags.map((t: string) => tagTranslations[t] || t);
---

<MainLayout title={`SRP portfolio | ${post.data.title}`} description={post.data.excerpt} ogtitle={post.data.title} ogdescription={post.data.excerpt}>
  <article class="max-w-4xl mx-auto px-6 md:pt-desktop-top pt-mobil-top md:pb-desktop-bottom pb-mobil-bottom">
    <a
      id="post-back"
      href="/blog"
      class="py-1 md:text-p-desktop text-[15px] text-gray-600 hover:text-blue-400 hover:underline transition duration-300 focus:outline-none focus:ring-2 focus:ring-pale-300"
      aria-label="Back to blog overview"
      data-i18n="blog.back">← Back to blog</a
    >

    <header class="md:pt-28 pt-24 mb-8 md:text-left text-center">
      <p id="post-date" class="text-[11px] uppercase tracking-[0.12em] text-gray-500 mb-3">{post.data.publishDate.toLocaleDateString("en-GB")}</p>
      <h1 id="post-title" class="font-nikumaru uppercase tracking-[0.14em] md:tracking-[0.18em] text-h3-mobile md:text-h3-desktop mb-4 text-gray-800">
        {post.data.title}
      </h1>
      <p id="post-excerpt" class="text-[14px] text-gray-600 leading-relaxed max-w-3xl">{post.data.excerpt}</p>
    </header>

    <div id="post-separator" class="mb-6 flex items-center gap-3 text-gray-300" aria-hidden="true">
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
      <span class="post-separator-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    </div>

    {
      post.data.tags.length > 0 && (
        <div
          id="post-tags"
          class="mb-8 flex flex-wrap gap-2 justify-center md:justify-start"
          data-tags-en={JSON.stringify(tagsEn)}
          data-tags-da={JSON.stringify(tagsDa)}
        >
          {tagsEn.map((tag: string) => (
            <span class="post-tag-chip rounded-full border px-2.5 py-1 text-[10px] uppercase tracking-[0.08em]">{tag}</span>
          ))}
        </div>
      )
    }

    <div id="post-content" class="blog-content prose prose-slate max-w-none">
      <Content />
    </div>

    <div id="post-back-bottom" class="pt-10">
      <a
        href="/blog"
        class="py-1 md:text-p-desktop text-[15px] text-gray-600 hover:text-blue-400 hover:underline transition duration-300 focus:outline-none focus:ring-2 focus:ring-pale-300"
        aria-label="Back to blog overview"
        data-i18n="blog.back">← Back to blog</a
      >
    </div>
  </article>
</MainLayout>

<style>
  .blog-content :global(p) {
    line-height: 1.8;
    color: rgb(75 85 99);
    margin-bottom: 1rem;
  }

  .blog-content :global(h2),
  .blog-content :global(h3) {
    margin-top: 2.75rem;
    margin-bottom: 0.875rem;
    line-height: 1.3;
  }

  .blog-content :global(p) + :global(p) {
    margin-top: 0.25rem;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  body.dark .blog-content :global(p),
  body.dark .blog-content :global(li),
  body.dark .blog-content :global(blockquote),
  body.dark .blog-content :global(strong) {
    color: var(--text-on-dark-soft);
  }

  body.dark .blog-content :global(h1),
  body.dark .blog-content :global(h2),
  body.dark .blog-content :global(h3) {
    color: var(--text-on-dark);
  }

  body.dark #post-back,
  body.dark #post-back-bottom a {
    color: var(--text-on-dark-soft);
  }

  body.dark #post-date,
  body.dark #post-tags .post-tag-chip {
    color: var(--text-on-dark-soft);
  }

  :global(#post-tags .post-tag-chip) {
    border-color: rgb(98 151 174 / 0.38);
    color: rgb(55 85 103);
    background-color: rgb(222 235 239 / 0.72);
  }

  body.dark #post-title,
  body.dark #post-excerpt {
    color: var(--text-on-dark);
  }

  body.dark #post-separator {
    color: var(--dark-border);
  }

  body.dark #post-separator .post-separator-center {
    background-color: var(--dark-surface-strong);
    border-color: var(--dark-border);
  }

  :global(body.dark #post-tags .post-tag-chip) {
    border-color: rgb(98 151 174 / 0.48);
    color: rgb(222 235 239 / 0.95);
    background-color: color-mix(in srgb, #334857 68%, transparent 32%);
  }
</style>

<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    if (document.body.classList.contains("reduce-motion")) return;

    let animationIndex = 0;
    const registerInView = (selector: string) => {
      const el = document.querySelector(selector) as HTMLElement | null;
      if (!el) return;
      inView(el, () => {
        el.classList.add("animate__animated", "animate__fadeInUp");
        el.style.animationDelay = `${animationIndex * 60}ms`;
        el.style.animationDuration = "1.4s";
      });
      animationIndex++;
    };

    ["#post-back", "#post-date", "#post-title", "#post-excerpt", "#post-separator", "#post-tags", "#post-content", "#post-back-bottom"].forEach(
      registerInView,
    );

    const applyTagLang = (lang: string) => {
      const el = document.querySelector("#post-tags") as HTMLElement | null;
      if (!el) return;

      const tagsRaw = lang === "da" ? el.dataset.tagsDa || el.dataset.tagsEn || "[]" : el.dataset.tagsEn || "[]";
      let tags: string[] = [];

      try {
        tags = JSON.parse(tagsRaw);
      } catch {
        tags = [];
      }

      el.innerHTML = "";
      tags.forEach((tag) => {
        const chip = document.createElement("span");
        chip.className = "post-tag-chip rounded-full border px-2.5 py-1 text-[10px] uppercase tracking-[0.08em]";
        chip.textContent = tag;
        el.appendChild(chip);
      });
    };

    const getLang = () => localStorage.getItem("lang") || "en";
    applyTagLang(getLang());

    window.addEventListener("langchange", (e: Event) => {
      const lang = (e as CustomEvent).detail?.lang || getLang();
      applyTagLang(lang);
    });
  });
</script>
