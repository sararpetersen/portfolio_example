---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts: CollectionEntry<"blog">[] = (await getCollection("blog")).filter((entry: CollectionEntry<"blog">) => !entry.data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);

const tagTranslations: Record<string, string> = {
  internship: "praktik",
  learning: "læring",
  career: "karriere",
  blog: "blog",
  portfolio: "portfolio",
  process: "proces",
};
const tagsEn = post.data.tags;
const tagsDa = post.data.tags.map((t: string) => tagTranslations[t] || t);
const articleUrl = new URL(`/blog/${post.id}`, "https://sararingkow.dk/").toString();
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.publishDate.toISOString(),
  mainEntityOfPage: articleUrl,
  author: {
    "@type": "Person",
    name: "Sara Ringkow Petersen",
    url: "https://sararingkow.dk/about_me",
  },
  publisher: {
    "@type": "Person",
    name: "Sara Ringkow Petersen",
    url: "https://sararingkow.dk/",
  },
  keywords: post.data.tags.join(", "),
};
---

<MainLayout
  title={`${post.data.title} | SRP Portfolio`}
  description={post.data.excerpt}
  ogtitle={`${post.data.title} – SRP Portfolio`}
  ogdescription={post.data.excerpt}
  pageType="article"
  schema={articleSchema}
>
  <article class="max-w-4xl mx-auto px-6 md:pt-desktop-top pt-mobil-top md:pb-desktop-bottom pb-mobil-bottom">
    <header class="md:pt-28 pt-24 mb-6">
      <p id="post-date" class="text-[11px] uppercase tracking-[0.12em] text-gray-500 mb-3">{post.data.publishDate.toLocaleDateString("en-GB")}</p>
      <h1
        id="post-title"
        class="font-nikumaru uppercase tracking-[0.08em] sm:tracking-[0.11em] md:tracking-[0.14em] text-[1.65rem] leading-tight sm:text-h3-mobile md:text-h3-desktop mb-3 text-gray-800 break-words"
      >
        {post.data.title}
      </h1>
      <p id="post-excerpt" class="text-[14px] text-gray-600 leading-relaxed max-w-3xl">{post.data.excerpt}</p>
    </header>

    <div id="post-separator" class="mb-6 flex items-center gap-3 text-gray-300" aria-hidden="true">
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
      <span class="post-separator-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
      <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    </div>

    {
      post.data.tags.length > 0 && (
        <div id="post-tags" class="mb-8 flex flex-wrap gap-2" data-tags-en={JSON.stringify(tagsEn)} data-tags-da={JSON.stringify(tagsDa)}>
          {tagsEn.map((tag: string) => (
            <span class="post-tag-chip rounded-full border px-2.5 py-1 text-[12px] uppercase tracking-[0.08em]">{tag}</span>
          ))}
        </div>
      )
    }

    <div id="post-content" class="blog-content max-w-none">
      <Content />
    </div>

    <div id="post-back-bottom" class="pt-10">
      <a
        href="/blog"
        class="py-1 md:text-p-desktop text-[15px] text-gray-500 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
        aria-label="Back to blog overview"
        data-i18n="blog.back">← Back to blog</a
      >
    </div>
  </article>
</MainLayout>

<style>
  .blog-content :global(p) {
    line-height: 1.8;
    color: rgb(75 85 99);
    margin-bottom: 1rem;
  }

  .blog-content :global(h2),
  .blog-content :global(h3) {
    margin-top: 2.75rem;
    margin-bottom: 0.875rem;
    line-height: 1.3;
  }

  .blog-content :global(p) + :global(p) {
    margin-top: 0.25rem;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    list-style-position: outside;
  }

  .blog-content :global(ul) {
    list-style-type: disc;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
  }

  .blog-content :global(li) {
    margin-top: 0.65rem;
  }

  .blog-content :global(ul ul),
  .blog-content :global(ul ol),
  .blog-content :global(ol ul),
  .blog-content :global(ol ol) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding-left: 1.25rem;
  }

  .blog-content :global(ul ul) {
    list-style-type: circle;
  }

  .blog-content :global(ol ol) {
    list-style-type: lower-alpha;
  }

  body.dark .blog-content :global(p),
  body.dark .blog-content :global(li),
  body.dark .blog-content :global(blockquote),
  body.dark .blog-content :global(strong) {
    color: var(--text-on-dark-soft);
  }

  .blog-content :global(a) {
    color: var(--brand-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .blog-content :global(a:hover) {
    color: var(--brand-primary-strong);
  }

  .blog-content :global(blockquote) {
    padding-left: 1rem;
    border-left: 4px solid var(--color-blue-200);
    color: var(--color-gray-700);
    font-style: italic;
    margin: 1.75rem 0;
  }

  .blog-content :global(code) {
    background-color: rgba(148, 163, 184, 0.12);
    color: var(--color-gray-800);
    padding: 0.08rem 0.18rem;
    border-radius: 0.25rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.9em;
    line-height: inherit;
  }

  .blog-content :global(h1 code),
  .blog-content :global(h2 code),
  .blog-content :global(h3 code),
  .blog-content :global(h4 code),
  .blog-content :global(h5 code),
  .blog-content :global(h6 code) {
    font-size: 0.75em;
    padding: 0.04rem 0.12rem;
    border-radius: 0.2rem;
    vertical-align: middle;
  }

  .blog-content :global(pre) {
    background-color: rgba(15, 23, 42, 0.98);
    color: #f8fafc;
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
  }

  .blog-content :global(th),
  .blog-content :global(td) {
    border: 1px solid rgba(148, 163, 184, 0.25);
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .blog-content :global(th) {
    font-weight: 600;
    background-color: rgba(226, 232, 240, 0.7);
  }

  .blog-content :global(strong) {
    font-weight: 700;
  }

  .blog-content :global(em) {
    font-style: italic;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(148, 163, 184, 0.35);
    margin: 2rem 0;
  }

  body.dark .blog-content :global(a) {
    color: var(--brand-primary-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  body.dark .blog-content :global(a:hover) {
    color: #f0f8ff;
  }

  body.dark .blog-content :global(h1),
  body.dark .blog-content :global(h2),
  body.dark .blog-content :global(h3),
  body.dark .blog-content :global(h4),
  body.dark .blog-content :global(h5),
  body.dark .blog-content :global(h6) {
    color: var(--text-on-dark);
  }

  body.dark #post-back,
  body.dark #post-back-bottom a {
    color: #acb0b5;
  }

  body.dark #post-back-bottom a:hover {
    color: var(--brand-primary-soft);
    text-decoration: underline;
  }

  body.dark #post-date,
  body.dark #post-tags .post-tag-chip {
    color: var(--text-on-dark-soft);
  }

  :global(#post-tags .post-tag-chip) {
    border-color: rgb(98 151 174 / 0.38);
    color: rgb(55 85 103);
    background-color: rgb(222 235 239 / 0.72);
  }

  body.dark #post-title,
  body.dark #post-excerpt {
    color: var(--text-on-dark);
  }

  body.dark #post-separator {
    color: var(--dark-border);
  }

  body.dark #post-separator .post-separator-center {
    background-color: var(--dark-surface-strong);
    border-color: var(--dark-border);
  }

  :global(body.dark #post-tags .post-tag-chip) {
    border-color: rgb(98 151 174 / 0.48);
    color: rgb(222 235 239 / 0.95);
    background-color: color-mix(in srgb, #334857 68%, transparent 32%);
  }
</style>

<script>
  import { inView, onReady } from "../../scripts/inViewAhead";

  onReady(() => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      document.body.classList.add("reduce-motion");
      return;
    }

    let animationIndex = 0;
    const registerInView = (selector: string) => {
      const el = document.querySelector(selector) as HTMLElement | null;
      if (!el) return;
      inView(el, () => {
        el.style.animationDelay = `${animationIndex * 60}ms`;
        el.style.animationDuration = "1.4s";
        el.style.animationFillMode = "both";
        el.classList.add("animate__animated", "animate__fadeInUp");
      });
      animationIndex++;
    };

    ["#post-back", "#post-date", "#post-title", "#post-excerpt", "#post-separator", "#post-tags", "#post-content", "#post-back-bottom"].forEach(
      registerInView,
    );

    const applyTagLang = (lang: string) => {
      const el = document.querySelector("#post-tags") as HTMLElement | null;
      if (!el) return;

      const tagsRaw = lang === "da" ? el.dataset.tagsDa || el.dataset.tagsEn || "[]" : el.dataset.tagsEn || "[]";
      let tags: string[] = [];

      try {
        tags = JSON.parse(tagsRaw);
      } catch {
        tags = [];
      }

      el.innerHTML = "";
      tags.forEach((tag) => {
        const chip = document.createElement("span");
        chip.className = "post-tag-chip rounded-full border px-2.5 py-1 text-[12px] uppercase tracking-[0.08em]";
        chip.textContent = tag;
        el.appendChild(chip);
      });
    };

    const getLang = () => localStorage.getItem("lang") || "en";
    applyTagLang(getLang());

    window.addEventListener("langchange", (e: Event) => {
      const lang = (e as CustomEvent).detail?.lang || getLang();
      applyTagLang(lang);
    });
  });
</script>

<style>
  html.has-js body:not(.reduce-motion) #post-back,
  html.has-js body:not(.reduce-motion) #post-date,
  html.has-js body:not(.reduce-motion) #post-title,
  html.has-js body:not(.reduce-motion) #post-excerpt,
  html.has-js body:not(.reduce-motion) #post-separator,
  html.has-js body:not(.reduce-motion) #post-tags,
  html.has-js body:not(.reduce-motion) #post-content,
  html.has-js body:not(.reduce-motion) #post-back-bottom {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    will-change: transform, opacity;
  }
</style>
