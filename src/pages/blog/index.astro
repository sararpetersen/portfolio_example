---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const posts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((entry: CollectionEntry<"blog">) => !entry.data.draft)
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<MainLayout
  title="Accessible Web Design & UX Blog | Sara Ringkow Petersen"
  description="Practical articles about accessible web design, inclusive UX/UI, neurodivergent users and implementing design decisions in code."
  ogtitle="Accessible Web Design & UX Blog"
  ogdescription="Practical notes on accessibility, inclusive UX/UI and implementing design decisions in code."
>
  <section class="max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top md:pb-desktop-bottom pb-mobil-bottom">
    <div id="blog-title-row" class="md:pt-28 pt-24 mb-3">
      <h1 class="uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru text-[1.85rem] md:text-h2-desktop" data-i18n="blog.title">
        Blog posts
      </h1>
    </div>

    <p id="blog-intro" class="text-gray-600 mb-3 text-[0.95rem] md:text-base leading-relaxed max-w-3xl text-left" data-i18n="blog.intro">
      Practical articles about accessible web design, inclusive UX/UI and implementing design decisions in code, including lessons from designing for
      neurodivergent users.
    </p>
    <div id="blog-lang-note" class="mb-8 text-[11px] tracking-[0.04em] text-gray-500">
      <span data-i18n="blog.lang.note1">→ All posts are written in English, a select few in Danish ←</span>
    </div>

    {
      posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <article class="blog-card rounded-2xl border-l-4 border border-gray-500 p-5 bg-gradient-to-br from-gray-50 to-gray-100">
              <p class="text-[11px] uppercase tracking-[0.12em] text-gray-500 mb-3">{post.data.publishDate.toLocaleDateString("en-GB")}</p>
              <h2 class="text-lg font-semibold leading-snug mb-2">{post.data.title}</h2>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">{post.data.excerpt}</p>
              <a
                href={`/blog/${post.id}`}
                aria-label={`Read post: ${post.data.title}`}
                class="py-1 md:text-p-desktop text-[15px] text-gray-500 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
                data-i18n="blog.read"
              >
                Read post →
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="rounded-2xl border border-gray-400 bg-gray-50 p-6 text-gray-700" data-i18n="blog.empty">
          No blog posts are published yet.
        </p>
      )
    }
  </section>
</MainLayout>

<style>
  body.dark #blog-label {
    color: var(--text-on-dark-soft);
  }

  body.dark #blog-lang-note {
    color: var(--text-on-dark-soft);
  }

  body.dark #blog-lang-note .blog-lang-dot {
    background-color: var(--text-on-dark-soft);
    opacity: 0.7;
  }

  body.dark #blog-title-row h1 {
    color: var(--text-on-dark);
  }

  body.dark #blog-intro {
    color: var(--text-on-dark-soft);
  }

  body.dark .blog-card {
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    border-color: var(--dark-border);
  }

  body.dark .blog-card h2,
  body.dark .blog-card p,
  body.dark .blog-card a {
    color: var(--text-on-dark-soft);
  }

  body.dark .blog-card a:hover {
    color: var(--brand-primary-soft);
  }
</style>

<script>
  import { inView, onReady } from "../../scripts/inViewAhead";

  onReady(() => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      document.body.classList.add("reduce-motion");
      return;
    }

    let animationIndex = 0;
    const registerInView = (selector: string) => {
      const el = document.querySelector(selector) as HTMLElement | null;
      if (!el) return;
      inView(el, () => {
        el.style.animationDelay = `${animationIndex * 60}ms`;
        el.style.animationDuration = "1.4s";
        el.style.animationFillMode = "both";
        el.classList.add("animate__animated", "animate__fadeInUp");
      });
      animationIndex++;
    };

    ["#blog-title-row", "#blog-intro", "#blog-lang-note"].forEach(registerInView);

    document.querySelectorAll(".blog-card").forEach((card, index) => {
      inView(card, () => {
        (card as HTMLElement).style.animationDelay = `${index * 80}ms`;
        (card as HTMLElement).style.animationDuration = "1.3s";
        (card as HTMLElement).style.animationFillMode = "both";
        card.classList.add("animate__animated", "animate__fadeInUp");
      });
    });
  });
</script>

<style>
  html.has-js body:not(.reduce-motion) #blog-title-row,
  html.has-js body:not(.reduce-motion) #blog-intro,
  html.has-js body:not(.reduce-motion) #blog-lang-note,
  html.has-js body:not(.reduce-motion) .blog-card {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    will-change: transform, opacity;
  }
</style>
