---
const fetchCards = async () => {
  const response = await fetch("https://bbmabdbbjpfqoapbtstm.supabase.co/rest/v1/portfolio_cases?order=id.asc", {
    method: "GET",
    headers: {
      apikey:
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJibWFiZGJianBmcW9hcGJ0c3RtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI0NjkwNDYsImV4cCI6MjA1ODA0NTA0Nn0.gFnw6GZiMFOCMwy6rAcQFzoK0_qUJCwKNpl-XGzy574",
    },
  });
  return response.ok ? await response.json() : [];
};

const cards = await fetchCards();

function breakTitle(title, maxLength = 25) {
  if (title.length > maxLength) {
    const words = title.split(" ");
    let line = "";
    let lines = [];

    words.forEach((word) => {
      if ((line + " " + word).length <= maxLength) {
        line += " " + word;
      } else {
        lines.push(line.trim());
        line = word;
      }
    });

    lines.push(line.trim());
    return lines;
  }
  return [title];
}

import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
import Cases from "../components/Cases.astro";
---

<MainLayout
  title="SRP portfolio | Homepage"
  description="The frontpage of the portfolio"
  ogtitle="SRP portfolio - the portfolio of Sara Ringkow Petersen"
  ogdescription="A page for projects, information and other things about Sara"
>
  <!-- Hero Section -->
  <section id="hero" class="hero-section relative w-full md:px-16 px-4 overflow-hidden">
    <div class="relative z-20 mx-auto md:px-0 px-2">
      <div id="hero-content" class="grid grid-cols-12 items-center min-h-screen pt-[11rem] md:pb-20 pb-8 gap-y-12">
        <div class="col-span-12 lg:col-span-7 hero-panel">
          <div id="status" class="hero-status md:mb-8 mb-6 flex items-center gap-3 justify-start text-sm">
            <span class="relative flex md:h-3.5 md:w-3.5 h-2.5 w-2.5" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
              <span class="relative inline-flex md:h-3.5 md:w-3.5 h-2.5 w-2.5 rounded-full bg-green-400"></span>
            </span>

            <p class="text-gray-50" aria-label="Indicates that I'm currently open for internship opportunities">
              <strong class="font-semibold">Status:</strong>
              <span class="text-[16px]" data-i18n="hero.status">Open for internship</span>
            </p>
          </div>

          <h1 class="hero-title display pb-6">Sara Ringkow Petersen</h1>
          <h2 class="hero-role text-gray-700 pb-6" data-i18n="hero.role">Multimedia Designer & Concept Developer</h2>
          <p class="hero-lead text-gray-600 font-light pb-8 max-w-3xl" data-i18n="hero.lead">
            Passionate about creating accessible, user-centered digital experiences that blend design, development, and strategy.
          </p>

          <div id="hero-cta" class="btn-container flex flex-wrap items-center gap-4">
            <a href="#project-section" aria-label="Go to projects section" class="md:hidden block">
              <Button variant="primary" size="medium"><span data-i18n="hero.cta">See projects</span></Button>
            </a>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5">
          <div id="hero-image" class="hero-image-wrap relative shadow-drop25">
            <div class="hero-image-accent md:block hidden" aria-hidden="true"></div>
            <img src="/images/hero_image.webp" alt="Hero image for Sara's portfolio" class="hero-image object-cover" />
          </div>
        </div>
      </div>
    </div>

    <div id="scroll-down" class="hidden md:flex absolute inset-x-0 -bottom-2 w-full justify-center z-[20]">
      <a href="#project-section" aria-label="Go further down the page" class="focus:outline-none focus:ring-2 focus:ring-pale-400 scroll-link">
        <div class="float flex flex-col items-center transition duration-300 ease-in-out">
          <p class="uppercase tracking-[0.22em] text-xs text-gray-500" data-i18n="hero.scroll">Scroll to projects</p>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 sm:w-10 sm:h-10 transition duration-300 ease-in-out scroll-icon"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
          </svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="project-section" class="grid grid-cols-12 max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <div class="container col-span-12">
      <!-- eyebrow label -->
      <p id="project-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="projects.label">
        Selected work
      </p>

      <!-- title -->
      <h3 id="project-title" class="col-span-12 uppercase tracking-[0.14em] md:tracking-[0.18em] font-hiro md:mb-7 mb-5" data-i18n="projects.title">
        Projects
      </h3>

      <!-- description -->
      <p id="project-text" class="col-span-12 text-gray-600 mb-12 leading-relaxed" data-i18n="projects.text">
        Below are some of the projects I've worked on during my studies and internships.
        <br class="hidden md:block" />
        Click on any of the cards to read more about the project, the process and the outcome.
      </p>
    </div>
    <div class="col-span-12">
      <Cases projects={cards.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())} />
    </div>
  </section>

  <!-- Intro Section: -->
  <section id="about-preview" class="max-w-7xl mx-auto relative px-6 md:pt-desktop-top pt-mobil-top">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Image -->
      <div class="flex md:justify-end justify-center md:order-1 order-2">
        <img src="/images/pfp3.webp" alt="Picture of Sara" class="border-r-4 border border-gray-500 rounded-2xl object-cover w-[550px] h-[350px]" />
      </div>

      <!-- Text -->
      <div id="about-preview-text">
        <p
          id="about-preview-label"
          class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4"
          data-i18n="about.preview.label"
        >
          Profile
        </p>

        <h3 class="uppercase tracking-[0.14em] md:tracking-[0.18em] md:mb-7 mb-5 font-hiro" data-i18n="about.preview.title">About me</h3>

        <p
          id="about-preview-text-paragraph"
          class="mb-6 text-gray-600 max-w-xl leading-relaxed md:mx-0 p-7 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 shadow-sm"
          data-i18n="about.preview.text"
        >
          I'm a Multimedia Designer and Concept Developer with a strong focus on accessibility and user-centred design. I enjoy creating digital
          experiences that combine visual clarity, thoughtful structure, and functionality. My work spans UX/UI design, concept development, and
          coding, enabling me to take ideas from early concept to finished product. I'm especially motivated by designing solutions that are
          intuitive, inclusive, and meaningful for the people who use them.
        </p>

        <div class="btn_container">
          <a aria-label="Learn more about me" id="about-preview-link" href="/about_me" class="mt-4">
            <Button variant="secondary" size="small"><span data-i18n="about.preview.cta">Learn more about me</span></Button>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="grid grid-cols-12 max-w-7xl mx-auto md:pb-desktop-bottom pb-mobil-bottom px-6 md:pt-desktop-top pt-mobil-top">
    <div class="container max-w-7xl mx-auto col-span-12 grid md:grid-cols-2 md:gap-10 gap-4 items-center justify-center md:px-0 px-6">
      <!-- Left: Heading + small context -->
      <div id="testimonial-heading">
        <p class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="testimonials.label">Recommendation</p>

        <h3 class="uppercase tracking-[0.14em] md:tracking-[0.18em] md:mb-7 mb-5 font-hiro" data-i18n="testimonials.title">Featured testimonial</h3>

        <p id="testimonial-context" class="text-gray-600 max-w-xl md:mx-0 md:mb-0 mb-2" data-i18n="testimonials.context">
          A short quote from someone I've worked with.
        </p>
      </div>

      <!-- Right: Testimonial card -->
      <figure id="testimonial-card" class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 p-8 shadow-sm">
        <blockquote class="text-gray-600 italic" data-i18n="testimonials.quote">
          <p>
            "Sara has shown consistent presence, where she has been fully involved in the daily operations of the agency. <em class="font-bold"
              >[...]</em
            > Both in team configurations and independently, Sara has demonstrated great responsibility and a strong desire to find solutions that meet
            the client's needs&mdash; this has been the case in both her work with design and coding."
          </p>
        </blockquote>

        <figcaption class="mt-6 flex items-center gap-4">
          <div>
            <p class="font-semibold">Jacob Klintrup</p>
            <p class="text-gray-600 text-sm tracking-[0.08em] uppercase">Creative Strategic Director, Kadaver ApS</p>
          </div>
        </figcaption>
      </figure>
    </div>
  </section>

  <script>
    import { inView } from "motion";

    document.addEventListener("DOMContentLoaded", () => {
      const reduceMotion = document.body.classList.contains("reduce-motion");

      if (!reduceMotion) {
        const elementmedanimation1 = document.querySelector("#hero-content h1");
        inView(elementmedanimation1, () => {
          elementmedanimation1.classList.add("animate__animated", "animate__backInLeft");
        });

        const elementmedanimation6 = document.querySelector("#testimonial-heading h3");
        inView(elementmedanimation6, () => {
          elementmedanimation6.classList.add("animate__animated", "animate__backInLeft");
        });

        const elementmedanimation6a = document.querySelector("#testimonial-heading p");
        inView(elementmedanimation6a, () => {
          elementmedanimation6a.classList.add("animate__animated", "animate__fadeInUp");
        });

        const elementmedanimation6b = document.querySelector("#testimonial-context");
        inView(elementmedanimation6b, () => {
          elementmedanimation6b.classList.add("animate__animated", "animate__fadeInRight");
        });

        const elementmedanimation7 = document.querySelector("#testimonial-card");
        inView(elementmedanimation7, () => {
          elementmedanimation7.classList.add("animate__animated", "animate__fadeInDown");
        });

        const elementmedanimation12 = document.querySelector("#scroll-down");
        inView(elementmedanimation12, () => {
          elementmedanimation12.classList.add("animate__animated", "animate__fadeInDown");
        });

        const elementmedanimation13 = document.querySelector("#project-title");
        inView(elementmedanimation13, () => {
          elementmedanimation13.classList.add("animate__animated", "animate__backInLeft");
        });

        const elementmedanimation14 = document.querySelector("#project-text");
        inView(elementmedanimation14, () => {
          elementmedanimation14.classList.add("animate__animated", "animate__fadeInRight");
        });

        const elementmedanimation14a = document.querySelector("#project-label");
        inView(elementmedanimation14a, () => {
          elementmedanimation14a.classList.add("animate__animated", "animate__fadeInUp");
        });

        const elementmedanimation15 = document.querySelector("#hero-image");
        inView(elementmedanimation15, () => {
          elementmedanimation15.classList.add("animate__animated", "animate__bounceInRight");
        });

        const elementmedanimation27 = document.querySelector("#hero-content h2");
        inView(elementmedanimation27, () => {
          elementmedanimation27.classList.add("animate__animated", "animate__fadeInDown");
        });

        const elementmedanimation28 = document.querySelector("#hero-content .hero-lead");
        inView(elementmedanimation28, () => {
          elementmedanimation28.classList.add("animate__animated", "animate__fadeInUp");
        });

        const elementmedanimation28a = document.querySelector("#hero-cta");
        inView(elementmedanimation28a, () => {
          elementmedanimation28a.classList.add("animate__animated", "animate__bounceInDown");
        });

        const elementmedanimation29 = document.querySelector("#status");
        inView(elementmedanimation29, () => {
          elementmedanimation29.classList.add("animate__animated", "animate__fadeInDown");
        });

        const elementmedanimation30 = document.querySelector("#about-preview-text h3");
        inView(elementmedanimation30, () => {
          elementmedanimation30.classList.add("animate__animated", "animate__backInLeft");
        });

        const elementmedanimation31 = document.querySelector("#about-preview-label");
        inView(elementmedanimation31, () => {
          elementmedanimation31.classList.add("animate__animated", "animate__fadeInUp");
        });

        const elementmedanimation31a = document.querySelector("#about-preview-text-paragraph");
        inView(elementmedanimation31a, () => {
          elementmedanimation31a.classList.add("animate__animated", "animate__fadeInRight");
        });

        const elementmedanimation32 = document.querySelector(".btn_container");
        inView(elementmedanimation32, () => {
          elementmedanimation32.classList.add("animate__animated", "animate__fadeInDown");
        });

        const elementmedanimation33 = document.querySelector("#about-preview img");
        inView(elementmedanimation33, () => {
          elementmedanimation33.classList.add("animate__animated", "animate__fadeInUp");
        });

        const intro1 = document.querySelectorAll("#intro-grid > div");

        intro1.forEach((intro1, index) => {
          inView(intro1, () => {
            (intro1 as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");
            (intro1 as HTMLElement).style.animationDelay = `${index * 0.2}s`; // Delay each image by 0.2s
          });
        });

        document.querySelectorAll("#").forEach((divider) => {
          inView(divider, () => {
            divider.classList.add("animate__animated", "animate__bounceInDown");
            divider.addEventListener(
              "animationend",
              () => {
                divider.classList.remove("animate__animated", "animate__bounceInDown");
              },
              { once: true },
            );
          });
        });
      }
    });
  </script>

  <style>
    /* Animations */
    @keyframes float {
      0% {
        transform: translatey(0);
      }
      50% {
        transform: translatey(-10px);
      }
      100% {
        transform: translatey(0);
      }
    }

    .float {
      animation: float 3s ease-in-out infinite;
    }

    @keyframes ping {
      75%,
      100% {
        transform: scale(2);
        opacity: 0;
      }
    }

    .animate-ping {
      animation: ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
    }

    /* Hero-section */

    .hero-status {
      width: fit-content;
      padding: 0.5rem 0.85rem;
      border-radius: 9999px;
      border: 1px solid #686868;
      background: linear-gradient(90deg, #4f6a5a, #7f9b8a);
    }

    .hero-role {
      font-size: clamp(1.4rem, 2.2vw, 2.25rem);
      line-height: 1.25;
      font-style: italic;
    }

    .hero-lead {
      font-size: clamp(1rem, 1.25vw, 1.35rem);
      line-height: 1.8;
    }

    .hero-image-wrap {
      border: 1px solid rgb(244 248 250 / 28%);
      border-radius: 1.75rem;
      background: linear-gradient(165deg, rgb(244 248 250 / 6%), rgb(244 248 250 / 0%));
      padding: 0.8rem;
    }

    .hero-image {
      width: 100%;
      aspect-ratio: 4 / 5;
      border-radius: 1.15rem;
      object-position: center 28%;
      border: 1px solid rgb(244 248 250 / 16%);
    }

    .hero-image-accent {
      position: absolute;
      z-index: -1;
      width: 70%;
      height: 40%;
      right: -16px;
      bottom: -18px;
      border-radius: 1.2rem;
      background: linear-gradient(145deg, rgb(71 123 147 / 30%), rgb(71 123 147 / 1%));
      border: 1px solid rgb(98 151 174 / 32%);
      filter: blur(0.2px);
    }

    @media (min-width: 768px) {
      .hero-image-wrap {
        margin-left: 0.8rem;
      }
    }

    @media (max-width: 767px) {
      .hero-image-wrap {
        margin: 0 auto;
      }

      .hero-image {
        aspect-ratio: 5 / 4;
      }

      .hero-image-accent {
        right: -10px;
        bottom: -10px;
      }
    }

    /* Dark-mode */
    body.dark .hero-title,
    body.dark .hero-role,
    body.dark .hero-lead,
    body.dark #portfolio-intro h3,
    body.dark #portfolio-intro p,
    body.dark #testimonials h3,
    body.dark #testimonials p,
    body.dark #testimonials blockquote,
    body.dark #testimonials blockquote em,
    body.dark #how-i-work p,
    body.dark #how-i-work h4,
    body.dark #project-section h3,
    body.dark #project-section p,
    body.dark #about-preview-text h3,
    body.dark #about-preview-text-paragraph,
    body.dark #about-preview-label {
      color: var(--text-on-dark-soft);
    }

    body.dark #testimonials hr,
    body.dark #how-i-work hr,
    body.dark #more-about-me hr {
      border-color: var(--dark-border);
    }

    body.dark #process-cards div,
    body.dark #testimonials-cards blockquote,
    body.dark #intro-grid > div,
    body.dark #about-preview-text-paragraph,
    body.dark #testimonial-card {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    body.dark #about-preview img {
      border-color: var(--dark-border);
    }

    /* Miscellaneous */
    #hero-subtitle-text,
    #hero-text-content {
      display: inline-block;
    }

    body.dark .hero-status {
      background: rgba(59, 59, 59, 0.82);
    }

    body.dark .hero-image-wrap {
      border-color: rgba(114, 114, 114, 0.7);
      background: rgb(11 11 11 / 74%);
    }

    .scroll-link:hover .scroll-icon {
      color: var(--brand-primary);
      transform: scale(1.1);
    }

    #scroll-down {
      color: var(--dark-bg);
    }

    body.dark #scroll-down .scroll-icon,
    body.dark #scroll-down p {
      color: var(--text-on-dark);
    }

    body.dark #process-cards div svg {
      color: var(--text-on-dark);
      background: transparent;
    }
  </style>
</MainLayout>
