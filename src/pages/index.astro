  .animate-ping {
    animation: ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  #scroll-down .scroll-link > div {
    animation: scrollFloat 2.4s ease-in-out infinite;
  }

  .animate__animated {
