---
import { ARCHIVED_CASE_SLUGS, fetchPortfolioCases } from "../data/portfolioCases";

const cards = await fetchPortfolioCases();

const getEducationOrder = (year = "") => {
  const education = year.toLowerCase();

  if (education.includes("multimedia design")) return 0;
  if (education.includes("digital concept development")) return 1;
  return 2;
};

// Cases hidden from the frontpage grid. Their pages still build and stay reachable by
// direct URL and the sitemap; vibeloop also stays linked from its card on The Lab.
// singleusesucks and vinens_essens currently have no other page linking to them —
// worth reconsidering now that The Archive (which used to hold them) has been removed.
const sortedCards = cards
  .filter((card) => !ARCHIVED_CASE_SLUGS.has(card.slug))
  .sort((a, b) => {
    const educationDifference = getEducationOrder(a.year) - getEducationOrder(b.year);
    if (educationDifference !== 0) return educationDifference;

    // IDs are chronological in portfolio_cases; the table has no created_at column.
    return Number(b.id) - Number(a.id);
  })
  .slice(0, 6);

import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
import Cases from "../components/Cases.astro";
---

<MainLayout
  title="UX/UI Designer Focused on Accessibility | SRP Portfolio"
  description="Explore the portfolio of Sara Ringkow Petersen, a concept developer, multimedia- and UX/UI designer focused on accessibility, inclusive design, and creating websites that are intuitive, usable, and welcoming for everyone."
  ogtitle="A Concept Developer & Designer Focused on Accessibility – SRP Portfolio"
  ogdescription="Explore accessible websites, inclusive interfaces and user-centred digital concepts designed and built in Denmark."
>
  <!-- Hero Section -->
  <section id="hero" class="hero-section relative w-full md:px-16 px-4 overflow-hidden">
    <div class="relative z-20 mx-auto md:px-0 px-2">
      <div id="hero-content" class="grid grid-cols-12 items-center min-h-screen pt-[11rem] md:pb-20 pb-8 gap-y-12">
        <div class="col-span-12 lg:col-span-7 hero-panel">
          <div id="status" class="hero-status mb-8 flex items-center gap-3 justify-start text-sm">
            <span class="relative flex md:h-3.5 md:w-3.5 h-2.5 w-2.5" aria-hidden="true">
              <span class="status-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
              <span class="status-dot relative inline-flex md:h-3.5 md:w-3.5 h-2.5 w-2.5 rounded-full bg-green-400 border border-[#1fb355]"></span>
            </span>

            <p data-i18n="hero.status">Interning at Folkæt</p>
          </div>

          <h1 class="hero-title display text-gray-800 pb-5 md:pb-6 max-w-2xl" data-i18n="hero.title">UX/UI designer focused on accessibility</h1>
          <p class="hero-role text-gray-700 pb-5 md:pb-6 font-garamond max-w-2xl" data-i18n="hero.role">
            Sara Ringkow Petersen · Multimedia Designer & Concept Developer
          </p>
          <p class="hero-lead text-gray-500 font-light pb-8 max-w-xl" data-i18n="hero.lead">
            I turn complex ideas into clear, inclusive websites and interfaces by combining thoughtful structure, visual design, and hands-on
            implementation.
          </p>

          <div id="hero-cta" class="btn-container flex flex-wrap items-center gap-4">
            <span class="md:hidden block">
              <Button href="#project-section" variant="primary" size="medium" aria-label="Go to projects section"
                ><span data-i18n="hero.cta">See projects</span></Button
              >
            </span>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5">
          <div id="hero-image" class="hero-image-wrap relative shadow-drop25">
            <div class="hero-image-accent md:block hidden" aria-hidden="true"></div>
            <img
              src="/images/hero_image.webp"
              alt="Sara Ringkow Petersen"
              class="hero-image object-cover"
              width="600"
              height="800"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="project-section" class="grid grid-cols-12 max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <div class="container col-span-12">
      <!-- kanji + title -->
      <div class="flex items-center mb-3">
        <h2 id="project-title" class="font-garamond font-semibold italic text-h3-mobile md:text-h3-desktop text-gray-800" data-i18n="projects.title">
          Selected cases
        </h2>
      </div>
    </div>

    <!-- description -->
    <p id="project-text" class="col-span-12 text-gray-600 mb-6 leading-relaxed" data-i18n="projects.text">
      Below is a selection of projects that I've worked on during my studies and internships. Click on any of the cards to read more about the
      project, the process and the outcome.
    </p>
    <div class="col-span-12">
      {
        sortedCards.length > 0 ? (
          <Cases projects={sortedCards} />
        ) : (
          <p class="rounded-2xl border border-gray-400 bg-gray-50 p-6 text-gray-700" data-i18n="projects.empty">
            Projects are temporarily unavailable. Please check back in a moment.
          </p>
        )
      }
    </div>
  </section>

  <!-- Divider -->
  <div id="divider-1" class="max-w-7xl mx-auto px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- What makes my approach different? -->
  <section id="differentiator" class="max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <div class="mb-8">
      <h2 id="diff-title" class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-3" data-i18n="diff.title">
        What makes my approach different?
      </h2>
      <p id="diff-intro" class="text-gray-600 leading-relaxed max-w-2xl text-sm md:text-base" data-i18n="diff.intro">
        A lot of designers mention accessibility. Here's what actually shapes how I work.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 grid-cols-1 gap-5">
      <!-- Card 1 -->
      <article id="diff-card-1" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card1.label">Lived experience</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card1.title">
          I design from the inside
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card1.text">
          I'm autistic and have ADD. That's <strong>not a footnote</strong>&mdash; it's the reason accessibility is central to how I work, not just
          something I layer on at the end. I know what it's like to use digital products that weren't built with you in mind, and that shapes every
          decision I make.
        </p>
      </article>

      <!-- Card 2 -->
      <article id="diff-card-2" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card2.label">Design + code</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card2.title">
          What I design, I can build
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card2.text">
          I don't just hand off specs and hope for the best. I design and develop, with <strong>no gap between the idea and the implementation</strong
          >. That means fewer compromises, faster iteration, and solutions that are actually accessible in the final product, not just on paper.
        </p>
      </article>

      <!-- Card 3 -->
      <article id="diff-card-3" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card3.label">Proof, not promises</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card3.title">
          The portfolio you're looking at is the work
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card3.text">
          This site has dark mode, focus mode, 4 different reading fonts, keyboard navigation, and bilingual support; all built by me. That, to me, is
          proof that I know <strong>how important accessibility is in web design</strong>. That it's not just something I claim to know.
        </p>
      </article>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="max-w-7xl mx-auto md:pb-desktop-bottom pb-mobil-bottom px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="testimonial-title"
      class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-6"
      data-i18n="testimonials.title"
    >
      Featured testimonial
    </h2>
    <figure id="testimonial-card" class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 p-8 max-w-3xl">
      <blockquote class="text-gray-600 italic" data-i18n="testimonials.quote">
        <p>
          "Sara has shown consistent presence, where she has been fully involved in the daily operations of the agency. <em class="font-bold"
            >[...]</em
          > Both in team configurations and independently, Sara has demonstrated great responsibility and a strong desire to find solutions that meet the
          client's needs&mdash; this has been the case in both her work with design and coding."
        </p>
      </blockquote>

      <figcaption class="mt-6 flex items-center gap-4">
        <div>
          <p class="font-semibold text-gray-700">Jacob Klintrup</p>
          <p class="text-gray-500 text-sm tracking-[0.08em] uppercase">Creative Strategic Director, Kadaver ApS</p>
        </div>
      </figcaption>
    </figure>
  </section>
</MainLayout>

<!-- CSS -->
<style>
  /* Animations */
  @keyframes ping {
    75%,
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  .animate-ping {
    animation: ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .animate__animated {
    --animate-duration: 1.6s;
  }

  html.has-js body:not(.reduce-motion) #status,
  html.has-js body:not(.reduce-motion) #hero-content h1,
  html.has-js body:not(.reduce-motion) #hero-content .hero-role,
  html.has-js body:not(.reduce-motion) #hero-content .hero-lead,
  html.has-js body:not(.reduce-motion) #hero-cta,
  html.has-js body:not(.reduce-motion) #hero-image,
  html.has-js body:not(.reduce-motion) #project-label,
  html.has-js body:not(.reduce-motion) #project-kanji,
  html.has-js body:not(.reduce-motion) #project-title,
  html.has-js body:not(.reduce-motion) #project-text,
  html.has-js body:not(.reduce-motion) #divider-1,
  html.has-js body:not(.reduce-motion) #testimonial-title,
  html.has-js body:not(.reduce-motion) #testimonial-card,
  html.has-js body:not(.reduce-motion) #diff-title,
  html.has-js body:not(.reduce-motion) #diff-intro,
  html.has-js body:not(.reduce-motion) #differentiator .diff-card {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    will-change: transform, opacity;
  }

  #project-title {
    line-height: 1.08;
    text-wrap: balance;
  }

  #project-text {
    max-width: 72ch;
  }

  /* Hero-section */

  /* Styled to match the pill treatment used elsewhere on the site for hover/tag badges
     (.card-degree-badge in Cases.astro, .lab-tag in lab.astro) — same glass-pill shape.
     Deliberately neutral gray rather than brand blue: that blue is already the active-nav
     and CTA-button colour right above/below this element in the hero, so reusing it here
     would compete with the CTA instead of reading as a quiet status label. Gray ties it
     into the existing hero-title/role/lead gray hierarchy instead. */
  .hero-status {
    width: fit-content;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 1px solid rgba(75, 85, 99, 0.45);
    border-radius: 9999px;
    padding: 0.55rem 0.8rem;
    background: rgba(75, 85, 99, 0.14);
    color: #4b5563;
    line-height: 1.2;
    text-transform: uppercase;
  }

  body.calm-mode .status-ping {
    background-color: #88b99f;
    opacity: 0.58;
  }

  body.calm-mode .status-dot {
    background-color: #88b99f;
    border-color: #67977d;
  }

  #status p {
    font-size: 0.75rem;
    color: inherit;
  }

  .hero-role {
    font-size: clamp(1.15rem, 1.75vw, 1.75rem);
    line-height: 1.35;
    font-style: italic;
  }

  .hero-lead {
    font-size: clamp(1rem, 1.25vw, 1.35rem);
    line-height: 1.8;
  }

  .hero-image-wrap {
    border: 1px solid rgb(244 248 250 / 28%);
    border-radius: 1.75rem;
    background: linear-gradient(165deg, rgb(244 248 250 / 6%), rgb(244 248 250 / 0%));
    padding: 0.8rem;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 1.15rem;
    object-position: center 28%;
    border: 1px solid rgb(244 248 250 / 16%);
  }

  @media (min-width: 1024px) {
    .hero-image-wrap {
      margin-left: 0.8rem;
    }
  }

  @media (max-width: 1023px) {
    .hero-image-wrap {
      margin: 0 auto;
    }

    .hero-image {
      aspect-ratio: 5 / 4;
    }

    .hero-image-accent {
      right: -10px;
      bottom: -10px;
    }
  }

  /* Differentiator section */
  body.dark #diff-title,
  body.dark #diff-intro,
  body.dark .diff-card h3 {
    color: var(--text-on-dark);
  }
  body.dark .diff-card p {
    color: var(--text-on-dark-soft, #c0c0c0);
  }
  body.dark .diff-card {
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    border-color: var(--dark-border);
  }

  /* Dark-mode */
  body.dark .hero-title,
  body.dark .hero-role,
  body.dark .hero-lead,
  body.dark #testimonial-title,
  body.dark #testimonials p,
  body.dark #testimonials blockquote,
  body.dark #testimonials blockquote em,
  body.dark #project-section h2,
  body.dark #project-section p {
    color: var(--text-on-dark-soft);
  }

  body.dark #testimonial-card {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #divider-1 {
    color: var(--dark-border);
  }

  body.dark #divider-1 .divider-center {
    background-color: var(--dark-surface-strong);
    border-color: var(--dark-border);
  }

  /* Miscellaneous */
  #hero-subtitle-text,
  #hero-text-content {
    display: inline-block;
  }

  body.dark .hero-status {
    border-color: rgba(163, 163, 163, 0.4);
    background: rgba(163, 163, 163, 0.18);
    color: var(--text-on-dark);
  }

  body.dark .hero-image-wrap {
    border-color: color-mix(in srgb, var(--dark-border) 64%, var(--brand-primary-soft) 36%);
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--dark-surface) 78%, var(--brand-primary-strong) 22%),
      color-mix(in srgb, var(--dark-surface-strong) 88%, var(--brand-primary-strong) 12%)
    );
  }

  body.dark #process-cards div svg {
    color: var(--text-on-dark);
    background: transparent;
  }
</style>
