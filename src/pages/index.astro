  html.has-js body:not(.reduce-motion) #project-title,
  html.has-js body:not(.reduce-motion) #project-kanji,
  html.has-js body:not(.reduce-motion) #project-text,
  html.has-js body:not(.reduce-motion) #project-label,
  html.has-js body:not(.reduce-motion) #hero-image,
