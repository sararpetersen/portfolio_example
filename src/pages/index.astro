</MainLayout>

<!-- Script for inView animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;

    if (!reduceMotion) {
      const registerInView = (selector: string, animationClass: string, delayMs = 0) => {
        const element = document.querySelector(selector);
        if (!element) return;

        let stop = () => {};
        stop = inView(element, () => {
          const animationToUse = animationClass;
          const normalizedDelay = isMobileViewport ? Math.min(delayMs, 220) : delayMs;

          (element as HTMLElement).classList.add("animate__animated", animationToUse);
          (element as HTMLElement).style.animationDelay = `${normalizedDelay}ms`;
          (element as HTMLElement).style.animationDuration = isMobileViewport ? "1s" : "1.6s";
          (element as HTMLElement).style.animationFillMode = "both";

          stop();
        });
      };

      [
        ["#status", "animate__fadeInUp"],
        ["#hero-content h1", "animate__fadeInUp"],
        ["#hero-content h2", "animate__fadeInUp"],
        ["#hero-content .hero-lead", "animate__fadeInUp"],
        ["#hero-cta", "animate__fadeInUp"],
        ["#hero-image", "animate__fadeInUp"],
        ["#scroll-down", "animate__fadeInUp"],
        ["#project-label", "animate__fadeInUp"],
        ["#project-kanji", "animate__fadeInUp"],
        ["#project-title", "animate__fadeInUp"],
        ["#project-text", "animate__fadeInUp"],
        ["#divider-1", "animate__fadeInUp"],
        ["#blog-preview-title", "animate__fadeInUp"],
        ["#blog-preview-text", "animate__fadeInUp"],
        ["#blog-preview-all", "animate__fadeInUp"],
        ["#divider-2", "animate__fadeInUp"],
        ["#lab-preview-header", "animate__fadeInUp"],
        ["#lab-preview-title", "animate__fadeInUp"],
        ["#lab-preview-text-paragraph", "animate__fadeInUp"],
        ["#lab-preview-cta", "animate__fadeInUp"],
        ["#lab-preview-card", "animate__fadeInUp"],
        ["#testimonial-card", "animate__fadeInUp"],
      ].forEach(([selector, animationClass], index) => {
        registerInView(selector, animationClass, index * 60);
      });

      document.querySelectorAll("#revamped-section article").forEach((article, index) => {
        let stop = () => {};
        stop = inView(article, () => {
          (article as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");
          (article as HTMLElement).style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          (article as HTMLElement).style.animationDuration = isMobileViewport ? "0.95s" : "1.4s";
          (article as HTMLElement).style.animationFillMode = "both";

          stop();
        });
      });

      document.querySelectorAll("#now-section .now-item, #blog-preview .blog-preview-item").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          (item as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");
          (item as HTMLElement).style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          (item as HTMLElement).style.animationDuration = isMobileViewport ? "0.95s" : "1.3s";
          (item as HTMLElement).style.animationFillMode = "both";

          stop();
        });
      });
    }
  });
</script>

<!-- CSS -->
<style>
