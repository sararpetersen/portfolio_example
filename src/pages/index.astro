---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const fetchCards = async () => {
  try {
    const response = await fetch("https://bbmabdbbjpfqoapbtstm.supabase.co/rest/v1/portfolio_cases?order=id.asc", {
      method: "GET",
      headers: {
        apikey:
          "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJibWFiZGJianBmcW9hcGJ0c3RtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI0NjkwNDYsImV4cCI6MjA1ODA0NTA0Nn0.gFnw6GZiMFOCMwy6rAcQFzoK0_qUJCwKNpl-XGzy574",
      },
    });

    if (!response.ok) {
      console.warn(`API error: ${response.status} ${response.statusText}`);
      return [];
    }

    const data = await response.json();
    return Array.isArray(data) ? data : [];
  } catch (error) {
    console.error("Failed to fetch portfolio cases:", error);
    return [];
  }
};

const cards = await fetchCards();

// Cases removed from the frontpage grid — their pages stay live and they remain
// reachable from The Archive (singleusesucks, vinens_essens) and The Lab (vibeloop).
const ARCHIVED_CASE_SLUGS = new Set(["singleusesucks", "vinens_essens", "vibeloop"]);

const sortedCards = cards
  .filter((card) => !ARCHIVED_CASE_SLUGS.has(card.slug))
  .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())
  .slice(0, 6);
const latestBlogPosts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((entry: CollectionEntry<"blog">) => !entry.data.draft)
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
import Cases from "../components/Cases.astro";
---

<MainLayout
  title="SRP portfolio | Homepage"
  description="Portfolio of Sara Ringkow Petersen, a multimedia designer and concept developer with a focus on accessibility and user-centred design."
  ogtitle="Frontpage – SRP Portfolio"
  ogdescription="Multimedia designer and concept developer based in Denmark. Browse selected cases, experiments, and design work by Sara Ringkow Petersen."
>
  <!-- Hero Section -->
  <section id="hero" class="hero-section relative w-full md:px-16 px-4 overflow-hidden">
    <div class="relative z-20 mx-auto md:px-0 px-2">
      <div id="hero-content" class="grid grid-cols-12 items-center min-h-screen pt-[11rem] md:pb-20 pb-8 gap-y-12">
        <div class="col-span-12 lg:col-span-7 hero-panel">
          <div id="status" class="hero-status mb-8 flex items-center gap-3 justify-start text-sm">
            <span class="relative flex md:h-3.5 md:w-3.5 h-2.5 w-2.5" aria-hidden="true">
              <span class="status-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
              <span class="status-dot relative inline-flex md:h-3.5 md:w-3.5 h-2.5 w-2.5 rounded-full bg-green-400 border border-[#1fb355]"></span>
            </span>

            <p data-i18n="hero.status" class="text-gray-50">Interning at Folkæt</p>
          </div>

          <h1 class="hero-title display text-gray-800 leading-[1.1] pb-6">Sara Ringkow Petersen</h1>
          <p class="hero-role text-gray-700 pb-6 font-garamond" data-i18n="hero.role">Multimedia Designer & Concept Developer</p>
          <p class="hero-lead text-gray-500 font-light pb-8 max-w-xl" data-i18n="hero.lead">
            I design and build accessible websites, interfaces, and concepts — focusing on structure, clarity, and the people who use them.
          </p>

          <div id="hero-cta" class="btn-container flex flex-wrap items-center gap-4">
            <span class="md:hidden block">
              <Button href="#project-section" variant="primary" size="medium" aria-label="Go to projects section"
                ><span data-i18n="hero.cta">See projects</span></Button
              >
            </span>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5">
          <div id="hero-image" class="hero-image-wrap relative shadow-drop25">
            <div class="hero-image-accent md:block hidden" aria-hidden="true"></div>
            <img src="/images/hero_image.webp" alt="Sara Ringkow Petersen" class="hero-image object-cover" width="500" height="500" loading="eager" />
          </div>
        </div>
      </div>
    </div>

    <div id="scroll-down" class="hidden md:flex absolute inset-x-0 -bottom-1 w-full justify-center z-[20]" aria-hidden="true">
      <a href="#project-section" tabindex="-1" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 scroll-link">
        <div class="flex flex-col items-center transition duration-300 ease-in-out">
          <p class="uppercase tracking-[0.22em] text-xs text-gray-500" data-i18n="hero.scroll">Scroll to projects</p>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8 sm:w-10 sm:h-10 transition duration-300 ease-in-out scroll-icon"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
          </svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="project-section" class="grid grid-cols-12 max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <div class="container col-span-12">
      <!-- kanji + title -->
      <div class="flex items-center mb-3">
        <h2 id="project-title" class="font-garamond font-semibold italic text-h3-mobile md:text-h3-desktop text-gray-800" data-i18n="projects.title">
          Selected cases
        </h2>
      </div>
    </div>

    <!-- description -->
    <p id="project-text" class="col-span-12 text-gray-600 mb-6 leading-relaxed" data-i18n="projects.text">
      Below is a selection of projects that I've worked on during my studies and internships. Click on any of the cards to read more about the
      project, the process and the outcome.
    </p>
    <div class="col-span-12">
      {
        sortedCards.length > 0 ? (
          <Cases projects={sortedCards} />
        ) : (
          <p class="rounded-2xl border border-gray-400 bg-gray-50 p-6 text-gray-700" data-i18n="projects.empty">
            Projects are temporarily unavailable. Please check back in a moment.
          </p>
        )
      }
    </div>
  </section>

  <!-- Divider -->
  <div id="divider-1" class="max-w-7xl mx-auto px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- What makes my approach different? -->
  <section id="differentiator" class="max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <div class="mb-8">
      <h2 id="diff-title" class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-3" data-i18n="diff.title">
        What makes my approach different?
      </h2>
      <p id="diff-intro" class="text-gray-600 leading-relaxed max-w-2xl text-sm md:text-base" data-i18n="diff.intro">
        A lot of designers mention accessibility. Here's what actually shapes how I work.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 grid-cols-1 gap-5">
      <!-- Card 1 -->
      <article id="diff-card-1" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card1.label">Lived experience</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card1.title">
          I design from the inside
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card1.text">
          I'm autistic and have ADD. That's <strong>not a footnote</strong>&mdash; it's the reason accessibility is central to how I work, not just
          something I layer on at the end. I know what it's like to use digital products that weren't built with you in mind, and that shapes every
          decision I make.
        </p>
      </article>

      <!-- Card 2 -->
      <article id="diff-card-2" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card2.label">Design + code</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card2.title">
          What I design, I can build
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card2.text">
          I don't just hand off specs and hope for the best. I design and develop, with <strong>no gap between the idea and the implementation</strong
          >. That means fewer compromises, faster iteration, and solutions that are actually accessible in the final product, not just on paper.
        </p>
      </article>

      <!-- Card 3 -->
      <article id="diff-card-3" class="diff-card rounded-2xl border-l-4 border border-gray-500 p-6 bg-gradient-to-br from-gray-50 to-gray-100">
        <p class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-500 mb-3" data-i18n="diff.card3.label">Proof, not promises</p>
        <h3 class="font-garamond italic font-semibold text-h4-mobile md:text-[1.3rem] text-gray-800 mb-3 leading-snug" data-i18n="diff.card3.title">
          The portfolio you're looking at is the work
        </h3>
        <p class="text-sm text-gray-600 leading-relaxed" data-i18n="diff.card3.text">
          This site has dark mode, calm mode, focus mode, four reading font options, keyboard navigation, reduced motion, and bilingual support — all
          built by me. Accessibility isn't a claim I make. It's something I demonstrate.
        </p>
      </article>
    </div>
  </section>

  <!-- Latest Blog Section -->
  <section id="blog-preview" class="max-w-7xl mx-auto px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="blog-preview-title"
      class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-3"
      data-i18n="blog.preview.title"
    >
      Latest posts
    </h2>

    <p id="blog-preview-text" class="text-gray-600 mb-6 leading-relaxed text-sm md:text-base" data-i18n="blog.preview.text">
      A running log of things I'm working on, thinking about, or just find worth writing down.
    </p>

    <div class="grid lg:grid-cols-3 gap-4">
      {
        latestBlogPosts.map((post) => (
          <article class="blog-preview-item rounded-2xl border-l-4 border border-gray-500 p-4 bg-gradient-to-br from-gray-50 to-gray-100">
            <p class="text-[11px] uppercase tracking-[0.12em] text-gray-500 mb-3">{post.data.publishDate.toLocaleDateString("en-GB")}</p>
            <h3 class="text-[18px] font-semibold mb-2 leading-snug">{post.data.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">{post.data.excerpt}</p>
            <a
              href={`/blog/${post.slug}`}
              aria-label={`Read post: ${post.data.title}`}
              class="py-1 md:text-p-desktop text-[15px] text-gray-500 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
              data-i18n="blog.read"
            >
              Read post →
            </a>
          </article>
        ))
      }
    </div>

    <div id="blog-preview-all" class="pt-6">
      <Button href="/blog" variant="primary" size="small" aria-label="Go to all blog posts"
        ><span data-i18n="blog.preview.all">See all blog posts</span></Button
      >
    </div>
  </section>

  <!-- Divider -->
  <div id="divider-2" class="max-w-7xl mx-auto px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- About Preview Section -->
  <section id="about-preview" class="max-w-7xl mx-auto relative px-6 md:pt-desktop-top pt-mobil-top">
    <div class="lg:flex lg:justify-center lg:items-center gap-12">
      <!-- Image -->
      <div class="hidden lg:flex lg:order-1 lg:shrink-0 order-2">
        <img
          src="/images/pfp3.webp"
          alt="Picture of Sara"
          class="border-r-4 border border-gray-500 rounded-2xl object-cover w-full max-w-[360px] aspect-[9/10]"
          width="826"
          height="952"
          loading="lazy"
        />
      </div>

      <!-- Text -->
      <div id="about-preview-text" class="lg:order-2 lg:max-w-lg order-1">
        <h2
          id="about-preview-title"
          class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-6"
          data-i18n="about.preview.title"
        >
          About me
        </h2>
        <p
          id="about-preview-text-paragraph"
          class="mb-6 text-gray-600 leading-relaxed p-7 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500"
          data-i18n="about.preview.text"
        >
          I'm a Multimedia Designer and Concept Developer. I work with web design, UX/UI, and concept development, with a focus on making things
          accessible, structured, and easy to use.
        </p>
        <div class="btn_container">
          <Button href="/about_me" variant="primary" size="small" aria-label="Learn more about me"
            ><span data-i18n="about.preview.cta">Learn more about me</span></Button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="max-w-7xl mx-auto md:pb-desktop-bottom pb-mobil-bottom px-6 md:pt-desktop-top pt-mobil-top">
    <h2
      id="testimonial-title"
      class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800 mb-6"
      data-i18n="testimonials.title"
    >
      Featured testimonial
    </h2>
    <figure id="testimonial-card" class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 p-8 max-w-3xl">
      <blockquote class="text-gray-600 italic" data-i18n="testimonials.quote">
        <p>
          "Sara has shown consistent presence, where she has been fully involved in the daily operations of the agency. <em class="font-bold"
            >[...]</em
          > Both in team configurations and independently, Sara has demonstrated great responsibility and a strong desire to find solutions that meet the
          client's needs&mdash; this has been the case in both her work with design and coding."
        </p>
      </blockquote>

      <figcaption class="mt-6 flex items-center gap-4">
        <div>
          <p class="font-semibold text-gray-700">Jacob Klintrup</p>
          <p class="text-gray-500 text-sm tracking-[0.08em] uppercase">Creative Strategic Director, Kadaver ApS</p>
        </div>
      </figcaption>
    </figure>
  </section>
</MainLayout>

<!-- Script for inView animations -->
<script>
  import { inView } from "motion";

  document.addEventListener("DOMContentLoaded", () => {
    const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;

    if (reduceMotion) document.body.classList.add("reduce-motion");

    if (!reduceMotion) {
      const registerInView = (selector: string, animationClass: string, delayMs = 0) => {
        const element = document.querySelector(selector);
        if (!element) return;

        let stop = () => {};
        stop = inView(element, () => {
          const animationToUse = animationClass;
          const normalizedDelay = isMobileViewport ? Math.min(delayMs, 220) : delayMs;

          (element as HTMLElement).style.animationDelay = `${normalizedDelay}ms`;
          (element as HTMLElement).style.animationDuration = isMobileViewport ? "1s" : "1.6s";
          (element as HTMLElement).style.animationFillMode = "both";
          (element as HTMLElement).classList.add("animate__animated", animationToUse);

          stop();
        });
      };

      [
        ["#status", "animate__fadeInUp"],
        ["#hero-content h1", "animate__fadeInUp"],
        ["#hero-content .hero-role", "animate__fadeInUp"],
        ["#hero-content .hero-lead", "animate__fadeInUp"],
        ["#hero-cta", "animate__fadeInUp"],
        ["#hero-image", "animate__fadeInUp"],
        ["#scroll-down", "animate__fadeInUp"],
        ["#project-label", "animate__fadeInUp"],
        ["#project-kanji", "animate__fadeInUp"],
        ["#project-title", "animate__fadeInUp"],
        ["#project-text", "animate__fadeInUp"],
        ["#divider-1", "animate__fadeInUp"],
        ["#diff-title", "animate__fadeInUp"],
        ["#diff-intro", "animate__fadeInUp"],
        ["#blog-preview-title", "animate__fadeInUp"],
        ["#blog-preview-text", "animate__fadeInUp"],
        ["#blog-preview-all", "animate__fadeInUp"],
        ["#divider-2", "animate__fadeInUp"],
        ["#about-preview-title", "animate__fadeInUp"],
        ["#about-preview-text-paragraph", "animate__fadeInUp"],
        [".btn_container", "animate__fadeInUp"],
        ["#about-preview img", "animate__fadeInUp"],
        ["#testimonial-title", "animate__fadeInUp"],
        ["#testimonial-card", "animate__fadeInUp"],
      ].forEach(([selector, animationClass], index) => {
        registerInView(selector, animationClass, index * 60);
      });

      document.querySelectorAll("#revamped-section article").forEach((article, index) => {
        let stop = () => {};
        stop = inView(article, () => {
          (article as HTMLElement).style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          (article as HTMLElement).style.animationDuration = isMobileViewport ? "0.95s" : "1.4s";
          (article as HTMLElement).style.animationFillMode = "both";
          (article as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");

          stop();
        });
      });

      document.querySelectorAll("#differentiator .diff-card").forEach((card, index) => {
        let stop = () => {};
        stop = inView(card, () => {
          (card as HTMLElement).style.animationDelay = `${isMobileViewport ? Math.min(index * 80, 220) : index * 80}ms`;
          (card as HTMLElement).style.animationDuration = isMobileViewport ? "0.95s" : "1.3s";
          (card as HTMLElement).style.animationFillMode = "both";
          (card as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");
          stop();
        });
      });

      document.querySelectorAll("#now-section .now-item, #blog-preview .blog-preview-item").forEach((item, index) => {
        let stop = () => {};
        stop = inView(item, () => {
          (item as HTMLElement).style.animationDelay = `${isMobileViewport ? Math.min(index * 60, 220) : index * 60}ms`;
          (item as HTMLElement).style.animationDuration = isMobileViewport ? "0.95s" : "1.3s";
          (item as HTMLElement).style.animationFillMode = "both";
          (item as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");

          stop();
        });
      });
    }
  });
</script>

<!-- CSS -->
<style>
  /* Animations */
  @keyframes ping {
    75%,
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  @keyframes scrollFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  .animate-ping {
    animation: ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  #scroll-down .scroll-link > div {
    animation: scrollFloat 2.4s ease-in-out infinite;
  }

  .animate__animated {
    --animate-duration: 1.6s;
  }

  html.has-js body:not(.reduce-motion) #status,
  html.has-js body:not(.reduce-motion) #hero-content h1,
  html.has-js body:not(.reduce-motion) #hero-content .hero-role,
  html.has-js body:not(.reduce-motion) #hero-content .hero-lead,
  html.has-js body:not(.reduce-motion) #hero-cta,
  html.has-js body:not(.reduce-motion) #hero-image,
  html.has-js body:not(.reduce-motion) #scroll-down,
  html.has-js body:not(.reduce-motion) #project-label,
  html.has-js body:not(.reduce-motion) #project-kanji,
  html.has-js body:not(.reduce-motion) #project-title,
  html.has-js body:not(.reduce-motion) #project-text,
  html.has-js body:not(.reduce-motion) #divider-1,
  html.has-js body:not(.reduce-motion) #blog-preview-title,
  html.has-js body:not(.reduce-motion) #blog-preview-text,
  html.has-js body:not(.reduce-motion) #blog-preview-all,
  html.has-js body:not(.reduce-motion) #divider-2,
  html.has-js body:not(.reduce-motion) #about-preview-title,
  html.has-js body:not(.reduce-motion) #about-preview-text-paragraph,
  html.has-js body:not(.reduce-motion) .btn_container,
  html.has-js body:not(.reduce-motion) #about-preview img,
  html.has-js body:not(.reduce-motion) #testimonial-title,
  html.has-js body:not(.reduce-motion) #testimonial-card,
  html.has-js body:not(.reduce-motion) #blog-preview .blog-preview-item,
  html.has-js body:not(.reduce-motion) #diff-title,
  html.has-js body:not(.reduce-motion) #diff-intro,
  html.has-js body:not(.reduce-motion) #differentiator .diff-card {
    opacity: 0;
    transform: translate3d(0, 1.25rem, 0);
    will-change: transform, opacity;
  }

  #project-title,
  #blog-preview-title {
    line-height: 1.08;
    text-wrap: balance;
  }

  #project-text {
    max-width: 72ch;
  }

  /* Hero-section */

  .hero-status {
    width: fit-content;
    font-weight: 600;
    letter-spacing: 0.08em;
    border: 1px solid rgba(73, 75, 79, 0.35);
    border-radius: 9999px;
    padding: 0.4rem 0.7rem;
    background: rgba(15, 23, 42, 0.82);
    color: #f8fafc;
    line-height: 1;
    text-transform: uppercase;
  }

  body.calm-mode .status-ping {
    background-color: #88b99f;
    opacity: 0.58;
  }

  body.calm-mode .status-dot {
    background-color: #88b99f;
    border-color: #67977d;
  }

  #status p {
    font-size: 0.79rem;
  }

  .hero-role {
    font-size: clamp(1.4rem, 2.2vw, 2.25rem);
    line-height: 1.25;
    font-style: italic;
  }

  .hero-lead {
    font-size: clamp(1rem, 1.25vw, 1.35rem);
    line-height: 1.8;
  }

  .hero-image-wrap {
