---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const fetchCards = async () => {
  try {
    const response = await fetch("https://bbmabdbbjpfqoapbtstm.supabase.co/rest/v1/portfolio_cases?order=id.asc", {
      method: "GET",
      headers: {
        apikey:
          "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJibWFiZGJianBmcW9hcGJ0c3RtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI0NjkwNDYsImV4cCI6MjA1ODA0NTA0Nn0.gFnw6GZiMFOCMwy6rAcQFzoK0_qUJCwKNpl-XGzy574",
      },
    });

    if (!response.ok) {
      console.warn(`API error: ${response.status} ${response.statusText}`);
      return [];
    }

    const data = await response.json();
    return Array.isArray(data) ? data : [];
  } catch (error) {
    console.error("Failed to fetch portfolio cases:", error);
    return [];
  }
};

const cards = await fetchCards();
const sortedCards = cards.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
const latestBlogPosts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((entry: CollectionEntry<"blog">) => !entry.data.draft)
  .sort((a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

function breakTitle(title: string, maxLength: number = 25): string[] {
  if (title.length > maxLength) {
    const words = title.split(" ");
    let line = "";
    let lines: string[] = [];

    words.forEach((word: string) => {
      if ((line + " " + word).length <= maxLength) {
        line += " " + word;
      } else {
        lines.push(line.trim());
        line = word;
      }
    });

    lines.push(line.trim());
    return lines;
  }
  return [title];
}

import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
import Button from "../components/Button.astro";
import Cases from "../components/Cases.astro";
---

