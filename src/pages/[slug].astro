---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import "../styles/global.css";

export async function getStaticPaths() {
  const response = await fetch("https://bbmabdbbjpfqoapbtstm.supabase.co/rest/v1/portfolio_cases", {
    headers: {
      apikey:
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJibWFiZGJianBmcW9hcGJ0c3RtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDI0NjkwNDYsImV4cCI6MjA1ODA0NTA0Nn0.gFnw6GZiMFOCMwy6rAcQFzoK0_qUJCwKNpl-XGzy574",
    },
  });

  const projects = await response.json();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: {
      project,
      allProjects: projects,
    },
  }));
}

interface Project {
  id: number;
  slug: string;
  name: string;
  semester?: string;
  description: string;
  description_da?: string;
  year: string;
  year_da?: string;
  semester_da?: string;
  image: string;
  tools?: string[];
  url: string;
  ai_used?: boolean;
}

const { project, allProjects } = Astro.props as { project: Project; allProjects: Project[] };

// ✅ Sort by ID (or change to .year or .created_at if needed)
const sortedProjects = [...allProjects].sort((a, b) => a.id - b.id);

// 🔁 Find current project in sorted array
const currentIndex = sortedProjects.findIndex((p) => p.slug === project.slug);

// ⬅️ ➡️ Get previous and next projects
const prevProject = currentIndex > 0 ? sortedProjects[currentIndex - 1] : null;
const nextProject = currentIndex < sortedProjects.length - 1 ? sortedProjects[currentIndex + 1] : null;
---

<MainLayout title={project.name} description={project.description} ogtitle={project.name} ogdescription={project.description}>
  <section id="project" class="relative grid grid-cols-12 max-w-6xl mx-auto pt-mobil-top md:mt-24 mt-12 md:px-0 px-6">
    <!-- Navigation -->
    <nav
      id="navigation"
      class="col-span-12 md:text-left text-center md:text-p-desktop flex flex-wrap justify-between items-center gap-4 mb-8 md:pt-0 pt-4"
    >
      <a
        href="/"
        class="py-1 md:text-p-desktop text-[15px] hover:text-blue-400 hover:underline transition duration-300 focus:outline-none focus:ring-2 focus:ring-pale-400"
        aria-label="Go to homepage"
        data-i18n="project.back">↑ Back to homepage</a
      >

      <div class="flex gap-4 ml-auto">
        {
          prevProject && prevProject.slug !== "no-project" && (
            <a
              href={`/${prevProject.slug}`}
              class="py-1 md:text-p-desktop text-[15px] hover:text-blue-400 hover:underline transition duration-300 focus:outline-none focus:ring-2  focus:ring-pale-400 text-gray-800"
              aria-label={`Go to previous project: ${prevProject.name}`}
            >
              ← {prevProject.name}
            </a>
          )
        }
        {
          nextProject && nextProject.slug !== "no-project" && (
            <a
              href={`/${nextProject.slug}`}
              class="py-1 md:text-p-desktop text-[15px] hover:text-blue-400 hover:underline transition duration-300 focus:outline-none focus:ring-2  focus:ring-pale-400 text-gray-800"
              aria-label={`Go to next project: ${nextProject.name}`}
            >
              {nextProject.name} →
            </a>
          )
        }
      </div>
    </nav>

    <!-- Header -->
    <header id="project-header" class="col-span-12 md:mb-12 mb-8 md:text-left text-center">
      <p id="project-label" class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4" data-i18n="project.label">
        Project
      </p>
      <h1 id="project-title" class="font-hiro md:text-h2-desktop text-h4-desktop uppercase tracking-[0.14em] md:tracking-[0.18em] mb-5">
        {project.name}
      </h1>
      <h2
        id="project-subtitle"
        class="italic font-light md:text-h4-desktop text-[18.5px] text-gray-600 leading-7"
        data-year={project.year || ""}
        data-year-da={project.year_da || ""}
      >
        {project.semester || project.year}
      </h2>
    </header>

    <!-- Figma Notice -->
    {
      project.slug === "vibeloop" || project.slug === "ungeforum"
        ? (project.slug === "vibeloop" || project.slug === "ungeforum") && (
            <div
              class="flex items-center gap-3 col-span-12 bg-red-500 border border-l-4 border-red-700 rounded-full md:p-4 p-3 md:w-[35rem] w-full mb-8"
              id="figma-notice"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="30"
                height="30"
                fill="currentColor"
                class="text-gray-50 flex-shrink-0"
                viewBox="0 0 16 16"
              >
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
              </svg>
              <div>
                <p class="text-gray-50 md:text-[14.5px] text-[12px]" data-i18n="project.figma.notice">
                  This project is presented as an interactive prototype created in Figma
                </p>
              </div>
            </div>
          )
        : null
    }

    <!-- Content Grid -->
    <div class="col-span-12 grid md:grid-cols-2 grid-cols-1 gap-12">
      <img
        id="project-image"
        src={project.image}
        alt={project.name}
        class="w-full rounded-xl object-cover border-l-4 border border-gray-500"
        loading="lazy"
      />

      <div class="space-y-6">
        <p
          id="project-description"
          class="text-gray-600"
          data-description={project.description || ""}
          data-description-da={project.description_da || ""}
        >
          {project.description}
        </p>

        {
          project.tools && (
            <div id="tools-list">
              <h3 id="tools-title" class="text-h4-mobile italic font-bold mb-2" data-i18n="project.tools">
                Tools used:
              </h3>
              <div class="flex flex-wrap gap-2 mb-12">
                {project.tools.map((tool) => (
                  <span class="rounded-full px-4 py-2 font-semibold border border-blue-600 bg-blue-600 text-gray-50 text-sm uppercase">{tool}</span>
                ))}
              </div>
            </div>
          )
        }
        <div id="project-link" class="btn-container">
          <a href={project.url} target="_blank" rel="noopener noreferrer" aria-label={`View project: ${project.name}`}>
            <Button variant="secondary" size="small"><span data-i18n="project.view">View project</span></Button>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Projects Section -->
  <section
    id="related-projects"
    class="max-w-6xl grid grid-cols-12 mx-auto md:pt-desktop-top pt-mobil-top md:pb-desktop-bottom pb-mobil-bottom md:px-0 px-6"
  >
    <div id="related-projects-title" class="col-span-12 mb-4">
      <p
        id="related-projects-label"
        class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4"
        data-i18n="project.related.label"
      >
        Selected work
      </p>
      <h2 class="text-h3-desktop uppercase tracking-[0.14em] md:tracking-[0.18em] font-hiro mb-5" data-i18n="project.related.title">More projects</h2>
    </div>

    {
      (() => {
        const randomProjects = sortedProjects.sort(() => 0.5 - Math.random()).slice(0, 3);
        return (
          <div class="col-span-12 grid md:grid-cols-3 grid-cols-1 gap-6">
            {randomProjects.map((proj) => (
              <a href={`/${proj.slug}`} class="group block rounded-3xl focus:outline-none focus:ring-2 focus:ring-pale-400">
                <div class="related-project-card rounded-xl overflow-hidden bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 shadow-sm transition-all duration-300 ease-in-out hover:-translate-y-1 hover:from-gray-100 hover:to-gray-200 hover:border-gray-400 group-focus-visible:-translate-y-1">
                  <img
                    src={proj.image}
                    alt={proj.name}
                    class="w-full h-48 object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03] group-focus-visible:scale-[1.03]"
                    loading="lazy"
                  />
                  <div class="related-project-info p-4 border-t border-gray-500 transition-colors duration-300">
                    <h3 class="related-project-title text-h4-mobile font-bold mb-2">{proj.name}</h3>
                    <p
                      class="related-project-year text-sm text-gray-600 transition-colors duration-300"
                      data-year={proj.year || ""}
                      data-year-da={proj.year_da || ""}
                    >
                      {proj.year}
                    </p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        );
      })()
    }
  </section>
</MainLayout>

<style>
  body.dark #project-header h1,
  body.dark #project-header h2,
  body.dark #project-description,
  body.dark #tools-title {
    color: var(--text-on-dark);
  }

  body.dark a {
    color: var(--text-on-dark);
  }

  body.dark a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #figma-notice {
    border-color: #f4a6a6;
  }

  body.dark #project-image {
    border-color: var(--dark-border);
  }

  body.dark section:last-child .col-span-12 > div > a > div {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #related-projects h2 {
    color: var(--text-on-dark);
  }

  body.dark .related-project-card {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark .related-project-card:hover,
  body.dark .related-project-card:focus-visible {
    background: linear-gradient(to bottom right, var(--dark-border), var(--dark-gradient-start));
  }

  body.dark .related-project-info {
    border-color: var(--dark-border);
  }

  body.dark .related-project-title,
  body.dark .related-project-year {
    color: var(--text-on-dark);
  }
</style>

<script>
  import { inView } from "motion";

  const elements = [
    { selector: "#project-label", animation: "animate__fadeInUp" },
    { selector: "#project-title", animation: "animate__backInRight" },
    { selector: "#project-subtitle", animation: "animate__backInLeft" },
    { selector: "#project-description", animation: "animate__fadeInRight" },
    { selector: "#related-projects-label", animation: "animate__fadeInUp" },
  ];

  const applyDatabaseTranslations = (lang: string) => {
    const descriptionEl = document.querySelector("#project-description") as HTMLElement | null;
    const subtitleEl = document.querySelector("#project-subtitle") as HTMLElement | null;

    if (descriptionEl) {
      const description = descriptionEl.dataset.description || "";
      const descriptionDa = descriptionEl.dataset.descriptionDa || "";
      const currentDescription = lang === "da" ? descriptionDa || description : description;
      descriptionEl.textContent = currentDescription;
    }

    const getCurrentPeriod = (el: HTMLElement) => {
      const year = el.dataset.year || "";
      const yearDa = el.dataset.yearDa || "";
      const semester = el.dataset.semester || "";
      const semesterDa = el.dataset.semesterDa || "";

      const currentYear = lang === "da" ? yearDa || year : year;
      const currentSemester = lang === "da" ? semesterDa || semester : semester;

      return currentSemester || currentYear;
    };

    if (subtitleEl) {
      subtitleEl.textContent = getCurrentPeriod(subtitleEl);
    }

    document.querySelectorAll(".related-project-year").forEach((yearEl) => {
      const element = yearEl as HTMLElement;
      element.textContent = getCurrentPeriod(element);
    });
  };

  const getLang = () => localStorage.getItem("lang") || "en";

  const initAnimations = () => {
    if (document.body.classList.contains("reduce-motion")) return;

    elements.forEach(({ selector, animation }) => {
      document.querySelectorAll(selector).forEach((el) => {
        inView(el, () => el.classList.add("animate__animated", animation));
      });
    });

    document.querySelectorAll("#tools-list").forEach((tool, i) => {
      inView(tool, () => {
        tool.classList.add("animate__animated", "animate__rotateInDownLeft");
        (tool as HTMLElement).style.animationDelay = `${i * 0.2}s`;
      });
    });

    const elementmedanimation6 = document.querySelector("#project-link") as HTMLElement | null;
    if (elementmedanimation6) {
      inView(elementmedanimation6, () => {
        elementmedanimation6.classList.add("animate__animated", "animate__fadeInUp");
      });
    }

    const elementmedanimation5 = document.querySelector("#project-image") as HTMLElement | null;
    if (elementmedanimation5) {
      inView(elementmedanimation5, () => {
        elementmedanimation5.classList.add("animate__animated", "animate__fadeInLeft");
      });
    }

    const elementmedanimation7 = document.querySelector("#gallery") as HTMLElement | null;
    if (elementmedanimation7) {
      inView(elementmedanimation7, () => {
        elementmedanimation7.classList.add("animate__animated", "animate__fadeInRight");
      });
    }

    const elementmedanimation8 = document.querySelector("#figma-notice") as HTMLElement | null;
    if (elementmedanimation8) {
      inView(elementmedanimation8, () => {
        elementmedanimation8.classList.add("animate__animated", "animate__backInDown");
      });
    }

    const elementmedanimation10 = document.querySelector("#ai-notice") as HTMLElement | null;
    if (elementmedanimation10) {
      inView(elementmedanimation10, () => {
        elementmedanimation10.classList.add("animate__animated", "animate__backInDown");
      });
    }

    const cards = document.querySelectorAll(".related-project-card");
    cards.forEach((card) => {
      const cardEl = card as HTMLElement;
      inView(cardEl, () => {
        cardEl.classList.add("animate__animated", "animate__fadeInUp");
        cardEl.style.animationDelay = `${Math.random() * 0.5}s`;
      });
    });

    const elementmedanimation9 = document.querySelector("#related-projects-title") as HTMLElement | null;
    if (elementmedanimation9) {
      inView(elementmedanimation9, () => {
        elementmedanimation9.classList.add("animate__animated", "animate__backInRight");
      });
    }
  };

  const syncDatabaseTranslations = () => {
    applyDatabaseTranslations(getLang());
  };

  document.addEventListener("DOMContentLoaded", () => {
    syncDatabaseTranslations();
    try {
      initAnimations();
    } catch {
      // Keep page functional even if animations fail.
    }
  });

  document.addEventListener("astro:page-load", () => {
    syncDatabaseTranslations();
  });

  window.addEventListener("langchange", (event: Event) => {
    const customEvent = event as CustomEvent;
    const lang = customEvent.detail?.lang || getLang();
    applyDatabaseTranslations(lang);
  });

  document.querySelectorAll("#lang-toggle-en, #lang-toggle-da").forEach((button) => {
    button.addEventListener("click", () => {
      requestAnimationFrame(() => {
        syncDatabaseTranslations();
      });
    });
  });
</script>
