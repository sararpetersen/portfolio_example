---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import { ARCHIVED_CASE_SLUGS, fetchPortfolioCases, NON_ACTIVE_CASE_SLUGS, type PortfolioCase } from "../data/portfolioCases";
import "../styles/global.css";

export async function getStaticPaths() {
  const projects = await fetchPortfolioCases();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project, allProjects: projects },
  }));
}

const { project, allProjects } = Astro.props as { project: PortfolioCase; allProjects: PortfolioCase[] };

const sortedProjects = [...allProjects].sort((a, b) => a.id - b.id);
const navigationProjects = sortedProjects.filter(
  (item) => !ARCHIVED_CASE_SLUGS.has(item.slug) && !NON_ACTIVE_CASE_SLUGS.has(item.slug),
);

const currentIndex = navigationProjects.findIndex((item) => item.slug === project.slug);

const prevProject = currentIndex > 0 ? navigationProjects[currentIndex - 1] : null;
const nextProject = currentIndex >= 0 && currentIndex < navigationProjects.length - 1 ? navigationProjects[currentIndex + 1] : null;
---

<MainLayout
  title={`${project.name} | Inclusive Design Case Study`}
  description={`${project.name} case study by Sara Ringkow Petersen. ${project.description}`}
  ogtitle={`${project.name} – Inclusive Design Case Study`}
  ogdescription={`Explore the challenge, design process and outcome behind ${project.name}. ${project.description}`}
>
  <section id="project" class="relative grid grid-cols-12 max-w-6xl mx-auto pt-mobil-top md:mt-[5.5rem] mt-12 lg:px-0 px-6">
    <!-- Navigation -->
    <nav
      id="navigation"
      aria-label="Page navigation"
      class="col-span-12 grid grid-cols-3 items-center gap-2 md:mb-12 mb-10 md:pt-0 pt-10 text-[15px] md:text-p-desktop"
    >
      <div>
        {
          prevProject && prevProject.slug !== "no-project" && (
            <a
              href={`/${prevProject.slug}`}
              class="inline-block text-gray-500 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
              aria-label={`Go to previous project: ${prevProject.name}`}
            >
              ←{" "}
              <>
                <span class="hidden md:inline">{prevProject.name}</span>
                <span class="md:hidden">Prev</span>
              </>
            </a>
          )
        }
      </div>

      <div class="text-center">
        <a
          href="/"
          class="inline-block text-gray-500 py-1 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
          aria-label="Go to homepage"
          data-i18n="project.back"
        >
          ↑ <span class="hidden md:inline">Homepage</span><span class="md:hidden">Home</span>
        </a>
      </div>

      <div class="text-right">
        {
          nextProject && nextProject.slug !== "no-project" && (
            <a
              href={`/${nextProject.slug}`}
              class="inline-block text-gray-500 py-1 hover:text-blue-400 hover:underline transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
              aria-label={`Go to next project: ${nextProject.name}`}
            >
              <>
                <span class="hidden md:inline">{nextProject.name}</span>
                <span class="md:hidden">Next</span>
              </>{" "}
              →
            </a>
          )
        }
      </div>
    </nav>

    <!-- Header -->
    <header id="project-header" class="col-span-12 md:mb-8 mb-6">
      <div id="project-title-row" class="mb-3">
        <h1 id="project-title" class="font-nikumaru md:text-h2-desktop text-h4-desktop uppercase tracking-[0.14em] md:tracking-[0.18em]">
          {project.name}
        </h1>
      </div>
      <h2
        id="project-subtitle"
        class="italic font-light md:text-h4-desktop text-[18.5px] text-gray-600 leading-7"
        data-semester={project.semester || ""}
        data-semester-da={project.semester_da || ""}
        data-year={project.year || ""}
        data-year-da={project.year_da || ""}
      >
        {project.semester || project.year}
      </h2>
    </header>

    <!-- Figma Notice -->
    {
      (project.slug === "vibeloop" || project.slug === "ungeforum" || project.slug === "pinterest-ai" || project.slug === "pace-duolingo") && (
        <div
          class="flex items-start md:items-center justify-center md:justify-start gap-3 col-span-12 bg-red-600 border border-l-4 border-red-700 rounded-2xl md:rounded-full md:p-4 px-4 py-3 md:w-[35rem] w-full mb-8"
          id="figma-notice"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="30"
            height="30"
            fill="currentColor"
            class="text-gray-50 flex-shrink-0 hidden md:block"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
          </svg>
          <div class="min-w-0 flex-1">
            <p
              class="text-gray-50 md:text-[14.5px] text-[12px] leading-[1.4] md:leading-[1.5] text-center md:text-left break-words"
              data-i18n="project.figma.notice"
            >
              This project is presented as an interactive prototype created in Figma
            </p>
          </div>
        </div>
      )
    }

    <!-- DB Notice -->
    {
      project.slug === "susse_volander" && (
        <div
          class="flex items-start md:items-center justify-center md:justify-start gap-3 col-span-12 bg-orange-200 border border-l-4 border-orange-600 rounded-2xl md:rounded-full md:p-4 px-4 py-3 md:w-fit w-full mb-8"
          id="db-notice"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="30"
            height="30"
            fill="currentColor"
            class="text-orange-800 flex-shrink-0 hidden md:block"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
          </svg>
          <div class="min-w-0 flex-1">
            <p
              class="text-orange-950 md:text-[14.5px] text-[12px] leading-[1.4] md:leading-[1.5] text-center md:text-left break-words"
              data-i18n="project.db.notice"
            >
              The images on the gallery page are no longer visible due to the original database being inactive. This does not reflect the original
              functionality of the project.
            </p>
          </div>
        </div>
      )
    }

    <!-- Content Grid -->
    <div class="col-span-12 grid md:grid-cols-2 grid-cols-1 gap-8">
      <img
        id="project-image"
        src={project.image}
        alt={project.name}
        class="w-full aspect-[4/3] rounded-xl object-cover border-l-4 border border-gray-500"
        loading="lazy"
      />

      <div class="flex flex-col">
        <p
          id="project-description"
          class="text-gray-600"
          data-description={project.description || ""}
          data-description-da={project.description_da || ""}
        >
          {project.description}
        </p>

        {
          project.tools && (
            <div id="tools-list" class="mt-6">
              <h2 id="tools-title" class="md:text-h4-desktop text-h4-mobile italic text-gray-800 mb-3" data-i18n="project.tools">
                Tools used:
              </h2>
              <div class="flex flex-wrap gap-2">
                {project.tools.map((tool) => (
                  <span class="rounded-full px-4 py-2 font-semibold border border-blue-600 bg-blue-600 text-gray-50 text-sm uppercase">{tool}</span>
                ))}
              </div>
            </div>
          )
        }
        <div id="project-link" class="btn-container mt-auto pt-8">
          <Button
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            size="small"
            aria-label={`View project: ${project.name} (opens in new tab)`}><span data-i18n="project.view">View project</span></Button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div id="project-divider-1" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Related Projects Section -->
  <section
    id="related-projects"
    class="max-w-6xl grid grid-cols-12 mx-auto md:pt-desktop-top pt-mobil-top md:pb-desktop-bottom pb-mobil-bottom lg:px-0 px-6"
  >
    <div id="related-projects-title" class="col-span-12">
      <div id="related-projects-title-row" class="flex items-center gap-4 mb-6">
        <h2
          class="font-garamond font-semibold italic text-h3-mobile md:text-h3-desktop text-gray-800 md:text-left text-center"
          data-i18n="project.related.title"
        >
          More projects
        </h2>
      </div>
    </div>

    {
      (() => {
        const otherProjects = sortedProjects.filter(
          (p) => p.slug !== project.slug && !ARCHIVED_CASE_SLUGS.has(p.slug) && !NON_ACTIVE_CASE_SLUGS.has(p.slug),
        );
        const randomProjects = otherProjects.sort(() => 0.5 - Math.random()).slice(0, 3);
        return (
          <div class="col-span-12 grid grid-cols-1 lg:grid-cols-3 gap-6">
            {randomProjects.map((proj) => (
              <a
                href={`/${proj.slug}`}
                class="group block rounded-3xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 transition-all duration-300 ease-in-out hover:-translate-y-1"
              >
                <div class="related-project-card rounded-xl overflow-hidden bg-gradient-to-br from-gray-50 to-gray-100 border-l-4 border border-gray-500 transition-all duration-300 ease-in-out group-hover:from-gray-100 group-hover:to-gray-200 group-hover:border-gray-400 group-focus-visible:-translate-y-1">
                  <img src={proj.image} alt={proj.name} class="w-full aspect-[4/3] sm:aspect-square md:aspect-[4/3] object-cover" loading="lazy" />
                  <div class="related-project-info p-4 border-t border-gray-500 transition-colors duration-300 group-hover:border-gray-400">
                    <h3 class="related-project-title text-h4-mobile font-bold mb-2">{proj.name}</h3>
                    <p
                      class="related-project-year text-sm text-gray-600 transition-colors duration-300"
                      data-semester={proj.semester || ""}
                      data-semester-da={proj.semester_da || ""}
                      data-year={proj.year || ""}
                      data-year-da={proj.year_da || ""}
                    >
                      {proj.semester || proj.year}
                    </p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        );
      })()
    }
  </section>
</MainLayout>

<style>
  body.dark #project-header h1,
  body.dark #project-header h2,
  body.dark #project-description,
  body.dark #tools-title {
    color: var(--text-on-dark);
  }

  body.dark a {
    color: var(--text-on-dark);
  }

  body.dark a:hover {
    color: var(--brand-primary-soft);
  }

  body.dark #figma-notice {
    border-color: #f3767f;
  }

  body.dark #db-notice {
    background-color: rgba(249, 115, 22, 0.18);
    border-color: #f97316;
  }

  body.dark #db-notice svg {
    color: #fdba74;
  }

  body.dark #db-notice p {
    color: #ffedd5;
  }

  body.dark #project-image {
    border-color: var(--dark-border);
  }

  body.dark #project-divider-1 {
    color: var(--dark-border);
  }

  body.dark #project-divider-1 .divider-center {
    background-color: var(--dark-surface-strong);
    border-color: var(--dark-border);
  }

  body.dark section:last-child .col-span-12 > div > a > div {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark #related-projects h2 {
    color: var(--text-on-dark);
  }

  body.dark .related-project-card {
    border-color: var(--dark-border);
    background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
  }

  body.dark .related-project-card:hover,
  body.dark .related-project-card:focus-visible {
    border-color: var(--dark-border-strong);
    background: linear-gradient(to bottom right, #3a3a3a, #2a2a2a);
  }

  body.dark .related-project-info {
    border-color: var(--dark-border);
  }

  body.dark .related-project-title,
  body.dark .related-project-year {
    color: var(--text-on-dark);
  }
</style>

<script>
  import { onReady } from "../scripts/inViewAhead";

  const applyDatabaseTranslations = (lang: string) => {
    const descriptionEl = document.querySelector("#project-description") as HTMLElement | null;
    const subtitleEl = document.querySelector("#project-subtitle") as HTMLElement | null;

    if (descriptionEl) {
      const description = descriptionEl.dataset.description || "";
      const descriptionDa = descriptionEl.dataset.descriptionDa || "";
      const currentDescription = lang === "da" ? descriptionDa || description : description;
      descriptionEl.textContent = currentDescription;
    }

    const getCurrentPeriod = (el: HTMLElement) => {
      const year = el.dataset.year || "";
      const yearDa = el.dataset.yearDa || "";
      const semester = el.dataset.semester || "";
      const semesterDa = el.dataset.semesterDa || "";

      const currentYear = lang === "da" ? yearDa || year : year;
      const currentSemester = lang === "da" ? semesterDa || semester : semester;

      return currentSemester || currentYear;
    };

    if (subtitleEl) {
      subtitleEl.textContent = getCurrentPeriod(subtitleEl);
    }

    document.querySelectorAll(".related-project-year").forEach((yearEl) => {
      const element = yearEl as HTMLElement;
      element.textContent = getCurrentPeriod(element);
    });
  };

  const getLang = () => localStorage.getItem("lang") || "en";

  const syncDatabaseTranslations = () => {
    applyDatabaseTranslations(getLang());
  };

  onReady(() => {
    syncDatabaseTranslations();
  });

  document.addEventListener("astro:page-load", () => {
    syncDatabaseTranslations();
  });

  window.addEventListener("langchange", (event: Event) => {
    const customEvent = event as CustomEvent;
    const lang = customEvent.detail?.lang || getLang();
    applyDatabaseTranslations(lang);
  });

</script>
