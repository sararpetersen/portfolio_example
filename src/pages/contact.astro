---
import Button from "../components/Button.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="SRP portfolio | Contact"
  description="Contact Sara"
  ogtitle="SRP portfolio - the portfolio of Sara Ringkow Petersen"
  ogdescription="Contact Sara through her email-address or phone-number"
>
  <!--  Contact Section -->
  <section id="contact" class="container mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <!-- Contact Information Section -->
    <div id="contact-form-container" class="flex flex-col md:flex-row gap-gap justify-center md:pt-28 pt-24">
      <!-- Image and Contact Info Box -->
      <div id="contact-container" class="md:col-span-10 col-span-12 flex flex-col md:flex-row items-center">
        <!-- Image with Enhanced Styling -->
        <div class="relative mb-12 md:mb-0 md:mr-16">
          <img
            src="/images/pfp.webp"
            alt="School-portrait of Sara (taken during the internship preparations)"
            class="w-56 h-56 md:w-[350px] md:h-[350px] object-cover rounded-full ring-1 ring-gray-500"
            width="350"
            height="350"
            loading="lazy"
          />
        </div>

        <!-- Contact Information Box -->
        <div>
          <p
            id="contact-title-label"
            class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4 md:text-left text-center"
            data-i18n="contact.label"
          >
            Contact
          </p>
          <h1
            id="contact-title"
            class="heading-title uppercase tracking-[0.14em] md:tracking-[0.18em] font-hiro md:text-left text-center mb-9 text-4xl md:text-5xl"
            data-i18n="contact.title"
          >
            Let's talk!
          </h1>
          <p id="contact-text" class="md:text-left text-center text-gray-800 pb-9 leading-relaxed max-w-xl" data-i18n="contact.text">
            If you're interested in working together, don't hesitate to get in touch. <br class="hidden md:block" /> You can use the form below or reach
            me directly via the contact methods listed here.
          </p>
          <div id="contact-info" class="p-8 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 shadow-sm">
            <ul class="md:space-y-6 space-y-4">
              <li class="some1 flex items-start gap-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-7 h-7 mr-2 text-gray-600"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                  ></path>
                </svg>
                <div>
                  <strong class="text-gray-950 block mb-2" data-i18n="contact.info.email">Email:</strong>
                  <a
                    href="mailto:sara.ringkow@gmail.com"
                    aria-label="Send email to 'sara.ringkow@gmail.com'"
                    class="transition-colors py-1 focus:outline-none focus:ring-2 focus:ring-pale-300 rounded">sara.ringkow@gmail.com</a
                  >
                </div>
              </li>
              <li class="some1 flex items-start gap-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-7 h-7 mr-2 text-gray-600"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-gray-800 block mb-2" data-i18n="contact.info.phone">Phone:</strong>
                  <a
                    href="tel:+4542428807"
                    aria-label="Call +45 42 42 88 07"
                    class="transition-colors py-1 focus:outline-none focus:ring-2 focus:ring-pale-300 rounded">+45 42 42 88 07</a
                  >
                </div>
              </li>
              <li class="some1 flex items-start gap-4">
                <svg
                  class="w-8 h-8 mr-2 text-gray-600"
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="45"
                  height="45"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    fill-rule="evenodd"
                    d="M12.51 8.796v1.697a3.738 3.738 0 0 1 3.288-1.684c3.455 0 4.202 2.16 4.202 4.97V19.5h-3.2v-5.072c0-1.21-.244-2.766-2.128-2.766-1.827 0-2.139 1.317-2.139 2.676V19.5h-3.19V8.796h3.168ZM7.2 6.106a1.61 1.61 0 0 1-.988 1.483 1.595 1.595 0 0 1-1.743-.348A1.607 1.607 0 0 1 5.6 4.5a1.601 1.601 0 0 1 1.6 1.606Z"
                    clip-rule="evenodd"></path>
                  <path d="M7.2 8.809H4V19.5h3.2V8.809Z"></path>
                </svg>
                <div>
                  <strong class="text-gray-800 block mb-2" data-i18n="contact.info.linkedin">LinkedIn:</strong>
                  <a
                    href="https://www.linkedin.com/in/sara-ringkow-petersen-49830b264/"
                    aria-label="Go to 'linkedin.com/in/sara-ringkow-petersen' (external link)"
                    class="transition-colors py-1 focus:outline-none focus:ring-2 focus:ring-pale-300 rounded"
                    >linkedin.com/in/sara-ringkow-petersen</a
                  >
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact-form-section" class="container max-w-6xl mx-auto md:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <div id="contact-form-intro" class="mb-8 max-w-3xl md:text-left text-center">
      <p
        id="contact-form-label"
        class="uppercase tracking-[0.16em] md:tracking-[0.25em] text-[11px] text-gray-500 mb-4"
        data-i18n="contact.form.label"
      >
        Get in touch
      </p>
      <h2
        id="contact-form-title"
        class="text-h3-desktop heading-title uppercase tracking-[0.14em] md:tracking-[0.18em] font-hiro mb-6"
        data-i18n="contact.form.title"
      >
        Send me a message
      </h2>
      <p id="contact-form-subtitle" class="text-gray-600 mb-8 max-w-2xl" data-i18n="contact.form.subtitle">
        Feel free to reach out with any questions or inquiries. I'll get back to you as soon as possible. If you're looking for a collaborator for
        your next digital project, tell me a bit about your idea.
      </p>
    </div>

    <div class="grid md:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] gap-gap items-center">
      <div>
        <form
          id="contact-form"
          name="contact"
          method="POST"
          action="/contact?submitted=true"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 p-8 shadow-sm"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Do not fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <!-- Name Field -->
          <div>
            <label for="form-name" class="block text-sm font-semibold text-gray-800 mb-2" data-i18n="contact.form.name"> Name </label>
            <input
              type="text"
              id="form-name"
              name="name"
              autocomplete="name"
              required
              class="w-full px-4 py-2 border border-gray-400 rounded-[5px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-300"
              placeholder="Your name"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="form-email" class="block text-sm font-semibold text-gray-800 mb-2" data-i18n="contact.form.email"> Email </label>
            <input
              type="email"
              id="form-email"
              name="email"
              autocomplete="email"
              required
              class="w-full px-4 py-2 border border-gray-400 rounded-[5px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-300"
              placeholder="your.email@example.com"
            />
          </div>

          <!-- Message Field -->
          <div>
            <label for="form-message" class="block text-sm font-semibold text-gray-800 mb-2" data-i18n="contact.form.message"> Message </label>
            <textarea
              id="form-message"
              name="message"
              autocomplete="off"
              required
              rows={6}
              class="w-full px-4 py-2 border border-gray-400 rounded-[5px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-300 resize-none"
              placeholder="Your message..."></textarea>
          </div>

          <!-- Submit Button -->
          <div class="pt-4 flex justify-center md:justify-start">
            <button
              type="submit"
              class="inline-flex w-auto items-center justify-center px-6 py-[10px] border-2 font-semibold rounded-[5px] transition duration-300 uppercase bg-transparent border-blue-900 text-blue-900 hover:bg-blue-900 hover:text-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-400"
              data-i18n="contact.form.submit"
            >
              Send Message
            </button>
          </div>

          <!-- Status Messages -->
          <div id="form-status" class="hidden rounded-lg p-4 text-sm font-medium" role="status" aria-live="polite"></div>
        </form>
      </div>

      <aside id="contact-form-media" class="hidden md:block">
        <div class="rounded-3xl border border-gray-500 border-r-4 overflow-hidden shadow-sm bg-gradient-to-br from-gray-50 to-gray-100">
          <img
            src="/images/contact_image.webp"
            alt="Decorative workspace scene for the contact section"
            class="w-full h-[460px] object-cover"
            width="640"
            height="360"
            loading="lazy"
          />
        </div>
      </aside>
    </div>
  </section>

  <section class="button-container mx-auto py-20 flex justify-center">
    <a href="/" class="mt-8 btn_container inline-flex" aria-label="Back to homepage">
      <Button variant="primary" size="small"><span data-i18n="btn.back">Back to homepage</span></Button>
    </a>
  </section>

  <script>
    import { inView } from "motion";

    document.addEventListener("DOMContentLoaded", () => {
      const reduceMotion = document.body.classList.contains("reduce-motion");

      if (!reduceMotion) {
        let animationIndex = 0;
        const registerInView = (selector: string, animationClass: string = "animate__fadeInUp") => {
          const element = document.querySelector(selector) as HTMLElement | null;
          if (!element) return;

          const delayMs = animationIndex * 60;
          inView(element, () => {
            element.classList.add("animate__animated", animationClass);
            element.style.animationDelay = `${delayMs}ms`;
            element.style.animationDuration = "1.6s";
          });

          animationIndex++;
        };

        [
          "#contact-title-label",
          "#contact-title",
          "#contact-text",
          "#contact-container img",
          "#contact-form-title",
          "#contact-form-subtitle",
          "#contact-form-label",
          "#contact-info",
          ".button-container",
          "#contact-form",
          "#contact-form-media",
        ].forEach((selector) => {
          registerInView(selector);
        });
      }

      const statusDiv = document.querySelector("#form-status") as HTMLElement | null;
      if (statusDiv) {
        const params = new URLSearchParams(window.location.search);
        if (params.get("submitted") === "true") {
          statusDiv.className = "block rounded-lg p-4 text-sm font-medium bg-green-50 text-green-800 border border-green-200";
          statusDiv.textContent = "Thank you! Your message has been sent successfully. I'll get back to you soon.";
        }
      }
    });
  </script>

  <style>
    :global(.animate__animated) {
      animation-duration: 1.6s !important;
    }

    :global(body.dark #contact-title) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-info) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-info strong),
    :global(body.dark #contact-info a),
    :global(body.dark #contact-text),
    :global(body.dark #contact-preferred strong),
    :global(body.dark #contact-preferred span),
    :global(body.dark .some1 svg),
    :global(body.dark #contact-title-label) {
      color: var(--text-on-dark-soft);
    }

    :global(body.dark #contact-info a:hover) {
      color: var(--brand-primary-soft);
    }

    :global(#contact-info a:hover) {
      color: var(--brand-primary);
    }

    :global(body.dark #contact-form-section h2),
    :global(body.dark #contact-form-section p) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-form-section label) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-form) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-form-media > div) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-form-media p) {
      color: var(--text-on-dark-soft);
    }

    :global(body.dark #contact-form input),
    :global(body.dark #contact-form textarea) {
      background-color: color-mix(in srgb, var(--dark-surface) 86%, #fff 14%);
      color: var(--text-on-dark);
      border-color: color-mix(in srgb, var(--dark-border) 72%, #dbe8ee 28%);
    }

    :global(body.dark #contact-form input::placeholder),
    :global(body.dark #contact-form textarea::placeholder) {
      color: color-mix(in srgb, var(--text-on-dark-soft) 78%, #8f9aa1 22%);
    }

    :global(body.dark #contact-form input:focus),
    :global(body.dark #contact-form textarea:focus) {
      border-color: color-mix(in srgb, var(--brand-primary-soft) 70%, #fff 30%);
      background-color: color-mix(in srgb, var(--dark-surface-strong) 74%, #fff 26%);
      box-shadow: 0 0 0 3px rgba(149, 188, 203, 0.24);
    }

    :global(body.dark #contact-form button[type="submit"]) {
      background-color: transparent;
      border-color: color-mix(in srgb, var(--brand-primary-soft) 72%, #eaf4f8 28%);
      color: color-mix(in srgb, var(--brand-primary-soft) 84%, #f4fbff 16%);
      font-weight: 700;
    }

    :global(body.dark #contact-form button[type="submit"]:hover),
    :global(body.dark #contact-form button[type="submit"]:focus-visible) {
      background-color: color-mix(in srgb, var(--brand-primary-soft) 88%, #d9edf5 12%);
      border-color: color-mix(in srgb, var(--brand-primary-soft) 88%, #d9edf5 12%);
      color: #102029;
    }
  </style>
</MainLayout>
