---
import Button from "../components/Button.astro";
import MainLayout from "../layouts/MainLayout.astro";
import ColorSymIcon from "../components/ColorSymIcon.astro";
---

<MainLayout
  title="Contact Sara | SRP Portfolio"
  description="Contact Sara Ringkow Petersen about UX/UI design, digital accessibility and inclusive web design in Denmark."
  ogtitle="Work with Sara – SRP Portfolio"
  ogdescription="Get in touch about UX/UI design, digital accessibility and inclusive web design."
>
  <!--  Contact Section -->
  <section id="contact" class="container max-w-6xl mx-auto lg:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <!-- Contact Information Section -->
    <div id="contact-form-container" class="flex flex-col md:flex-row gap-gap md:pt-28 pt-24">
      <!-- Image and Contact Info Box -->
      <div id="contact-container" class="w-full flex flex-col md:flex-row items-center">
        <!-- Image with Enhanced Styling -->
        <div class="relative md:mb-12 mb-0 md:mr-16 shrink-0">
          <img
            src="/images/pfp.webp"
            alt="School-portrait of Sara (taken during the internship preparations)"
            class="hidden lg:block w-56 h-56 lg:w-[350px] lg:h-[350px] object-cover rounded-full border-l-4 border border-gray-500"
            width="350"
            height="350"
            loading="lazy"
          />
        </div>

        <!-- Contact Information Box -->
        <div>
          <div id="contact-title-row" class="mb-3">
            <h1
              id="contact-title"
              class="heading-title uppercase tracking-[0.14em] md:tracking-[0.18em] font-nikumaru text-[1.85rem] md:text-h2-desktop"
              data-i18n="contact.title"
            >
              Get in touch
            </h1>
          </div>
          <p id="contact-text" class="text-left text-gray-800 mb-8 leading-relaxed max-w-xl" data-i18n="contact.text">
            If you'd like to work together or just have a question, you're welcome to reach out. Use the form or contact me directly using the
            information below.
          </p>
          <div id="contact-info" class="p-8 bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-r-4 border border-gray-500">
            <ul class="md:space-y-6 space-y-4">
              <li class="some1 flex items-start gap-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-7 h-7 mr-2 text-gray-600"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                  ></path>
                </svg>
                <div>
                  <strong class="text-gray-800 block mb-1" data-i18n="contact.info.email">Email</strong>
                  <a
                    href="mailto:sara.ringkow@gmail.com"
                    aria-label="Send email to 'sara.ringkow@gmail.com'"
                    class="transition-colors py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 rounded"
                    >sara.ringkow@gmail.com</a
                  >
                </div>
              </li>
              <li class="some1 flex items-start gap-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-7 h-7 mr-2 text-gray-600"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-gray-800 block mb-1" data-i18n="contact.info.phone">Phone</strong>
                  <a
                    href="tel:+4542428807"
                    aria-label="Call +45 42 42 88 07"
                    class="transition-colors py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300">+45 42 42 88 07</a
                  >
                </div>
              </li>
              <li class="some1 flex items-start gap-4">
                <svg
                  class="w-8 h-8 mr-2 text-gray-600"
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="45"
                  height="45"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    fill-rule="evenodd"
                    d="M12.51 8.796v1.697a3.738 3.738 0 0 1 3.288-1.684c3.455 0 4.202 2.16 4.202 4.97V19.5h-3.2v-5.072c0-1.21-.244-2.766-2.128-2.766-1.827 0-2.139 1.317-2.139 2.676V19.5h-3.19V8.796h3.168ZM7.2 6.106a1.61 1.61 0 0 1-.988 1.483 1.595 1.595 0 0 1-1.743-.348A1.607 1.607 0 0 1 5.6 4.5a1.601 1.601 0 0 1 1.6 1.606Z"
                    clip-rule="evenodd"></path>
                  <path d="M7.2 8.809H4V19.5h3.2V8.809Z"></path>
                </svg>
                <div>
                  <strong class="text-gray-800 block mb-1" data-i18n="contact.info.linkedin">LinkedIn</strong>
                  <a
                    href="https://www.linkedin.com/in/sara-ringkow-petersen-49830b264/"
                    aria-label="Go to 'linkedin.com/in/sara-ringkow-petersen' (external link)"
                    class="transition-colors py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300"
                    >linkedin.com/in/sara-ringkow-petersen</a
                  >
                </div>
              </li>
            </ul>
          </div>

          <p
            id="contact-services-label"
            data-i18n="contact.services.label"
            class="text-[14px] font-garamond italic font-light text-gray-600 uppercase tracking-widest mt-6 mb-2"
          >
            What I offer
          </p>
          <ul id="contact-services" class="flex flex-wrap gap-2" aria-label="Services offered">
            <li
              class="inline-flex items-center gap-0.5 px-2.5 py-1 text-xs font-semibold bg-green-100 border border-green-500 border-r-4 rounded-full text-green-800"
            >
              <ColorSymIcon letter="G" class="contact-tag-icon" /><span data-i18n="contact.services.uiux">UX/UI design</span>
            </li>
            <li
              class="inline-flex items-center gap-0.5 px-2.5 py-1 text-xs font-semibold bg-orange-100 border border-orange-400 border-r-4 rounded-full text-orange-800"
            >
              <ColorSymIcon letter="O" class="contact-tag-icon" /><span data-i18n="contact.services.web">Accessible web design</span>
            </li>
            <li
              class="inline-flex items-center gap-0.5 px-2.5 py-1 text-xs font-semibold bg-vermilion-100 border border-vermilion-500 border-r-4 rounded-full text-vermilion-800"
            >
              <ColorSymIcon letter="O" class="contact-tag-icon" /><span data-i18n="contact.services.concept">Development of concepts</span>
            </li>
            <li
              class="inline-flex items-center gap-0.5 px-2.5 py-1 text-xs font-semibold bg-red-100 border border-red-400 border-r-4 rounded-full text-red-800"
            >
              <ColorSymIcon letter="R" class="contact-tag-icon" /><span data-i18n="contact.services.brand">Brand and visual identity</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div id="contact-divider-1" class="max-w-6xl mx-auto lg:px-0 px-6 md:pt-20 pt-14 flex items-center gap-3 text-gray-300" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
    <span class="divider-center block h-2 w-2 rotate-45 border border-current/70 bg-white"></span>
    <span class="h-px flex-1 bg-gradient-to-r from-transparent via-current to-transparent opacity-70"></span>
  </div>

  <!-- Contact Form Section -->
  <section id="contact-form-section" class="container max-w-6xl mx-auto lg:px-0 px-6 md:pt-desktop-top pt-mobil-top">
    <div id="contact-form-intro" class="mb-8 max-w-3xl">
      <div id="contact-form-title-row" class="mb-3">
        <h2
          id="contact-form-title"
          class="font-garamond italic font-semibold text-h3-mobile md:text-h3-desktop text-gray-800"
          data-i18n="contact.form.title"
        >
          Send me a message
        </h2>
      </div>
      <p id="contact-form-subtitle" class="text-gray-600 mb-4 max-w-xl" data-i18n="contact.form.subtitle">
        I'll get back to you as soon as I can. If you're looking for a collaborator for your next project, feel free to reach out and tell me a bit
        about your idea.
      </p>
    </div>

    <div class="grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] gap-gap items-center">
      <div>
        <form
          id="contact-form"
          name="contact"
          method="POST"
          action="/contact/?submitted=true"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-3xl border-l-4 border border-gray-500 p-8"
        >
          <input type="hidden" name="form-name" value="contact" class="bg-[#fafafa]" />
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" /></label>
          </p>

          <div class="space-y-6">
            <!-- Name Field -->
            <div>
              <label for="form-name" class="block text-sm font-semibold text-gray-800 mb-2">
                <span data-i18n="contact.form.name">Name</span><span aria-hidden="true" class="text-red-500">*</span>
                <span class="sr-only">(required)</span>
              </label>
              <input
                type="text"
                id="form-name"
                name="name"
                autocomplete="name"
                required
                aria-required="true"
                class="bg-[#fafafa] w-full px-4 py-2 border border-gray-400 rounded-[5px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:border-transparent transition duration-300"
                placeholder="Your name"
              />
            </div>

            <!-- Email Field -->
            <div>
              <label for="form-email" class="block text-sm font-semibold text-gray-800 mb-2">
                <span data-i18n="contact.form.email">Email</span><span aria-hidden="true" class="text-red-500">*</span>
                <span class="sr-only">(required)</span>
              </label>
              <input
                type="email"
                id="form-email"
                name="email"
                autocomplete="email"
                required
                aria-required="true"
                class="bg-[#fafafa] w-full px-4 py-2 border border-gray-400 rounded-[5px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:border-transparent transition duration-300"
                placeholder="your.email@example.com"
              />
            </div>

            <!-- Message Field -->
            <div>
              <label for="form-message" class="block text-sm font-semibold text-gray-800 mb-2">
                <span data-i18n="contact.form.message">Message</span><span aria-hidden="true" class="text-red-500">*</span>
                <span class="sr-only">(required)</span>
              </label>
              <textarea
                id="form-message"
                name="message"
                autocomplete="off"
                required
                aria-required="true"
                rows={6}
                class="bg-[#fafafa] w-full px-4 py-2 border border-gray-400 rounded-[5px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-300 focus-visible:border-transparent transition duration-300 resize-none"
                placeholder="Your message..."></textarea>
            </div>

            <!-- Fine print: GDPR + what happens next -->
            <div class="space-y-2">
              <p class="text-xs text-gray-500 leading-relaxed" data-i18n="contact.form.gdpr">
                By submitting this form you agree to my <a
                  href="/terms"
                  class="underline underline-offset-2 hover:text-blue-500 transition duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 text-xs"
                  >Terms & Privacy Policy</a
                >.
              </p>
              <p class="text-xs text-gray-400 leading-relaxed max-w-md italic" data-i18n="contact.form.next">
                (After you hit send, your message goes straight to my inbox and a confirmation appears right here on the page – I usually reply within
                a couple of days)
              </p>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-center md:justify-start">
              <Button variant="secondary" size="small" type="submit"><span data-i18n="contact.form.submit">Send Message</span></Button>
            </div>
          </div>

          <!-- Status Messages: kept outside .space-y-6 so this hidden element doesn't
               absorb a sibling gap meant for the (visible) submit button above it. -->
          <div id="form-status" class="hidden mt-6 rounded-lg p-4 text-sm font-medium" role="status" aria-live="polite"></div>
        </form>
      </div>

      <aside id="contact-form-media" class="hidden lg:block">
        <div class="rounded-3xl border border-gray-500 border-r-4 overflow-hidden bg-gradient-to-br from-gray-50 to-gray-100">
          <img
            src="/images/contact_image.webp"
            alt="An everyday picture of Sara, taken during a trip to the ocean"
            class="w-full h-[460px] object-cover"
            width="640"
            height="360"
            loading="lazy"
          />
        </div>
      </aside>
    </div>
  </section>

  <section class="button-container mx-auto py-20 flex justify-center">
    <Button href="/" variant="primary" size="small" aria-label="Back to homepage"><span data-i18n="btn.back">Back to homepage</span></Button>
  </section>

  <script>
    import { inView, onReady } from "../scripts/inViewAhead";

    onReady(() => {
      const reduceMotion = document.body.classList.contains("reduce-motion") || window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduceMotion) document.body.classList.add("reduce-motion");

      if (!reduceMotion) {
        let animationIndex = 0;
        const registerInView = (selector: string, animationClass: string = "animate__fadeInUp") => {
          const element = document.querySelector(selector) as HTMLElement | null;
          if (!element) return;

          const delayMs = animationIndex * 60;
          inView(element, () => {
            element.style.animationDelay = `${delayMs}ms`;
            element.style.animationDuration = "1.6s";
            element.style.animationFillMode = "both";
            element.classList.add("animate__animated", animationClass);
          });

          animationIndex++;
        };

        [
          "#contact-title-label",
          "#contact-title-row",
          "#contact-text",
          "#contact-container img",
          "#contact-divider-1",
          "#contact-form-title-row",
          "#contact-form-subtitle",
          "#contact-form-label",
          "#contact-info",
          "#contact-services-label",
          ".button-container",
          "#contact-form",
          "#contact-form-media",
        ].forEach((selector) => {
          registerInView(selector);
        });

        document.querySelectorAll("#contact-services li").forEach((el) => {
          const delayMs = animationIndex * 60;
          inView(el as HTMLElement, () => {
            (el as HTMLElement).style.animationDelay = `${delayMs}ms`;
            (el as HTMLElement).style.animationDuration = "1.6s";
            (el as HTMLElement).style.animationFillMode = "both";
            (el as HTMLElement).classList.add("animate__animated", "animate__fadeInUp");
          });
          animationIndex++;
        });
      }

      const textarea = document.querySelector("#form-message") as HTMLElement | null;
      const contactForm = document.querySelector("#contact-form") as HTMLElement | null;

      if (textarea && contactForm && window.matchMedia("(min-width: 768px)").matches) {
        const observer = new ResizeObserver(() => {
          const style = getComputedStyle(contactForm);
          const paddingH = parseFloat(style.paddingLeft) + parseFloat(style.paddingRight);
          contactForm.style.minWidth = textarea.offsetWidth + paddingH + "px";
        });
        observer.observe(textarea);
      }

      const statusDiv = document.querySelector("#form-status") as HTMLElement | null;
      if (statusDiv) {
        const params = new URLSearchParams(window.location.search);
        if (params.get("submitted") === "true") {
          statusDiv.className = "block rounded-lg p-4 text-sm font-medium bg-green-50 text-green-800 border border-green-200";
          statusDiv.textContent = "Thank you! Your message has been sent successfully. I'll get back to you soon.";
        }
      }
    });
  </script>

  <style>
    :global(.contact-tag-icon) {
      width: 0.95em;
      height: 0.95em;
    }

    @media (min-width: 768px) {
      :global(#form-message) {
        resize: both;
      }
    }

    :global(.animate__animated) {
      animation-duration: 1.6s !important;
    }

    :global(html.has-js body:not(.reduce-motion) #contact-title-label),
    :global(html.has-js body:not(.reduce-motion) #contact-title-row),
    :global(html.has-js body:not(.reduce-motion) #contact-text),
    :global(html.has-js body:not(.reduce-motion) #contact-container img),
    :global(html.has-js body:not(.reduce-motion) #contact-divider-1),
    :global(html.has-js body:not(.reduce-motion) #contact-form-title-row),
    :global(html.has-js body:not(.reduce-motion) #contact-form-subtitle),
    :global(html.has-js body:not(.reduce-motion) #contact-form-label),
    :global(html.has-js body:not(.reduce-motion) #contact-info),
    :global(html.has-js body:not(.reduce-motion) #contact-services-label),
    :global(html.has-js body:not(.reduce-motion) .button-container),
    :global(html.has-js body:not(.reduce-motion) #contact-form),
    :global(html.has-js body:not(.reduce-motion) #contact-form-media),
    :global(html.has-js body:not(.reduce-motion) #contact-services li) {
      opacity: 0;
      transform: translate3d(0, 1.25rem, 0);
      will-change: transform, opacity;
    }

    :global(body.dark #contact-title) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-info) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-info strong),
    :global(body.dark #contact-info a),
    :global(body.dark #contact-text),
    :global(body.dark .some1 svg),
    :global(body.dark #contact-title-label) {
      color: var(--text-on-dark-soft);
    }

    :global(body.dark #contact-info a:hover) {
      color: var(--brand-primary-soft);
    }

    :global(#contact-info a:hover) {
      color: var(--brand-primary);
    }

    :global(body.dark #contact-form-section h2),
    :global(body.dark #contact-form-section p) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-form-section label) {
      color: var(--text-on-dark);
    }

    :global(body.dark #contact-form) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-form-media > div) {
      border-color: var(--dark-border);
      background: linear-gradient(to bottom right, var(--dark-gradient-start), var(--dark-gradient-end));
    }

    :global(body.dark #contact-divider-1) {
      color: var(--dark-border);
    }

    :global(body.dark #contact-divider-1 .divider-center) {
      background-color: var(--dark-surface-strong);
      border-color: var(--dark-border);
    }

    :global(body.dark #contact-form-media p) {
      color: var(--text-on-dark-soft);
    }

    :global(body.dark #contact-services-label) {
      color: var(--text-on-dark-soft);
    }

    :global(body.dark #contact-services li:nth-child(1)) {
      background-color: color-mix(in srgb, #22c55e 20%, var(--dark-surface) 80%);
      border-color: #4ade80;
      color: #dcfce8;
    }
    :global(body.dark #contact-services li:nth-child(2)) {
      background-color: color-mix(in srgb, #f97316 20%, var(--dark-surface) 80%);
      border-color: #fb923c;
      color: #ffedd5;
    }
    :global(body.dark #contact-services li:nth-child(3)) {
      background-color: color-mix(in srgb, #dc6d57 20%, var(--dark-surface) 80%);
      border-color: #e99180;
      color: #fbe9e5;
    }
    :global(body.dark #contact-services li:nth-child(4)) {
      background-color: color-mix(in srgb, #e63946 20%, var(--dark-surface) 80%);
      border-color: #f3767f;
      color: #fde3e5;
    }

    :global(body.calm-mode #contact-services li) {
      background-color: #f0ebe6;
      border-color: #8f8882;
      color: #4b4b4b;
    }

    :global(body.dark.calm-mode #contact-services li) {
      background-color: color-mix(in srgb, var(--dark-surface-strong) 80%, #fff 20%);
      border-color: var(--dark-border);
      color: var(--text-on-dark-soft);
    }

    :global(html.text-large #contact-services li) {
      font-size: 0.8rem;
      padding: 0.25rem 0.85rem;
    }

    :global(body.dark #contact-form input),
    :global(body.dark #contact-form textarea),
    :global(body.dark #contact-form select) {
      background-color: color-mix(in srgb, var(--dark-surface) 86%, #fff 14%);
      color: var(--text-on-dark);
      border-color: color-mix(in srgb, var(--dark-border) 72%, #dbe8ee 28%);
    }

    :global(body.dark #contact-form input::placeholder),
    :global(body.dark #contact-form textarea::placeholder) {
      color: color-mix(in srgb, var(--text-on-dark-soft) 78%, #8f9aa1 22%);
    }

    :global(body.dark #contact-form input:focus),
    :global(body.dark #contact-form textarea:focus),
    :global(body.dark #contact-form select:focus) {
      border-color: color-mix(in srgb, var(--brand-primary-soft) 70%, #fff 30%);
      background-color: color-mix(in srgb, var(--dark-surface-strong) 74%, #fff 26%);
      box-shadow: 0 0 0 3px rgba(149, 188, 203, 0.24);
    }

    :global(body.dark p[data-i18n="contact.form.gdpr"]),
    :global(body.dark p[data-i18n="contact.form.next"]) {
      color: var(--text-on-dark-soft, #c0c0c0);
    }
    :global(body.dark p[data-i18n="contact.form.gdpr"] a) {
      color: var(--brand-primary-soft, #c0d7e1);
    }
    :global(body.dark p[data-i18n="contact.form.gdpr"] a:hover) {
      color: var(--brand-primary-strong, #95bccb);
    }
  </style>
</MainLayout>
